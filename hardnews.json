otogaleria/pompa-boa-disposicao-familia-real-juntase-casamento-peter-phillips-415601","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"Ímpar","url":"https://www.publico.pt/2026/06/07/impar/fotogaleria/pompa-boa-disposicao-familia-real-juntase-casamento-peter-phillips-415601"},"id":415601,"type":"FOTOGALERIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"<em>Power dressing</em> foi tendência nos anos 1980, mas sempre nos vestimos para o poder","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2091403?tp=UH&db=IMAGENS&type=JPG","author":[{"id":12425,"nome":"Inês Duarte de Freitas","descricao":"","email":"ines.freitas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ines-duarte-freitas","imagem":{"w":null,"h":null,"largura":344,"altura":320,"nome":"WhatsApp_Image_2023-02-01_at_13.49.04-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1775300?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#105;&#101;&#114;&#102;&#46;&#115;&#101;&#110;&#105;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Na mesma altura em que ascendem a cargos de topo, os ombros com chumaços exagerados tomaram conta dos armários das mulheres. Mas não há uma só definição de <em>power dressing</em>.","url":"/2026/06/06/impar/noticia/power-dressing-tendencia-anos-1980-vestimos-2175894","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"Revista Ímpar","url":"https://www.publico.pt/2026/06/06/impar/noticia/power-dressing-tendencia-anos-1980-vestimos-2175894"},"id":2175894,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":23,"title":"Bárbara Bulhosa: “O telemóvel é o maior inimigo da leitura de um livro”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2093718?tp=UH&db=IMAGENS&type=JPG","author":[{"id":281,"nome":"Ana Sá Lopes","descricao":"Sempre quis ser jornalista, ao mesmo tempo que automobilista de Fórmula 1 (não tenho carta de condução) e arqueóloga, por causa de Michel Vaillant e Blake e Mortimer. Acabei por começar a escrever coisas no jornal da terra onde vivi desde criança, a Gazeta das Caldas, de Caldas da Rainha. Como toda a minha geração de jornalistas, andei pelas rádios piratas, a Rádio Litoral Oeste e a Rádio Margem. Concorri a um concurso de estagiários para o extinto semanário \"O Jornal\" e para meu júbilo fui uma das seleccionadas. Fui muito feliz por lá, como na fundação do PÚBLICO, um momento transcendental na vida de todos os que passámos por isso. No PÚBLICO trabalhei essencialmente na secção política, fui jornalista parlamentar, \"fiz\" o PSD, umas reportagens razoáveis em Angola e Timor-Leste e fui durante uns anos editora de política. Saí do jornal no fim de 2005, passei dois anos no Diário de Notícias, onde fui redactora-principal e depois editora de política. Saí do DN em 2008 para fazer parte da equipa fundadora do i. No i fui directora adjunta de Janeiro de 2011 até à minha saída em  Julho de 2018, quando o director Manuel Carvalho me convidou para ser directora-adjunta do PÚBLICO. Com a remodelação da direcção editorial do PÚBLICO, passei a redactora principal em Setembro deste ano.","email":"ana.sa.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Redactora-principal","profissaoNaAltura":"Redactora-principal","slug":"ana-sa-lopes","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"ana-sa-lopes-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1739858?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Ana Sousa Dias","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#97;&#115;&#46;&#97;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Um das fundadoras da Tinta-da-China, chancela que já leva duas décadas, fala dos desafios do livro, da leitura e da sua editora: “É uma proeza mantermo-nos há 20 anos totalmente independentes”.","url":"/2026/06/07/culturaipsilon/entrevista/barbara-bulhosa-telemovel-maior-inimigo-leitura-livro-2177274","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista","url":"/podcast-arde"},"id":2177274,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":17536,"nome":"Podcast O que fazer quando tudo arde","slug":"podcast-arde","tagEn":"","isPrincipal":false,"isVisible":true,"urlRoute":"/tpodcast-arde","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAberto":false,"follow_type":null,"descricao":null,"imagem":null,"html":null,"isForForuns":false,"isUsedInForuns":false},"size":30},{"pos":24,"title":"Programa de Saúde Escolar prevê mais projectos de educação sexual em 40% das escolas","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2093780?tp=UH&db=IMAGENS&type=JPG","author":[{"id":495,"nome":"Andreia Sanches","descricao":"Entrei no PÚBLICO em 1996. Tinha 22 anos, terminado o curso de Ciências da Comunicação na Universidade Nova de Lisboa e estava no jornal onde queria, de facto, começar a fazer jornalismo. Estagiei no Internacional, quando ainda fazíamos fila para aceder ao computador da redacção que estava ligado à Internet. Seguiu-se a Educação, onde fiquei vários anos, quando aquela era uma secção autónoma, diária. Já na Sociedade, o leque de temas sobre os quais passei a escrever alargou-se – a pobreza e as desigualdades, a exclusão e as políticas de protecção social são alguns dos que tenho acompanhado de forma mais sistemática. Em 2013 foi publicado o meu primeiro livro. Chama-se \"Os Anjos Não Comem Chocolate\" e tem como ponto de partida uma reportagem que fiz no PÚBLICO sobre pais que perderam os seus filhos. Ao longo dos últimos anos desempenhei funções de editora do P2, editora da Sociedade, editora-executiva e directora-adjunta.","email":"asanches@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Redactora principal","profissaoNaAltura":"","slug":"andreia-sanches","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"andreia-sanches-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1748990?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Andreia C. Faria","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#104;&#99;&#110;&#97;&#115;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Saúde mental e actividade física são outras prioridades. Programa entrou em discussão pública. Até 2030 todas as escolas devem ter “espaços adequados para prática de actividade física”.","url":"/2026/06/07/sociedade/noticia/novo-programa-saude-escolar-preve-aumento-projectos-educacao-sexual-menos-40-escolas-2177352","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Direcção-Geral da Saúde","url":"https://www.publico.pt/2026/06/07/sociedade/noticia/novo-programa-saude-escolar-preve-aumento-projectos-educacao-sexual-menos-40-escolas-2177352"},"id":2177352,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":25,"title":"O <em>smartwatch </em>que quer dominar 2026 já chegou a Portugal","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2089140?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"O HUAWEI Watch Fit 5 Pro aposta num equilíbrio raro: métricas avançadas de desporto e saúde, materiais premium e um design leve para acompanhar tanto a corrida ao fim da tarde como um dia de trabalho.","url":"/2026/05/21/estudiop/noticia/smartwatch-quer-dominar-2026-ja-chegou-portugal-2175111","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Huawei","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1650273?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/05/21/estudiop/noticia/smartwatch-quer-dominar-2026-ja-chegou-portugal-2175111"},"id":2175111,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":26,"title":"Quem são e o que defendem os candidatos a juiz do TC","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2093785?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3898,"nome":"Liliana Borges","descricao":"","email":"liliana.borges@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"liliana-pascoal-borges","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"liliana-borges.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1172095?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#103;&#114;&#111;&#98;&#46;&#97;&#110;&#97;&#105;&#108;&#105;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Quatro juristas de perfis distintos foram indicados por PSD, PS e Chega para o Tribunal Constitucional, num acordo político que antecede a votação no Parlamento, agendada para sexta-feira.","url":"/2026/06/06/politica/noticia/sao-defendem-candidatos-juiz-tribunal-constitucional-2177339","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Tribunal Constitucional","url":"https://www.publico.pt/2026/06/06/politica/noticia/sao-defendem-candidatos-juiz-tribunal-constitucional-2177339"},"id":2177339,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":27,"title":"Yolanda Díaz: “Quando damos direitos às mulheres, aos migrantes, todos ganhamos”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2093745?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3150,"nome":"Raquel Martins","descricao":"Aos 15 anos decidi que queria mudar o mundo e, para desgosto da minha professora de Português, quis ser jornalista. Fiz o curso de Ciências da Comunicação na Universidade Nova, frequentei o Cenjor e andei indecisa entre a rádio e a imprensa. Depois de uma breve passagem pela rádio (Antena 3 e Rádio Expo), acabei por entrar no jornalismo económico um pouco por acaso. Primeiro, no Diário Económico – onde escrevi sobre ambiente, autarquias, política e, mais tarde, sobre trabalho e função pública – depois no Jornal de Negócios. Foi por isso que, em 2009, fiz uma formação na Universidade Católica sobre legislação laboral. Estou no PÚBLICO desde 2010. Acompanho os assuntos relacionados com trabalho, emprego e administração pública (há quem diga, com humor, que o Código do Trabalho é o meu livro de cabeceira.) Defendo que o jornalismo tem um papel cada vez mais importante na descodificação da avalanche de informação que todos os dias circula nas mais diversas plataformas.","email":"raquel.martins@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"raquel-martins","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"raquel-martins-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1991256?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Debi Thomas","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#110;&#105;&#116;&#114;&#97;&#109;&#46;&#108;&#101;&#117;&#113;&#97;&#114;","contribuicao":"","tipo":"INTERNO"},{"id":6310,"nome":"Inês Chaíça","descricao":"","email":"ines.chaica@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"ines-chaica","imagem":{"w":null,"h":null,"largura":544,"altura":459,"nome":"Inês_profile_pic-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/2003976?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#99;&#105;&#97;&#104;&#99;&#46;&#115;&#101;&#110;&#105;","contribuicao":"texto","tipo":"INTERNO"},{"id":3976,"nome":"Nuno Ferreira Santos","descricao":"","email":"nuno.santos@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"nuno-ferreira-santos","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#111;&#116;&#110;&#97;&#115;&#46;&#111;&#110;&#117;&#110;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"A vice-presidente do Governo de Espanha e ministra do Trabalho alerta que o pacote laboral português “vai prejudicar a economia do país” e “é um retrocesso democrático”.","url":"/2026/06/06/economia/entrevista/yolanda-diaz-damos-direitos-mulheres-migrantes-ganhamos-2177306","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista","url":"/espanha"},"id":2177306,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":28,"title":"Fujimori e Sánchez querem ser a resposta para a fragmentação da política no Peru","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2092942?tp=UH&db=IMAGENS&type=JPG","author":[{"id":5355,"nome":"António Saraiva Lima","descricao":"Pertenço a uma geração indefinida e vesti a camisola como poucos. Experimentei Direito, viajei e desviei-me. Pelo meio, escrevi. Licenciei-me em Ciência Política e Relações Internacionais, andei a debater sobre a Europa num <i>think tank</i>, e estagiei numa afamada organização internacional. Continuei a escrever. Tropecei no jornalismo em 2015, e logo no PÚBLICO, para um estágio na inigualável secção Mundo. Três meses de instrução diária, com os melhores dos melhores, que se alongaram para cinco. Sempre a escrever, mas também a perguntar e a ouvir. Ainda testei o ofício diplomático-consular, em Inglaterra, apenas para confirmar que a indefinição que me corria no sangue estava afinal fora de prazo. Voltei para Lisboa, realistei-me no jornalismo, pela mão do <i>i</i> e do <i>Sol</i>, e terminei um mestrado em Estudos Europeus. Permanentemente a escrever. No início de 2018 voltei à casa de partida – precisamente no meio do tabuleiro e deste texto.","email":"antonio.lima@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"antonio-saraiva-lima","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Antonio Saraiva Lima.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1527215?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":",Norges teknisk-naturvitenskaplige universitet","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#109;&#105;&#108;&#46;&#111;&#105;&#110;&#111;&#116;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Filha de antigo ditador e aliado de Castillo disputam segunda volta das presidenciais peruanas. Abstenção e votos nulos ou brancos podem ser decisivos para o desfecho da votação deste domingo.","url":"/2026/06/07/mundo/noticia/fujimori-sanchez-querem-resposta-fragmentacao-politica-peru-2176967","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Eleições","url":"https://www.publico.pt/2026/06/07/mundo/noticia/fujimori-sanchez-querem-resposta-fragmentacao-politica-peru-2176967"},"id":2176967,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":29,"title":"Morreu Patrick Godfrey, de <em>Para Sempre Cinderela</em> ou <em>Os Miseráveis</em>","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2093813?tp=UH&db=IMAGENS&type=JPG","author":[{"id":973,"nome":"PÚBLICO","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"publico","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Actor britânico “morreu tranquilamente em casa, rodeado pela família”, na última quinta-feira, anunciou a agência Markham, Froggatt & Irwin.","url":"/2026/06/07/culturaipsilon/noticia/morreu-patrick-godfrey-cinderela-miseraveis-2177379","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Óbito","url":"https://www.publico.pt/2026/06/07/culturaipsilon/noticia/morreu-patrick-godfrey-cinderela-miseraveis-2177379"},"id":2177379,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30}]
