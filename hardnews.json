cia/agiotas-raptaram-jovem-reaver-dinheiro-emprestado-2173371","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Polícia Judiciária","url":"https://www.publico.pt/2026/05/03/sociedade/noticia/agiotas-raptaram-jovem-reaver-dinheiro-emprestado-2173371"},"id":2173371,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":9,"title":"Pedro Sampaio Nunes: “Portugal precisa de quatro centrais nucleares”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2085526?tp=UH&db=IMAGENS&type=JPG","author":[{"id":486,"nome":"Cristina Ferreira","descricao":"","email":"cferreira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"cristina-ferreira","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Cristisna ferreira nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1153416?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#114;&#101;&#102;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Histórico defensor do nuclear em Portugal, Pedro Sampaio Nunes avisa que a actual estratégia nacional energética é “insustentável” e “incapaz de assegurar previsibilidade à economia”.","url":"/2026/05/03/economia/entrevista/pedro-sampaio-nunes-portugal-precisa-quatro-centrais-nucleares-2173025","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista","url":"/energia"},"id":2173025,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":10,"title":"FC Porto reiniciou sistema com processador topo de gama","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2085564?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1059,"nome":"Nuno Sousa","descricao":"Primeiro, foi a informação local. Em Aveiro, durante um ano (o de 2003), ajudei a levantar um dos quatro cadernos regionais que o PÚBLICO chegou a oferecer aos leitores, antes de me tornar editor do entretanto extinto Local Centro. A viagem para norte foi relativamente rápida e, em 2005, assumi a editoria do Local Porto, da qual me despediria no final de 2007, para ocupar o cargo que actualmente desempenho, na chefia da secção de Desporto. Desde então, tenho olhado para a actualidade desportiva com a avidez e o interesse do dia de estreia. E acompanhado o relançamento do site de Desporto, a criação de canais dedicados (Jogos Olímpicos, Europeu, Mundial de futebol) e a edição de suplementos em papel com a mesma lupa que uso para aperfeiçoar o jornal que todos os dias sai para as bancas.","email":"nsousa@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editor de Desporto","profissaoNaAltura":"Editor de Desporto","slug":"nuno-sousa","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"nsousa.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1951120?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Liga Europa da UEFA","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#115;&#117;&#111;&#115;&#110;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"“Azuis e brancos” conquistaram o 13.º título neste século, graças a uma aposta desportiva e financeira de risco e a uma coesão defensiva fora do comum.","url":"/2026/05/02/desporto/noticia/fc-porto-reiniciou-sistema-processador-topo-gama-2173298","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Futebol nacional","url":"https://www.publico.pt/2026/05/02/desporto/noticia/fc-porto-reiniciou-sistema-proc