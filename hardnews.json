pinion":false,"homeBrand":null,"brand":{"id":0,"name":"Fundação BIAL","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1366934?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/03/16/estudiop/noticia/revolucao-terapeutica-luta-cancro-2168011"},"id":2168011,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":25,"title":"Servane Mouton: “As redes sociais populares são ilegais ao abrigo da lei europeia”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2074007?tp=UH&db=IMAGENS&type=JPG","author":[{"id":5669,"nome":"Claudia Carvalho Silva","descricao":"Nasci em Neuchâtel, na Suíça – daí que escreva o meu nome sem acento. Mais tarde, já em Portugal, estive dividida entre as ciências e as letras, num ímpeto constante de querer fazer e aprender tudo ao mesmo tempo. Decidi deixar de lado a certeza de que o coração não tem vontade e estudar Jornalismo na Faculdade de Letras da Universidade de Coimbra. Passei pelo jornal universitário <i>A Cabra</i>, a revista <i>Via Latina</i> e o Festival Caminhos do Cinema Português. E, no final de 2015, cheguei ao PÚBLICO para estagiar na secção Local, onde descobri algumas das histórias que Lisboa tem para contar. Depois de abraçar o desafio online, integrei a equipa fundadora do Azul, o nosso projecto dedicado à crise climática, que editei durante dois anos. Agora, estou no P3. E aprendo todos os dias.","email":"claudia.silva@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"claudia-carvalho-silva","imagem":{"w":null,"h":null,"largura":437,"altura":572,"nome":"CLAUDIACARVALHOSILVA_REDIMENSIONADA-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1440637?tp=UH&db=IMAGENS&type=PNG","is_vertical":true,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#118;&#108;&#105;&#115;&#46;&#97;&#105;&#100;&#117;&#97;&#108;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"A neurologista Servane Mouton escreveu um livro para alertar para os perigos dos ecrãs, do sedentarismo à saúde mental. E defende um outro modelo para fugir das actuais redes que manipulam e viciam.","url":"/2026/03/16/p3/noticia/servane-mouton-redes-sociais-populares-sao-ilegais-utilizam-algoritmos-manipuladores-2167868","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"p3"},"brand":null,"rubric":{"name":"Tecnologia","url":"https://www.publico.pt/2026/03/16/p3/noticia/servane-mouton-redes-sociais-populares-sao-ilegais-utilizam-algoritmos-manipuladores-2167868"},"id":2167868,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":26,"title":"De Kolovrat no museu à customização de Dino Alves: os destaques da 66.ª ModaLisboa","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2074525?tp=UH&db=IMAGENS&type=JPG","author":[{"id":12425,"nome":"Inês Duarte de Freitas","descricao":"","email":"ines.freitas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ines-duarte-freitas","imagem":{"w":null,"h":null,"largura":344,"altura":320,"nome":"WhatsApp_Image_2023-02-01_at_13.49.04-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1775300?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#105;&#101;&#114;&#102;&#46;&#115;&#101;&#110;&#105;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"De 12 a 15 de Março, o evento de moda da capital voltou a montar a <em>passerelle </em>do Pátio da Galé e destacou-se quem tem algo a dizer sobre o mundo. As escolhas do PÚBLICO.","url":"/2026/03/16/impar/noticia/kolovrat-museu-customizacao-dino-alves-sete-destaques-66-modalisboa-2167998","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"ModaLisboa","url":"https://www.publico.pt/2026/03/16/impar/noticia/kolovrat-museu-customizacao-dino-alves-sete-destaques-66-modalisboa-2167998"},"id":2167998,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":27,"title":"<em>Dinastias: Os Murdoch</em> é quase um documentário sobre <em>Succession</em>","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2074322?tp=UH&db=IMAGENS&type=JPG","author":[{"id":136,"nome":"Joana Amaral Cardoso","descricao":"Comecei na secção de Sociedade em 1999, dali fui para o Publico.pt e como colaboradora da revista Pública escrevi sobre tendências sociais e Manias. Em 2006 comecei a debruçar-me sobre uma das áreas que mais me interessam – o audiovisual. Depois, já na secção de Cultura, onde sou hoje jornalista, juntei a isto tudo a cultura popular, o cinema, a moda, o design e interesso-me em aplicar a lente do género a muitos fenómenos.  Em 2009 editei a secção de Televisão da revista TimeOut e mais recentemente dei aulas de Jornalismo de Moda. No Público também editei a secção da Cultura online, fui subeditora da revista Pública e co-editora da revista Fugas. E vejo demasiada televisão.","email":"joana.cardoso@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"joana-amaral-cardoso","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#115;&#111;&#100;&#114;&#97;&#99;&#46;&#97;&#110;&#97;&#111;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Série de Liz Garbus na Netflix relata décadas de lutas intestinas e influência de uma família nos <em>media</em> e na sociedade. Tem um potente precedente na série de ficção da HBO, e não o esquece.","url":"/2026/03/16/culturaipsilon/noticia/dinastias-murdoch-quase-documentario-succession-2167932","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Televisão","url":"https://www.publico.pt/2026/03/16/culturaipsilon/noticia/dinastias-murdoch-quase-documentario-succession-2167932"},"id":2167932,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":28,"title":"Dmitro Kuleba: “Toda a gente verá que a promessa de segurança e unidade da UE é falsa”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/canal_videos/videoPortal/Images/202603/kuleba297732.jpg?tp=VIDEOS","author":[{"id":12744,"nome":"Tiago Bernardo Lopes","descricao":"Licenciei-me em Cinema e Audiovisual, na ESAP, por achar que ao estudar Cinema aprenderia também sobre Fotografia. Não foi o caso. Mais tarde, integrei mesmo o Curso Profissional de Fotografia no IPF do Porto, tendo-me focado mais na área documental. \r\nDepois de dois estágios (o primeiro em fotojornalismo, interrompido pela pandemia em 2020, e o segundo em jornalismo multimédia), integrei o PÚBLICO em 2022 na equipa de vídeo, ligado ao Azul.","email":"tiago.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Fotojornalista e Jornalista Multimédia","profissaoNaAltura":"Fotojornalista e Jornalista Multimédia","slug":"tiago-lopes","imagem":{"w":null,"h":null,"largura":1066,"altura":977,"nome":"5ec3f5a3-9e45-47f0-8ec2-be86b9a9010e-removebg.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1796704?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Jogador de tênis","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#111;&#103;&#97;&#105;&#116;","contribuicao":null,"tipo":"INTERNO"},{"id":12789,"nome":"Ivo Neto","descricao":"Cheguei ao jornalismo com idade para ter juízo. Foi em 2016, aos 28 anos. Comecei no JN, na imponente torre da Gonçalo Cristóvão, no coração do Porto, como Gestor de Redes Sociais, passando depois para a equipa do Online. Em 2020, semanas antes de o mundo se fechar em casa, entrei para o PÚBLICO para integrar a equipa de editores da secção Online. Sou agora Editor do Mundo. Já escrevi sobre tudo um pouco: Saúde, Ciência, Natureza ou Tecnologia e Desinformação. Mas é de olhar para o Mundo que mais gosto. Pelo meio tirei um doutoramento que me levou a Austin, no Texas. Sou também professor Associado na Universidade da Maia.","email":"ivo.neto@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Jornalista e editor na secção Mundo","profissaoNaAltura":"Jornalista e editor na secção Mundo","slug":"ivo-neto","imagem":{"w":null,"h":null,"largura":511,"altura":488,"nome":"2-removebg-preview (1).png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1567262?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Tartan","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#116;&#101;&#110;&#46;&#111;&#118;&#105;","contribuicao":null,"tipo":"INTERNO"},{"id":4123,"nome":"João Ruela Ribeiro","descricao":"","email":"joao.ruela@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"joao-ruela-ribeiro","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#108;&#101;&#117;&#114;&#46;&#111;&#97;&#111;&#106;","contribuicao":null,"tipo":"INTERNO"}],"shares":0,"description":"<p>O ex-ministro dos Neg&oacute;cios Estrangeiros da Ucr&acirc;nia considera que a UE t&ecirc;m de preparar os cidad&atilde;os para um eventual conflito com a R&uacute;ssia.</p>\r\n","url":"/2026/03/16/mundo/video/dmitro-kuleba-gente-vera-promessa-seguranca-unidade-ue-falsa-20260313-173054","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Vídeo","url":"/video-"},"id":97732,"type":"VIDEO","isMultipleRubric":false,"tag":null,"size":30},{"pos":29,"title":"E os Óscares vão para... As escolhas e previsões do Ípsilon","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/canal_videos/videoPortal/Images/202603/OscaresVCamara_Ficha97729.jpg?tp=VIDEOS","author":[{"id":885,"nome":"Vasco Câmara","descricao":"Foi depois de ter entrado pela casa que Gloria Swanson teve em Sintra, onde vi junto à piscina um animal empalhado, que me deixaram, aqui no PÚBLICO, meter as mãos no cinema. Isto foi no início deste projecto jornalístico. Eu fui um dos 25 estagiários admitidos depois de um curso de meses que começou com 500 candidatos de todo o país. Após a história da estrela dos anos 20 que vinha descansar perto da praia das Maçãs, alguém me disse: “Faça as malas, amanhã vai para Cannes”. E foi, no ano do fósforo a arder no ecrã gigante do Palais des Festivals, o ano de “Wild at Heart” de Lynch. Se não fossem os filmes não saberia o que estaria a fazer aqui – e isso é verdade para o bigger picture: sem os filmes não saberia o que fazer.","email":"vasco.camara@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"vasco-camara","imagem":{"w":null,"h":null,"largura":216,"altura":216,"nome":"vasco-camara-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1747423?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Cannes","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#97;&#109;&#97;&#99;&#46;&#111;&#99;&#115;&#97;&#118;","contribuicao":null,"tipo":"INTERNO"},{"id":13909,"nome":"Michelle Coelho","descricao":"","email":"michelle.coelho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Redes sociais","profissaoNaAltura":"Redes sociais","slug":"-michelle-coelho","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#108;&#101;&#111;&#99;&#46;&#101;&#108;&#108;&#101;&#104;&#99;&#105;&#109;","contribuicao":null,"tipo":"INTERNO"}],"shares":0,"description":"<p>J&aacute; sabemos quem vai ganhar os &Oacute;scares ou vamos ter uma surpresa? A an&aacute;lise de Vasco C&acirc;mara, jornalista e cr&iacute;tico de cinema do P&Uacute;BLICO.</p>\r\n","url":"/2026/03/13/culturaipsilon/video/oscares-vao-escolhas-previsoes-ipsilon-20260313-170121","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Óscares 2026","url":"/oscares-2026"},"id":97729,"type":"VIDEO","isMultipleRubric":false,"tag":null,"size":30}]
