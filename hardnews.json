 estreia. E acompanhado o relançamento do site de Desporto, a criação de canais dedicados (Jogos Olímpicos, Europeu, Mundial de futebol) e a edição de suplementos em papel com a mesma lupa que uso para aperfeiçoar o jornal que todos os dias sai para as bancas.","email":"nsousa@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editor de Desporto","profissaoNaAltura":"Editor de Desporto","slug":"nuno-sousa","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"nsousa.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1951120?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Liga Europa da UEFA","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#115;&#117;&#111;&#115;&#110;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"“Encarnados” bateram o último classificado e somaram a 16.ª vitória na Liga. Alexander Bah regressou aos relvados e marcou.","url":"/2026/02/21/desporto/cronica_de_jogo/benfica-ultrapassa-afs-esquerda-boleia-schjelderup-2165594","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Crónica de jogo","url":"/futebol-nacional"},"id":2165594,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":19,"title":"Dinamarca diz que Gronelândia não precisa de navio-hospital que Trump anunciou","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2068922?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1026,"nome":"Agências","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"agencias","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"AGENCIAS"}],"shares":0,"description":"Primeira-ministra da Dinamarca diz-se “feli