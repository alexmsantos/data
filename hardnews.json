p=UH&db=IMAGENS&type=JPG","author":[{"id":14261,"nome":"Carolina Amado","descricao":"","email":"carolina.amado@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"carolina-amado","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#100;&#97;&#109;&#97;&#46;&#97;&#110;&#105;&#108;&#111;&#114;&#97;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Disparos na aldeia de Tel, junto a Nablus, mataram quatro palestinianos e dois israelitas nesta sexta-feira. Ataques de colonos multiplicaram-se nas horas seguintes, com o aval de Netanyahu.","url":"/2026/07/24/mundo/noticia/colonos-declaram-guerra-cisjordania-apos-morte-quatro-palestinianos-dois-israelitas-2182984","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Médio Oriente","url":"https://www.publico.pt/2026/07/24/mundo/noticia/colonos-declaram-guerra-cisjordania-apos-morte-quatro-palestinianos-dois-israelitas-2182984"},"id":2182984,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":13,"title":"Merz remodela Governo após saída de político por recurso a “barriga de aluguer”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2105087?tp=UH&db=IMAGENS&type=JPG","author":[{"id":349,"nome":"Maria João Guimarães","descricao":"Sou jornalista desde 1998, no PÚBLICO, onde tenho podido ler, ouvir, contar, e viver histórias. Lembro-me da primeira, como estagiária: a de um afinador de acordeões no Intendente. Do pequeno largo de Lisboa passei para o Internacional e continuei a ouvir pessoas que tornam o mundo menos preto e branco. Escrevi sobre o muro em Israel e o muro de Berlim. Sobre racismo em Israel, na Alemanha, na Grécia. Falei com jovens alemães precários, com jovens gregos desempregados, com jovens a tentar saídas profissionais em Gaza. \r\nVivi em Berlim no ano académico de 2015/16, com uma bolsa para um programa para jornalistas da Universidade Livre. Vi um conjunto de reportagens sobre a Grécia distinguido com o Prémio de Reportagem Norberto Lopes da Casa da Imprensa 2011/2012, a reportagem “Uma geração a tentar sair de Gaza para dizer: sou de Gaza” com o Prémio de Jornalismo Direitos Humanos & Integração 2019 (imprensa escrita), e a cobertura das eleições alemãs de 2021 com o Prémio de Jornalismo Luso-Alemão 2022.","email":"maria.joao.guimaraes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"maria-joao-guimaraes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Maria_J_Guimaraes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737866?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#97;&#114;&#97;&#109;&#105;&#117;&#103;&#46;&#111;&#97;&#111;&#106;&#46;&#97;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Jens Spahn deixou a liderança do grupo parlamentar por ter recorrido a gestação de substituição nos EUA, quando esta é proibida na Alemanha.","url":"/2026/07/24/mundo/noticia/merz-remodela-governo-apos-saida-politico-uso-barriga-aluguer-2182932","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Alemanha","url":"https://www.publico.pt/2026/07/24/mundo/noticia/merz-remodela-governo-apos-saida-politico-uso-barriga-aluguer-2182932"},"id":2182932,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":14,"title":"Quercus alerta que novo aeroporto pode ameaçar maior aquífero ibérico","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2105018?tp=UH&db=IMAGENS&type=JPG","author":[{"id":177,"nome":"Andréia Azevedo Soares","descricao":"Nasci no Rio de Janeiro, onde estudei jornalismo na Universidade Federal. Mudei-me para Portugal em 1999. Trabalho no PÚBLICO desde 2000, com duas interrupções – uma para um doutoramento em Comunicação de Ciência no Imperial College, em Londres, e outra para colaborar com a revista científica WHO Bulletin, em Genebra. Já fui estagiária, colaboradora, repórter e sub-editora em diferentes secções deste jornal. A ciência e a literatura são as áreas sobre as quais mais gosto de escrever; fascina-me o modo como o escritor e o cientista se empenham para detalhar e compreender o mundo que nos rodeia, incluindo os seres vivos que nele habitam.\r\n\r\n\r\n\r\n","email":"aasoares@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"andreia-azevedo-soares","imagem":{"w":null,"h":null,"largura":501,"altura":498,"nome":"andreia_soares-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1725026?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#114;&#97;&#111;&#115;&#97;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Associação avisa que a localização prevista no campo de tiro de Alcochete poderá colocar em causa recursos hídricos estratégicos para Setúbal.","url":"/2026/07/24/azul/noticia/quercus-alerta-novo-aeroporto-ameacar-maior-aquifero-peninsula-iberica-2182900","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Aeroporto","url":"https://www.publico.pt/2026/07/24/azul/noticia/quercus-alerta-novo-aeroporto-ameacar-maior-aquifero-peninsula-iberica-2182900"},"id":2182900,"type":"NOTICIA","isMultipleRu