unicação de ciência","url":"https://www.publico.pt/2026/05/22/ciencia/noticia/podem-cientistas-festival-cienciacidada-chega-sabado-figueira-foz-2175406"},"id":2175406,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":20,"title":"Miles Davis e John Coltrane: 100 anos a iluminar o jazz","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2089620?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1036,"nome":"Jorge Mourinha","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Crítico","profissaoNaAltura":"Crítico","slug":"jorge-mourinha","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"jmourinha-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/2074861?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Os Cavalheiros","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Um aventureiro e um miniaturista, um obsessivo e um impulsivo. O acaso fez Miles e Coltrane nascerem no mesmo ano, 1926. A sua música e os seus discos são autênticas bibliotecas de um momento do mundo","url":"/2026/05/22/culturaipsilon/noticia/miles-davis-john-coltrane-100-anos-iluminar-jazz-2175223","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Música","url":"https://www.publico.pt/2026/05/22/culturaipsilon/noticia/miles-davis-john-coltrane-100-anos-iluminar-jazz-2175223"},"id":2175223,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":21,"title":"O impacto da cultura no caminho do futuro","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2089955?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"<!--StartFragment--><span data-olk-copy-source=\"MessageBody\" style=\"color: black; font-family: Aptos;\">De olhos postos em artistas e jovens emergentes, a actua&ccedil;&atilde;o do Grupo Ageas Portugal na cultura passa pelo teatro, m&uacute;sica, dan&ccedil;a, circo e, ainda, pelo audiovisual.</span><!--EndFragment-->","url":"https://www.publico.pt/estudiop/conteudo_patrocinado/impacto-cultura-ageas","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"CONTEÚDO COMERCIAL","url":"/ageas-cultura"},"id":27256,"type":"EXTERNOS","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"Loulé Rural: uma caminhada entre natureza, património e o mel das abelhas","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2090107?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3457,"nome":"Mara Gonçalves","descricao":"","email":"mara.goncalves@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"mara-goncalves","imagem":{"w":null,"h":null,"largura":2048,"altura":1365,"nome":"#f25_1 COL (para usar a cara).jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1470491?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#118;&#108;&#97;&#99;&#110;&#111;&#103;&#46;&#97;&#114;&#97;&#109;","contribuicao":"texto","tipo":"INTERNO"},{"id":20292,"nome":"Pedro V. Inácio","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"pedro-v-inacio","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"Os passeios da Loulé Rural começam sempre no campo e terminam à mesa, entre interpretação da natureza, património cultural e visita a produtores locais, para mostrar a riqueza do interior do Algarve.","url":"/2026/05/22/fugas/reportagem/loule-rural-caminhada-natureza-patrimonio-mel-abelhas-2174747","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Reportagem","url":"/passeios"},"id":2174747,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":23,"title":"Cannes: nos bastidores de um dos maiores festivais de cinema do mundo","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2089809?tp=UH&db=IMAGENS&type=JPG","author":[{"id":633,"nome":"Alexandra Prado Coelho","descricao":"Quando entrei no PÚBLICO, em 1989, entre os estagiários que participaram na aventura da fundação do jornal, queria muito trabalhar na secção Internacional. O mundo estava a mudar, em Berlim o Muro caía, Saddam Hussein invadia o Kuwait , usávamos telex e nem sonhávamos com a Internet. Durante 15 anos viajei pelo Médio Oriente, Rússia, Europa, Afeganistão. Depois, foi tempo de mudar e passei para a Cultura, onde escrevi sobre cinema, teatro, arquitectura, design, literatura. Em 2011 passei a acompanhar a área da alimentação – dos produtores aos restaurantes, das novas tendências gastronómicas à saúde. Porque, se há tema que cruza todos os países, culturas e pessoas, é o da comida.","email":"apc@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"alexandra-prado-coelho","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Alexandra Prado Coelho z.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1526725?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#99;&#112;&#97;","contribuicao":"","tipo":"INTERNO"},{"id":885,"nome":"Vasco Câmara","descricao":"Foi depois de ter entrado pela casa que Gloria Swanson teve em Sintra, onde vi junto à piscina um animal empalhado, que me deixaram, aqui no PÚBLICO, meter as mãos no cinema. Isto foi no início deste projecto jornalístico. Eu fui um dos 25 estagiários admitidos depois de um curso de meses que começou com 500 candidatos de todo o país. Após a história da estrela dos anos 20 que vinha descansar perto da praia das Maçãs, alguém me disse: “Faça as malas, amanhã vai para Cannes”. E foi, no ano do fósforo a arder no ecrã gigante do Palais des Festivals, o ano de “Wild at Heart” de Lynch. Se não fossem os filmes não saberia o que estaria a fazer aqui – e isso é verdade para o bigger picture: sem os filmes não saberia o que fazer.","email":"vasco.camara@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"vasco-camara","imagem":{"w":null,"h":null,"largura":216,"altura":216,"nome":"vasco-camara-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1747423?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Cannes","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#97;&#109;&#97;&#99;&#46;&#111;&#99;&#115;&#97;&#118;","contribuicao":"","tipo":"INTERNO"},{"id":19752,"nome":"Tiago Orato","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Sonoplasta","profissaoNaAltura":"","slug":"tiago-orato","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"edição","tipo":"INTERNO"}],"shares":0,"description":"Vasco Câmara é o enviado do PÚBLICO a Cannes e conta-nos o que é esta vida dupla que a pequena cidade da Riviera francesa vive por estes dias, comparando o ambiente de hoje com o do passado.","url":"/2026/05/22/culturaipsilon/podcast/cannes-bastidores-maiores-festivais-cinema-mundo-2175466","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Podcast","url":"/podcast-escuro"},"id":2175466,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":24,"title":"Uma ópera para ouvir os ecos do 25 de Abril","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2090292?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3182,"nome":"Pedro Boléo","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":null,"profissaoNaAltura":"","slug":"pedro-boleo","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"<em>Por Todos Nós</em>, ópera de Eurico Carrapatoso a partir de um romance de Lídia Jorge, tem fragilidades e forças, entre as quais a voz de um Anjo que vem interrogar as histórias e a História.","url":"/2026/05/22/culturaipsilon/critica/opera-ouvir-ecos-25-abril-2175712","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Crítica","url":"/musica"},"id":2175712,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":25,"title":"A transição para a mobilidade eléctrica pode ser simples?","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2089908?tp=UH&db=IMAGENS&type=PNG","author":[],"shares":0,"description":"Mudar de um veículo a combustão para um automóvel 100% eléctrico ainda levanta algumas hesitações.  A melhor forma de desconstruir mitos é levar a tecnologia para a rua e testá-la num cenário real.","url":"/2026/05/21/estudiop/noticia/transicao-mobilidade-electrica-simples-2175512","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"HYUNDAI","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2089885?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/05/21/estudiop/noticia/transicao-mobilidade-electrica-simples-2175512"},"id":2175512,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":26,"title":"Um Fidju Kitxora à casa torna e retorna","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2089612?tp=UH&db=IMAGENS&type=JPG","author":[{"id":788,"nome":"Inês Nadais","descricao":"","email":"inadais@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editora de Cultura","profissaoNaAltura":"Editora de Cultura","slug":"ines-nadais","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Ines Nadais1.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1325418?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#105;&#97;&#100;&#97;&#110;&#105;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"<em>Ti Manxe</em> mergulha ainda mais fundo nos trânsitos e nos transes, musicais e existenciais, de um filho anónimo da diáspora cabo-verdiana. Desta vertigem, diz ele, não há retorno — e ainda bem.","url":"/2026/05/22/culturaipsilon/noticia/fidju-kitxora-casa-torna-retorna-2175283","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Música","url":"https://www.publico.pt/2026/05/22/culturaipsilon/noticia/fidju-kitxora-casa-torna-retorna-2175283"},"id":2175283,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":27,"title":"<em>La vera pizza napoletana</em>: tradição e técnica no campeonato mundial em Portugal","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2090257?tp=UH&db=IMAGENS&type=JPG","author":[{"id":18338,"nome":"Rita Caetano","descricao":"","email":"rscaetano@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"rita-caetano","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#97;&#116;&#101;&#97;&#99;&#115;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"A “Michelin das pizzas” veio a Portugal avaliar <em>piazzaioli </em>e fomos saber como se faz a <em>vera pizza</em> napolitana: tudo começa com “água, farinha, fermento, sal”, mas não pode faltar “muita paixão”.","url":"/2026/05/22/fugas/noticia/vera-pizza-napoletana-tradicao-tecnica-campeonato-mundial-portugal-2175678","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Gastronomia","url":"https://www.publico.pt/2026/05/22/fugas/noticia/vera-pizza-napoletana-tradicao-tecnica-campeonato-mundial-portugal-2175678"},"id":2175678,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":28,"title":"Imaginarius, o festival “democrático” que “traz mundo” a Santa Maria da Feira","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2090244?tp=UH&db=IMAGENS&type=JPG","author":[{"id":120,"nome":"Sandra Silva Costa","descricao":"Nunca fui bairrista mas também nunca fui de renegar as origens: nasci numa aldeia, Maceda, no concelho de Ovar, e lá vivi até aos 20 anos, mais coisa menos coisa. Nessa altura já estudava Jornalismo, na Universidade de Coimbra. Entrei para o PÚBLICO aos 22, tinha cabelos curtos e um mar de sonhos na cabeça. Vim estagiar, com experiência quase zero — mas justiça seja feita ao Jornal de Ovar, que me deu a primeira oportunidade, ainda nos tempos da faculdade. Estágio cumprido, integrei a secção de Educação, na altura uma editoria autónoma. Estávamos em 1998. Passei ainda pela Sociedade, como jornalista e como editora, até que, em 2008, assumi a edição da Fugas, onde fiquei até Dezembro de 2024. Em Janeiro de 2025, integrei a equipa do Local Porto.","email":"scosta@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"sandra-silva-costa","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"sc.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1091354?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#116;&#115;&#111;&#99;&#115;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Festival de Artes Performativas em Espaço Público termina este sábado. Conta com 39 espectáculos a cargo de 200 artistas de 16 países, entre música, dança, teatro e circo.","url":"/2026/05/22/local/reportagem/imaginarius-festival-democratico-traz-mundo-santa-maria-feira-2175690","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Reportagem","url":"/artes-de-rua"},"id":2175690,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":9041,"nome":"Artes de rua","slug":"artes-de-rua","tagEn":"","isPrincipal":false,"isVisible":true,"urlRoute":"/tartes-de-rua","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAberto":false,"follow_type":null,"descricao":null,"imagem":null,"html":null,"isForForuns":false,"isUsedInForuns":false},"size":30},{"pos":29,"title":"<em>Kristin</em>: moratória abrangeu mil milhões de euros de empresas e famílias","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2090167?tp=UH&db=IMAGENS&type=JPG","author":[{"id":459,"nome":"Rosa Soares","descricao":"","email":"rsoares@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"rosa-soares","imagem":{"w":null,"h":null,"largura":472,"al