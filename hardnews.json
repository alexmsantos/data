;&#100;&#46;&#108;&#101;&#105;&#110;&#97;&#100;","contribuicao":"","tipo":"INTERNO"},{"id":20431,"nome":"Margarida Adão","descricao":"","email":"Margarida.Adao@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Sonoplasta","profissaoNaAltura":"","slug":"margarida-adao","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#97;&#100;&#65;&#46;&#97;&#100;&#105;&#114;&#97;&#103;&#114;&#97;&#77;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Nunca se produziu tanta música — e nunca foi tão difícil perceber de onde vem. Com a IA a invadir o <em>streaming</em>, a questão pode já não ser se é um problema, mas o que fazer com ele.","url":"/2026/06/11/culturaipsilon/noticia/musica-invadida-ia-boa-noticia-assim-2177798","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Podcast Como Assim ","url":"https://www.publico.pt/2026/06/11/culturaipsilon/noticia/musica-invadida-ia-boa-noticia-assim-2177798"},"id":2177798,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":29,"title":"Cientistas criam o primeiro mapa global dos fungos subterrâneos","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2094820?tp=UH&db=IMAGENS&type=JPG","author":[{"id":177,"nome":"Andréia Azevedo Soares","descricao":"Nasci no Rio de Janeiro, onde estudei jornalismo na Universidade Federal. Mudei-me para Portugal em 1999. Trabalho no PÚBLICO desde 2000, com duas interrupções – uma para um doutoramento em Comunicação de Ciência no Imperial College, em Londres, e outra para colaborar com a revista científica WHO Bulletin, em Genebra. Já fui estagiária, colaboradora, repórter e sub-editora em diferentes secções deste jornal. A ciência e a literatura são as áreas sobre as quais mais gosto de escrever; fascina-me o modo como o escritor e o cientista se empenham para detalhar e compreender o mundo que nos rodeia, incluindo os seres vivos que nele habitam.\r\n\r\n\r\n\r\n","email":"aasoares@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"andreia-azevedo-soares","imagem":{"w":null,"h":null,"largura":501,"altura":498,"nome":"andreia_soares-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1725026?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#114;&#97;&#111;&#115;&#97;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Estudo publicado na revista <em>Science</em> estima que os solos da Terra contêm 110 mil biliões de quilómetros de filamentos fúngicos, estruturas vivas que movem carbono e nutrientes à escala planetária. \r\n\r\n","url":"/2026/06/11/azul/noticia/cientistas-criam-mapa-global-fungos-subterraneos-2177889","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Biodiversidade","url":"https://www.publico.pt/2026/06/11/azul/noticia/cientistas-criam-mapa-global-fungos-subterraneos-2177889"},"id":2177889,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30}]
