[{"pos":0,"title":"“Sem pedir desculpa”, o <em>enfant terrible</em> Santana Lopes está de regresso ao PS","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2097105?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19357,"nome":"Filipe Santa-Bárbara","descricao":"","email":"filipe.santabarbara@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"filipe-santabarbara","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#97;&#98;&#114;&#97;&#98;&#97;&#116;&#110;&#97;&#115;&#46;&#101;&#112;&#105;&#108;&#105;&#102;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Foi líder do PSD, voltou a tentar e perdeu para Rui Rio, acabou por sair do partido em 2018. Oito anos depois, a surpresa do congresso: Pedro Santana Lopes está de volta.","url":"/2026/06/21/politica/noticia/pedir-desculpa-enfant-terrible-santana-lopes-regresso-psd-2178956","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"PSD","url":"https://www.publico.pt/2026/06/21/politica/noticia/pedir-desculpa-enfant-terrible-santana-lopes-regresso-psd-2178956"},"id":2178956,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":1,"title":"Natureza: um refúgio natural para desligar (e dentro do orçamento)","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2091678?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Mudar de ritmo e abrandar, junto da Natureza, não obriga a deslocações longas e dispendiosas.","url":"/2026/06/08/estudiop/noticia/natureza-refugio-natural-desligar-dentro-orcamento-2176198","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Huttopia","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2082090?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/08/estudiop/noticia/natureza-refugio-natural-desligar-dentro-orcamento-2176198"},"id":2176198,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":2,"title":"Mais do que um ataque à oposição, uma ode a Montenegro no primeiro dia de congresso","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2097086?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19357,"nome":"Filipe Santa-Bárbara","descricao":"","email":"filipe.santabarbara@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"filipe-santabarbara","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#97;&#98;&#114;&#97;&#98;&#97;&#116;&#110;&#97;&#115;&#46;&#101;&#112;&#105;&#108;&#105;&#102;","contribuicao":"texto","tipo":"INTERNO"},{"id":3977,"nome":"Paulo Pimenta","descricao":"","email":"paulo.pimenta@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"Fotojornalista","slug":"paulo-pimenta","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#116;&#110;&#101;&#109;&#105;&#112;&#46;&#111;&#108;&#117;&#97;&#112;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"Chumbo na lei laboral marcou intervenções no Congresso e houve até a promessa de voltar à carga. Com Governo em peso, mais do que ataque ao PS e Chega, tom foi de elogio a Montenegro.","url":"/2026/06/20/politica/noticia/ataque-oposicao-ode-montenegro-dia-congresso-2178942","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Congresso","url":"https://www.publico.pt/2026/06/20/politica/noticia/ataque-oposicao-ode-montenegro-dia-congresso-2178942"},"id":2178942,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"Reforma laboral: as medidas que ficam pelo caminho","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2097071?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3150,"nome":"Raquel Martins","descricao":"Aos 15 anos decidi que queria mudar o mundo e, para desgosto da minha professora de Português, quis ser jornalista. Fiz o curso de Ciências da Comunicação na Universidade Nova, frequentei o Cenjor e andei indecisa entre a rádio e a imprensa. Depois de uma breve passagem pela rádio (Antena 3 e Rádio Expo), acabei por entrar no jornalismo económico um pouco por acaso. Primeiro, no Diário Económico – onde escrevi sobre ambiente, autarquias, política e, mais tarde, sobre trabalho e função pública – depois no Jornal de Negócios. Foi por isso que, em 2009, fiz uma formação na Universidade Católica sobre legislação laboral. Estou no PÚBLICO desde 2010. Acompanho os assuntos relacionados com trabalho, emprego e administração pública (há quem diga, com humor, que o Código do Trabalho é o meu livro de cabeceira.) Defendo que o jornalismo tem um papel cada vez mais importante na descodificação da avalanche de informação que todos os dias circula nas mais diversas plataformas.","email":"raquel.martins@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"raquel-martins","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"raquel-martins-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1991256?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Debi Thomas","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#110;&#105;&#116;&#114;&#97;&#109;&#46;&#108;&#101;&#117;&#113;&#97;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Medidas relacionadas com a flexibilização dos despedimentos, da contratação a prazo, da organização do trabalho ou com os limites ao uso da inteligência artificial na gestão de pessoas não avançam.","url":"/2026/06/20/economia/noticia/medidas-laborais-ficam-caminho-2178937","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Legislação laboral","url":"https://www.publico.pt/2026/06/20/economia/noticia/medidas-laborais-ficam-caminho-2178937"},"id":2178937,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"Luís Neves diz que “houve uma falha” ao não avisar o primeiro-ministro da ameaça","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2097070?tp=UH&db=IMAGENS&type=JPG","author":[{"id":18319,"nome":"Gina Pereira","descricao":"","email":"gina.pereira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editora de Sociedade","profissaoNaAltura":"","slug":"gina-pereira","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#101;&#112;&#46;&#97;&#110;&#105;&#103;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Ministro da Administração Interna era director da Judiciária quando a operação teve lugar, no ano passado, e admite que quando houve novos dados “a comunicação poderia e deveria ter sido diferente”.","url":"/2026/06/20/sociedade/noticia/ameaca-terrorista-luis-neves-falha-nao-avisar-gabinete-primeiroministro-2178935","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Justiça","url":"https://www.publico.pt/2026/06/20/sociedade/noticia/ameaca-terrorista-luis-neves-falha-nao-avisar-gabinete-primeiroministro-2178935"},"id":2178935,"type":"NOTICIA","isMultipleRubr