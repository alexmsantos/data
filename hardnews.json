rnal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#105;&#100;&#114;&#97;&#110;&#114;&#101;&#98;&#46;&#111;&#116;&#115;&#117;&#103;&#117;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Ao terceiro título nacional consecutivo, poderá juntar-se, nesta semana, a presença nas meias-finais da Liga dos Campeões, que em 2025 esteve por um fio.","url":"/2026/05/03/desporto/noticia/avassalador-portugal-andebol-sporting-procura-voar-europa-2173369","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Andebol","url":"https://www.publico.pt/2026/05/03/desporto/noticia/avassalador-portugal-andebol-sporting-procura-voar-europa-2173369"},"id":2173369,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":12,"title":"Inter é campeão com Chivu, um homem que achou que estava tudo bem","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2085760?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6063,"nome":"Diogo Cardoso Oliveira","descricao":"Ver desporto, escrever e contar histórias: costumo dizer que sou pago para fazer algo que faria <i>pro-bono</i>. Tudo começou numa t-shirt branca, feita na escola primária, que já identificava um gaiato com más ideias: dizia “Diogo, o jornalista”. Feito um raide incompleto pela aviação, formei-me em Comunicação Social, época em que fazia do jornal universitário <i>Pontivirgula</i> uma tela para rascunhos do que estaria por vir. Comecei a carreira como estagiário no PÚBLICO, no mês em que Éder decidiu dar um chuto aos franceses. Ainda estive no <i>Record</i>, antes de fazer parte do início do site <i>Bancada</i>. Voltei para o PÚBLICO, que já me levou ao Mundial do Qatar, aos Jogos Olímpicos de Paris e onde faço um pouco de tudo no desporto. Gosto de ciclismo, basquetebol, ginástica, futebol, História e histórias — também por isso escrevi o livro <i>Futebol numa conversa de café</i>.","email":"diogo.oliveira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"diogo-cardoso-oliveira","imagem":{"w":null,"h":null,"largura":1064,"altura":1345,"nome":"WhatsApp Image 2025-04-24 at 20.31.38.jpeg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1995019?tp=UH&db=IMAGENS&type=JPG","is_vertical":true,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#118;&#105;&#108;&#111;&#46;&#111;&#103;&#111;&#105;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O treinador romeno pegou no que havia e adicionou coisas aqui e acolá, mas mantendo a base herdada. Resultado: domínio na Liga italiana e uma equipa que parece ainda mais capaz do que com Inzaghi.","url":"/2026/05/03/desporto/noticia/inter-campeao-chivu-homem-achou-bem-2173386","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Futebol internacional","url":"https://www.publico.pt/2026/05/03/desporto/noticia/inter-campeao-chivu-homem-achou-bem-2173386"},"id":2173386,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":13,"title":"Ténis: mais um feito histórico para Jannik Sinner","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2085721?tp=UH&db=IMAGENS&type=JPG","author":[{"id":141,"nome":"Pedro Keul","descricao":"","email":"pkeul@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":null,"profissaoNaAltura":"","slug":"pedro-keul","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#108;&#117;&#101;&#107;&#112;","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Italiano conquistou cinco títulos Masters 100