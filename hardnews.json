issaoNaAltura":"Jornalista","slug":"leonor-alhinho","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#110;&#105;&#104;&#108;&#97;&#46;&#114;&#111;&#110;&#111;&#101;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"A Assembleia Nacional francesa revogou oficialmente o <em>Code noir</em>, um texto do século XVII que regulava a escravatura nas colónias francesas e equiparava um ser humano a um bem móvel.","url":"/2026/05/29/mundo/noticia/franca-anula-unanimidade-atraso-180-anos-codigo-legal-regulava-escravatura-2176420","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Escravatura","url":"https://www.publico.pt/2026/05/29/mundo/noticia/franca-anula-unanimidade-atraso-180-anos-codigo-legal-regulava-escravatura-2176420"},"id":2176420,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":24,"title":"Pequenos investidores contribuem para uma maior incerteza no ouro","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2091703?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19360,"nome":"Diogo Cavaleiro","descricao":"Estagiei no PÚBLICO em 2009 no Local Lisboa, tendo no ano seguinte entrado no <em>Jornal de Negócios</em>, onde fiquei por quase nove anos. O sector bancário foi aquele em que me especializei, tendo publicado um livro – <em>Caixa Negra</em> – sobre décadas de gestão e polémica na Caixa Geral de Depósitos, em 2017. Em 2019, segui para o <em>Expresso</em>, continuando na mesma área, onde fiquei até Maio de 2025. Regresso agora ao PÚBLICO para continuar esse trabalho, integrando a secção de Economia. Licenciado em Ciências da Comunicação, tenho pós-graduações em Ciência Política – Relações Internacionais, na vertente de Estudos Europeus, e em Compliance.","email":"diogo.cavaleiro@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"diogo-cavaleiro","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Diogo Cavaleiro.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/2051033?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#114;&#105;&#101;&#108;&#97;&#118;&#97;&#99;&#46;&#111;&#103;&#111;&#105;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Tendências passadas com activos de refúgio, como o ouro, não se estão a repetir, nota o Banco Central Europeu. Exposição indirecta ao metal precioso amplifica movimentos.","url":"/2026/05/29/economia/noticia/investidores-contribuem-maior-incerteza-ouro-2176350","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Ouro","url":"https://www.publico.pt/2026/05/29/economia/noticia/investidores-contribuem-maior-incerteza-ouro-2176350"},"id":2176350,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":25,"title":"Wasted Rita: radar, satélite, a artista pós-Internet","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2090735?tp=UH&db=IMAGENS&type=JPG","author":[{"id":12172,"nome":"João de Sousa Cardoso","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"joao-sousa-cardoso","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"texto","tipo":"EXTERNO"},{"id":3976,"nome":"Nuno Ferreira Santos","descricao":"","email":"nuno.santos@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"Fotografia","slug":"nuno-ferreira-santos","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#111;&#116;&#110;&#97;&#115;&#46;&#111;&#110;&#117;&#110;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"Instalou um colchão numa galeria, onde criou à frente de todos. O capitalismo, o tédio, a solidão digital: tudo converge no trabalho de Rita Gomes, adorada pelos anónimos da Internet e por Madonna.","url":"/2026/05/28/culturaipsilon/noticia/wasted-rita-radar-satelite-artista-posinternet-2175917","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Artes","url":"https://www.publico.pt/2026/05/28/culturaipsilon/noticia/wasted-rita-radar-satelite-artista-posinternet-2175917"},"id":2175917,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":26,"title":"Quase todos dizem ter visto cinema português, mas metade não se lembra do filme","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2091670?tp=UH&db=IMAGENS&type=JPG","author":[{"id":136,"nome":"Joana Amaral Cardoso","descricao":"Comecei na secção de Sociedade em 1999, dali fui para o Publico.pt e como colaboradora da revista Pública escrevi sobre tendências sociais e Manias. Em 2006 comecei a debruçar-me sobre uma das áreas que mais me interessam – o audiovisual. Depois, já na secção de Cultura, onde sou hoje jornalista, juntei a isto tudo a cultura popular, o cinema, a moda, o design e interesso-me em aplicar a lente do género a muitos fenómenos.  Em 2009 editei a secção de Televisão da revista TimeOut e mais recentemente dei aulas de Jornalismo de Moda. No Público também editei a secção da Cultura online, fui subeditora da revista Pública e co-editora da revista Fugas. E vejo demasiada televisão.","email":"joana.cardoso@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"joana-amaral-cardoso","imagem":n