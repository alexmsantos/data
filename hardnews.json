author":[{"id":3265,"nome":"Amanda Ribeiro","descricao":"","email":"amanda.ribeiro@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"amanda-ribeiro","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#114;&#105;&#101;&#98;&#105;&#114;&#46;&#97;&#100;&#110;&#97;&#109;&#97;","contribuicao":null,"tipo":"INTERNO"},{"id":890,"nome":"Reuters","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"","profissaoNaAltura":"","slug":"reuters","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":null,"tipo":"AGENCIAS"}],"shares":0,"description":"<p>Ouviram-se disparos no jantar dos correspondentes da Casa Branca e Donald Trump teve de ser retirado. Suspeito foi detido.</p>\r\n","url":"/2026/04/26/video/momento-trump-retirado-jantar-disparos-20260426-111600","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Vídeo","url":"/video-"},"id":97846,"type":"VIDEO","isMultipleRubric":false,"tag":null,"size":30},{"pos":21,"title":"As enfermeiras pára-quedistas que estiveram na Guerra Colonial em “missão de paz”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2084134?tp=UH&db=IMAGENS&type=JPG","author":[{"id":488,"nome":"Lucinda Canelas","descricao":"Quando cheguei aqui, Lisboa estava a preparar-se para a grande exposição dos oceanos e a cidade mudava à beira-rio. Os quatro primeiros meses foram intensos, no recinto da Expo e fora dele, nos festivais que invadiam teatros e auditórios, sempre de Polaroid na mochila. O interesse pela arte, sobretudo a dança, já lá estava, mas pelo caminho foi crescendo e foi mudando. Talvez porque acabei por conversar com coreógrafos que me habituei a admirar nos livros e nos palcos, porque uma reportagem me levou a um sítio arqueológico que eu ainda não conhecia e uma exposição me fez descobrir um fotógrafo, um escritor, um artista ou um historiador de arte com muita coisa para contar sobre os mestres da pintura antiga. Sair em reportagem para caminhar no campo à procura de um mosteiro medieval ou de um castelo nas margens do Guadiana parece-me quase sempre boa ideia.","email":"lcanelas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"lucinda-canelas","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#108;&#101;&#110;&#97;&#99;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Foram as primeiras mulheres nas Forças Armadas portuguesas. Exposição em Lisboa recupera parte desta história que também se construiu — e constrói — com fotografias.","url":"/2026/04/26/culturaipsilon/noticia/enfermeiras-paraquedistas-guerra-colonial-missao-paz-2172302","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Guerra Colonial","url":"https://www.publico.pt/2026/04/26/culturaipsilon/noticia/enfermeiras-paraquedistas-guerra-colonial-missao-paz-2172302"},"id":2172302,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"Tchernobil, 40 anos: das imagens esquecidas à independência de um país","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2084173?tp=UH&db=IMAGENS&type=JPG","author":[{"id":17909,"nome":"André Luís Alves","descricao":"Cobre a guerra na Ucrânia desde Fevereiro de 2022, reportando diversas vezes a partir da linha da frente. Premiado com Bolsa a Estação Imagem de 2022 como fotógrafo","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"na Ucrânia","profissaoActual":"Repórter","profis