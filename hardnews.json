":[{"id":204,"nome":"Andrea Cunha Freitas","descricao":"Tenho uma licenciatura em Jornalismo Internacional e sou jornalista no PÚBLICO desde 1997. Trabalhei na secção do Local e da Sociedade, onde fui editora. Desde 2016 sou jornalista na secção de Ciência.","email":"acfreitas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"andrea-cunha-freitas","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#105;&#101;&#114;&#102;&#99;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Fenómeno ocorre a alta altitude, mas poderá trazer poderá alguma deposição de poeiras em carros, janelas e painéis solares no Norte de Portugal durante terça e quarta-feira.","url":"/2026/02/23/azul/noticia/nuvem-poeira-sara-devera-atingir-portugal-resto-europa-2165665","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Poluição atmosférica","url":"https://www.publico.pt/2026/02/23/azul/noticia/nuvem-poeira-sara-devera-atingir-portugal-resto-europa-2165665"},"id":2165665,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":11,"title":"Building The Future 2026 quer transformar IA em vantagem competitiva","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2068602?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"O Building The Future regressa a Lisboa a 12 e 13 de março de 2026 com um objetivo claro: ajudar empresas e organizações a transformar a Inteligência Artificial em valor real e mensurável.","url":"/2026/02/20/estudiop/noticia/building-the-future-2026-quer-transformar-ia-vantagem-competitiva-2165431","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Building the Future","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1977429?tp=UH