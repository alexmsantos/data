or-vestiu-noivos-2180529","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"Celebridades","url":"https://www.publico.pt/2026/07/04/impar/noticia/taylor-swift-travis-kelce-estao-casados-adam-sandler-fez-cerimonia-dior-vestiu-noivos-2180529"},"id":2180529,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":12,"title":"A arte da grelha: “Gosto de grelhar porque tenho os amigos por perto”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2100074?tp=UH&db=IMAGENS&type=JPG","author":[{"id":12751,"nome":"Edgardo Pacheco","descricao":"Terroir","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"edgardo-pacheco","imagem":{"w":null,"h":null,"largura":593,"altura":421,"nome":"Captura_de_ecra~_2023-09-29__a`s_14.37.04-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1846146?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Para cada cidadão (e cada carteira) há soluções técnicas de grelha que não acabam. Os portugueses gostam de churrascos por causa do convívio.","url":"/2026/07/04/fugas/noticia/arte-grelha-gosto-grelhar-amigos-perto-2179919","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Gastronomia","url":"https://www.publico.pt/2026/07/04/fugas/noticia/arte-grelha-gosto-grelhar-amigos-perto-2179919"},"id":2179919,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":13,"title":"Ir à Eslovénia para comer a montanha","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2100118?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3332,"nome":"Cláudia Lima Carvalho","descricao":"Não sei se jornalista foi o que sempre quis ser, mas sei que escrever foi o que sempre fiz. Comecei com um caderno das histórias inventadas, quando ainda aprendia o sentido das palavras, e acabei, muitos anos depois, na Universidade do Minho, em Braga, no curso de Ciências da Comunicação. As histórias inventadas passaram a histórias reais que aprendi a observar e a contar. Escrevi no universitário ComUM e na mesma altura no regional Notícias de Coura. Dei um salto a Inglaterra, na Universidade de Loughborough, e no final de 2010 cheguei aqui. Estagiei na Cultura, fiquei a trabalhar no online e voltei à Cultura, se é que não é tudo a mesma coisa. Actualmente, sou editora online.","email":"claudia.carvalho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"claudia-carvalho","imagem":{"w":null,"h":null,"largura":408,"altura":611,"nome":"CLAUDIA_LIMA_CARVALHO_09112022___MARIANA_VALLE_LIMA-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/2089252?tp=UH&db=IMAGENS&type=PNG","is_vertical":true,"tags":"Maren Morris","translations":null},"hasImage":true,"isExternal":true,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#108;&#97;&#118;&#114;&#97;&#99;&#46;&#97;&#105;&#100;&#117;&#97;&#108;&#99;","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Nas montanhas de Kranjska Gora, David Žefran destaca-se na nova geração de <em>chefs</em>eslovenos. No Milka, a cozinha segue as estações e a montanha. Sem concessões.","url":"/2026/07/04/fugas/noticia/ir-eslovenia-comer-montanha-2179804","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Gastronomia","url":"https://www.publico.pt/2026/07/04/fugas/noticia/ir-eslovenia-comer-montanha-2179804"},"id":2179804,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":14,"title":"Em Beja, a Casa Amarela honra o passado a olhar para o futuro","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2081699?tp=UH&db=IMAGENS&type=JPG","author":[{"id":5473,"nome":"Cláudia Alpendre Marques","descricao":"","email":"calpendre@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"claudia-alpendre","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#101;&#114;&#100;&#110;&#101;&#112;&#108;&#97;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O hotel <em>boutique </em>onde a tradição encontra o design chama à alma alentejana de uma verdadeira casa de família.","url":"/2026/07/04/fugas/reportagem/beja-casa-amarela-honra-passado-olhar-futuro-2171413","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Reportagem","url":"/hoteis"},"id":2171413,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":8440,"nome":"Hotéis","slug":"hoteis","tagEn":"","isPrincipal":false,"isVisible":true,"urlRoute":"/thoteis","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAberto":false,"follow_type":null,"descricao":null,"imagem":null,"html":null,"isForForuns":false,"isUsedInForuns":false},"size":30},{"pos":15,"title":"Por Beja e Viana do Alentejo, a aprender artes do vagar","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098929?tp=UH&db=IMAGENS&type=JPG","author":[{"id":5473,"nome":"Cláudia Alpendre Marques","descricao":"","email":"calpendre@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"claudia-alpendre","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#101;&#114;&#100;&#110;&#101;&#112;&#108;&#97;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Vamos de passeio alentejano sem perder de vista artes que moldam a região, entre o buinho e o barro. E aproveitando para meter as mãos ao trabalho.","url":"/2026/07/04/fugas/reportagem/beja-viana-alentejo-aprender-artes-vagar-2179856","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Reportagem","url":"/passeios"},"id":2179856,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":8441,"nome":"Passeios","slug":"passeios","tagEn":"","isPrincipal":false,"isVisible":true,"urlRoute":"/tpasseios","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAberto":false,"follow_type":null,"descricao":null,"imagem":null,"html":null,"isForForuns":false,"isUsedInForuns":false},"size":30},{"pos":16,"title":"PHotoEspaña: imaginar o regresso da imaginação","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2099579?tp=UH&db=IMAGENS&type=JPG","author":[{"id":242,"nome":"Sérgio B. Gomes","descricao":"O Diário da Expo, jornal da Exposição Internacional de Lisboa de 1998, foi a minha primeira experiência profissional, ano em que conclui a licenciatura na Escola Superior de Jornalismo (hoje integrada na Universidade do Porto). Fiz parte do núcleo pioneiro de jornalistas que, em 1999, começaram a trabalhar em noticiário exclusivo para o PÚBLICO Online e publiquei nesta página alguns dos primeiros textos de acompanhamento em tempo real através da Internet de um acontecimento em Portugal (chegada a Lisboa do bispo timorense D. Ximenes Belo). Mantive o blogue Arte Photographica entre 2005 e 2015, espaço onde divulguei e pensei a fotografia. Integrei o júri de vários prémios de fotografia. Em 2007 assumi o cargo de editor do PÚBLICO Online e em 2011 passei a editar a área de Plataformas e Multimédia.","email":"sergio.gomes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"em Madrid","profissaoActual":"Editor do Caderno P2","profissaoNaAltura":"Editor do Caderno P2","slug":"sergio-b-gomes","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"sgomes.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1887608?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#109;&#111;&#103;&#46;&#111;&#105;&#103;&#114;&#101;&#115;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"De regresso às edições temáticas, o festival PHotoEspaña incentiva-nos a praticar uma coisa aparentemente simples e que dispensaria recordatórios: imaginar. Com Viviane Sassen como a ponta-de-lança.","url":"/2026/07/04/culturaipsilon/noticia/photoespana-imaginar-regresso-imaginacao-2180039","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Fotografia","url":"https://www.publico.pt/2026/07/04/culturaipsilon/noticia/photoespana-imaginar-regresso-imaginacao-2180039"},"id":2180039,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":17,"title":"À espera das células CAR-T. A odisseia de Gualter para calar o mieloma múltiplo","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2099734?tp=UH&db=IMAGENS&type=JPG","author":[{"id":7026,"nome":"Tiago Ramalho","descricao":"","email":"tiago.ramalho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"tiago-ramalho","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"tiagoramalho.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1328997?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExterna