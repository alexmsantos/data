os media. \r\n\r\n","email":"maria.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"maria-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Maria_C_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737865?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#97;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O Presidente da República está esta terça-feira a visitar o concelho de Arganil.","url":"/2026/03/10/politica/noticia/leis-laborais-seguro-apela-sindicatos-governo-patroes-voltem-sentarse-mesa-2167400","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Presidente da República","url":"https://www.publico.pt/2026/03/10/politica/noticia/leis-laborais-seguro-apela-sindicatos-governo-patroes-voltem-sentarse-mesa-2167400"},"id":2167400,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"“Trump, olha-as nos olhos”: jornal iraniano publica fotografias das crianças mortas","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2072926?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19987,"nome":"Mafalda Fidalgo","descricao":"","email":"mafalda.fidalgo@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista estagiária","profissaoNaAltura":"","slug":"mafalfa-fidalgo","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#103;&#108;&#97;&#100;&#105;&#102;&#46;&#97;&#100;&#108;&#97;&#102;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"sha