;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#117;&#113;&#105;&#114;&#110;&#101;&#104;&#98;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Juízes Orlando Nascimento e Vaz das Neves ilibados pela terceira vez pelo uso do salão nobre do Tribunal da Relação de Lisboa numa altura em que lei já permitia arrendar em vez de ceder de graça.","url":"/2026/04/21/sociedade/noticia/cedencia-salao-nobre-tribunal-julgamento-privado-cobrada-2171929","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Justiça","url":"https://www.publico.pt/2026/04/21/sociedade/noticia/cedencia-salao-nobre-tribunal-julgamento-privado-cobrada-2171929"},"id":2171929,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":13,"title":"Greenpeace defende que descarbonizar Portugal até 2040 “paga-se a si próprio”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2082807?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6488,"nome":"Aline Flor","descricao":"Natural do Rio de Janeiro, vivo em Portugal há quase 30 anos. Criei raízes. Fui directora do Jornal Universitário do Porto, passei pela Ciência e Tecnologia no Canal Superior, editei notícias do portal AEIOU.pt. Fiz um mestrado em Cinema Documental que me abriu os olhos (e ouvidos) para a riqueza de cada encontro com o outro. Cheguei ao PÚBLICO para integrar a equipa de áudio, onde produzi podcasts em áreas desde a igualdade de género às questões europeias. Hoje sou editora do Azul, a nossa secção dedicada à crise climática e sustentabilidade, e aventurei-me num segundo mestrado: Economia e Gestão do Ambiente. Gosto de ouvir e de contar as histórias que ficam à margem e acredito que temos sempre algo a aprender quando encaramos o desafio de traduzir no preto e branco dos caracteres as infinitas tonalidades que nos rodeiam.","email":"aline.flor@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"aline-flor","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Aline Flor z.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1530339?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#114;&#111;&#108;&#102;&#46;&#101;&#110;&#105;&#108;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Suficiência, eficiência e 100% renováveis: Greenpeace defende que, se Portugal eliminar totalmente dependência de importações de gás e petróleo, pouparia na ordem dos sete mil milhões por ano.","url":"/2026/04/21/azul/noticia/greenpeace-defende-descarbonizar-portugal-ate-2040-pagase-proprio-2171818","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Greenpeace","url":"https://www.publico.pt/2026/04/21/azul/noticia/greenpeace-defende-descarbonizar-portugal-ate-2040-pagase-proprio-2171818"},"id":2171818,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":14,"title":"Porto vai estudar segurança e impacto de trotinetas","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2082866?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3419,"nome":"Mariana Correia Pinto","descricao":"","email":"mariana.pinto@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"mariana-correia-pinto","imagem":{"w":null,"h":null,"largura":216,"altura":216,"nome":"mariana correia pinto.JPG","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1446489?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#1