":"https://imagens.publico.pt/imagens.aspx/2077888?tp=UH&db=IMAGENS&type=JPG","author":[{"id":973,"nome":"PÚBLICO","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"publico","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Presidente dos EUA afirmou ao <em>Financial Times</em> que “quer ficar com o petróleo do Irão”, elevando o preço da matéria-prima nos mercados internacionais.","url":"/2026/03/30/economia/noticia/petroleo-reage-declaracoes-trump-sobe-acima-116-dolares-barril-2169583","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Mercados","url":"https://www.publico.pt/2026/03/30/economia/noticia/petroleo-reage-declaracoes-trump-sobe-acima-116-dolares-barril-2169583"},"id":2169583,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"O programa que não quer deixar ninguém para trás","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2065091?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Implementado em Portugal em 2021, o Proinfância nasceu para quebrar o ciclo de pobreza geracional e ajudar a garantir que nenhuma criança fica para trás, independentemente do seu ponto de partida.","url":"/2026/03/23/estudiop/noticia/nao-deixar-ninguem-tras-2163788","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"BPI La Caixa","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1779903?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/03/23/estudiop/noticia/nao-deixar-ninguem-tras-2163788"},"id":2163788,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Trump suspende bloqueio energético a Cuba e permite passagem de petroleiro russo","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2077887?tp=UH&db=IMAGENS&type=JPG","author":[{"id":5355,"nome":"António Saraiva Lima","descricao":"Pertenço a uma geração indefinida e vesti a camisola como poucos. Experimentei Direito, viajei e desviei-me. Pelo meio, escrevi. Licenciei-me em Ciência Política e Relações Internacionais, andei a debater sobre a Europa num <i>think tank</i>, e estagiei numa afamada organização internacional. Continuei a escrever. Tropecei no jornalismo em 2015, e logo no PÚBLICO, para um estágio na inigualável secção Mundo. Três meses de instrução diária, com os melhores dos melhores, que se alongaram para cinco. Sempre a escrever, mas também a perguntar e a ouvir. Ainda testei o ofício diplomático-consular, em Inglaterra, apenas para confirmar que a indefinição que me corria no sangue estava afinal fora de prazo. Voltei para Lisboa, realistei-me no jornalismo, pela mão do <i>i</i> e do <i>Sol</i>, e terminei um mestrado em Estudos Europeus. Permanentemente a escrever. No início de 2018 voltei à casa de partida – precisamente no meio do tabuleiro e deste texto.","email":"antonio.lima@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"antonio-saraiva-lima","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Antonio Saraiva Lima.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1527215?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":",Norges teknisk-naturvitenskaplige universitet","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#109;&#105;&#108;&#46;&#111;&#105;&#110;&#111;&#116;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Após ameaça de tarifas, Trump diz agora que não vê “qualquer problema” se um país “quiser enviar petróleo para Cuba”, “seja a Rússia ou outro”. E admite que os cubanos estão a passar dificuldades.","url":"/2026/03/30/mundo/noticia/trump-suspende-bloqueio-energetico-cuba-permite-passagem-petroleiro-russo-2169581","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Petróleo","url":"https://www.publico.pt/2026/03/30/mundo/noticia/trump-suspende-bloqueio-energetico-cuba-permite-passagem-petroleiro-russo-2169581"},"id":2169581,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"EUA mobilizam-se contra Trump: recorde de pessoas manifesta-se em todos os estados","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2077853?tp=UH&db=IMAGENS&type=JPG","author":[{"id":12777,"nome":"Danielle Paquette","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"danielle-paquettewashington-post","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"},{"id":6113,"nome":"Michelle Boorstein","descricao":"Washington Post","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"michelle-boorstein","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"},{"id":11683,"nome":"Joanna Slater","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista The Washington Post","profissaoNaAltura":"","slug":"-joanna-slater","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"PROJECT_SYNDICATE"},{"id":20208,"nome":"Nick Kirkpatrick","descricao":"Jornalista do Washington Post","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"nick-kirkpatrick","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"PROJECT_SYNDICATE"}],"shares":0,"description":"Os protestos “No Kings”, de oposição pacifica ao autoritarismo do Presidente, realizaram-se em mais de 3300 localidades de todos os estados do país. “Até os introvertidos” foram para a rua.","url":"/2026/03/29/mundo/noticia/eua-mobilizamse-trump-recorde-pessoas-manifestase-estados-2169556","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"EUA","url":"https://www.publico.pt/2026/03/29/mundo/noticia/eua-mobilizamse-trump-recorde-pessoas-manifestase-estados-2169556"},"id":2169556,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"O canal AXN Portugal decreta: hoje é o Dia Mundial da Acção","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2074971?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Realidade e ficção são duas realidades sempre distintas? Se há situações na vida real em que “criamos filmes”, também há ficções que nos atingem em cheio por serem tão reais. Essa é a magia.","url":"/2026/03/24/estudiop/noticia/canal-axn-portugal-decreta-hoje-dia-mundial-accao-2165954","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"AXN","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1953085?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/03/24/estudiop/noticia/canal-axn-portugal-decreta-hoje-dia-mundial-accao-2165954"},"id":2165954,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"Portugal lança hoje cinco satélites de uma só vez no espaço","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2077670?tp=UH&db=IMAGENS&type=JPG","author":[{"id":130,"nome":"Teresa Firmino","descricao":"O homem já tinha ido à Lua há décadas, mas o fax da NASA nunca mais chegava. Tinha acabado o curso de Comunicação Social na Universidade Nova de Lisboa em 1992 e descobria no PÚBLICO o jornalismo de ciência. A Internet não tinha entrado nas nossas vidas, por isso a maneira rápida de receber a imagem (esquemática) de um robô da NASA, que ia simular na Antárctida a exploração do ambiente de Marte, era por fax. Desses tempos distantes mantém-se o gosto pelo jornalismo de ciência, tal como pela aventura que a história desse robô continha. Outras aventuras levaram-me ao mar dos Açores, para acompanhar, aí sim, de perto, o mergulho de um robô submarino, ou à Antárctida com cientistas portugueses. Pelo meio, uma pausa nos EUA, entre 2008-2009, com a bolsa Knight para jornalistas de ciência no MIT.","email":"teresa.firmino@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editora de ciência","profissaoNaAltura":"Editora de ciência","slug":"teresa-firmino","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Teresa_Firmino.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737916?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#105;&#109;&#114;&#105;&#102;&#46;&#97;&#115;&#101;&#114;&#101;&#116;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Quatro dos satélites são da empresa LusoSpace e têm nomes de poetas e escritores portugueses. Outro é da Força Aérea Portuguesa. Vão para o espaço no foguetão Falcon 9, da SpaceX de Elon Musk.","url":"/2026/03/30/ciencia/noticia/portugal-lanca-hoje-cinco-satelites-so-espaco-2169488","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Indústria aeroespacial","url":"https://www.publico.pt/2026/03/30/ciencia/noticia/portugal-lanca-hoje-cinco-satelites-so-espaco-2169488"},"id":2169488,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":9,"title":"Helena Roseta, a voz do direito à habitação na Constituinte","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2077490?tp=UH&db=IMAGENS&type=JPG","author":[{"id":205,"nome":"Ana Cristina Pereira","descricao":"Licenciada em Comunicação pela Universidade do Minho, sou repórter do Público há mais de 25 anos. Nessa qualidade, escrevo de forma consistente sobre direitos humanos. Pratico um jornalismo empenhado na escuta dos grupos sociais mais vulneráveis. Isso levou-me a escrever o pequeno ensaio \"Todas as Vozes/All the Voices\" (2014), que co-assino com Mike Jempson, e a orientar oficinas sobre media e direitos humanos/ media e diversidade. Várias reportagens minhas foram premiadas. Algumas evoluíram para livros. Sou autora dos livros \"Meninos de Ninguém\" (2009), \"Viagens Brancas\" (2011), \"Movimento Perpétuo\" (2016), \"Mulheres da minha ilha, mulheres do meu país\" (2022). Do meu trabalho de voluntariado resultaram os livros \"Desafios – Direitos das Mulheres na Guiné-Bissau\" (2012), que co-assino com Nelson Constantino Lopes, e \"Mulheres de São Tomé e Príncipe\" (2018), que co-assino com Dário Pequeno Paraíso. Dos projectos colectivos dessa natureza destaco o livro híbrido \"As Vozes do Silêncio – um grupo de sem-abrigo em busca de cidadania\" (2017). Estou a explorar outras formas de escutar grupos sociais silenciados e de contar as suas histórias. Escrevi duas peças de teatro-documental: a primeira, Onde o Frio se Demora, foi co-produzida pela Narrativensaio e pela Casa das Artes de Famalicão (2016) e a segunda, Agora é diferente, pela Feiticeiro do Norte (2019).  Hoje, no PÚBLICO, o que me dá mais gosto é fazer reportagens aprofundadas e séries de grande fôlego em formato multimédia sobre os temas que acompanho há muito. Fora do jornal, estou a realizar a minha primeira curta de animação documental.","email":"acpereira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"ana-cristina-pereira","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Ana Cristina Pereira.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1157456?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#101;&#112;&#99;&#97;","contribuicao":null,"tipo":"INTERNO"},{"id":3966,"nome":"Adriano Miranda","descricao":"Nasci em Aveiro, em 1966, estudei na Escola Secundária José Estevão em Aveiro e depois rumei ao Porto para estudar na Cooperativa Árvore. Fiz a minha especialização em Fotografia no AR.CO em Lisboa.  Em 1994 ingressei no PÚBLICO como Fotojornalista. Fui Editor de Fotografia durante 4 anos e agora estou na redacção do Porto. O PÚBLICO é a minha segunda casa. Com orgulho! \r\n´","email":"amiranda@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Fotojornalista","profissaoNaAltura":"Fotojornalista","slug":"adriano-miranda","imagem":{"w":null,"h":null,"largura":216,"altura":216,"nome":"1044361-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1889075?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Augusto Santos Silva","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#100;&#110;&#97;&#114;&#105;&#109;&#97;","contribuicao":null,"tipo":"INTERNO"},{"id":12744,"nome":"Tiago Bernardo Lopes","descricao":"Licenciei-me em Cinema e Audiovisual, na ESAP, por achar que ao estudar Cinema aprenderia também sobre Fotografia. Não foi o caso. Mais tarde, integrei mesmo o Curso Profissional de Fotografia no IPF do Porto, tendo-me focado mais na área documental. \r\nDepois de dois estágios (o primeiro em fotojornalismo, interrompido pela pandemia em 2020, e o segundo em jornalismo multimédia), integrei o PÚBLICO em 2022 na equipa de vídeo, ligado ao Azul.","email":"tiago.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Fotojornalista e Jornalista Multimédia","profissaoNaAltura":"Fotojornalista e Jornalista Multimédia","slug":"tiago-lopes","imagem":{"w":null,"h":null,"largura":1066,"altura":977,"nome":"5ec3f5a3-9e45-47f0-8ec2-be86b9a9010e-removebg.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1796704?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Jogador de tênis","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#111;&#103;&#97;&#105;&#116;","contribuicao":null,"tipo":"INTERNO"},{"id":16009,"nome":"Nuno Moura","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Web Designer","profissaoNaAltura":"Web Designer","slug":"nuno-barata-moura","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":null,"tipo":"INTERNO"}],"shares":0,"description":"Forjada nos movimentos cat&oacute;licos, entrou na Assembleia Constituinte convicta de que uma democracia s&oacute; se cumpre quando todos t&ecirc;m um lugar para viver e nunca mais deixou de lutar por esse direito.","url":"https://www.publico.pt/multimedia/interactivo/50-anos-constituicao-historia-tres-deputados-ajudaram-construir/helena-roseta-direito-habitacao","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"50 anos da Constituição","url":"/25-de-abril"},"id":27228,"type":"EXTERNOS","isM