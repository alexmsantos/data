[{"pos":0,"title":"Portugal adormeceu na <em>siesta </em>e vai ver o resto do Mundial em casa","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2100787?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6063,"nome":"Diogo Cardoso Oliveira","descricao":"Ver desporto, escrever e contar histórias: costumo dizer que sou pago para fazer algo que faria <i>pro-bono</i>. Tudo começou numa t-shirt branca, feita na escola primária, que já identificava um gaiato com más ideias: dizia “Diogo, o jornalista”. Feito um raide incompleto pela aviação, formei-me em Comunicação Social, época em que fazia do jornal universitário <i>Pontivirgula</i> uma tela para rascunhos do que estaria por vir. Comecei a carreira como estagiário no PÚBLICO, no mês em que Éder decidiu dar um chuto aos franceses. Ainda estive no <i>Record</i>, antes de fazer parte do início do site <i>Bancada</i>. Voltei para o PÚBLICO, que já me levou ao Mundial do Qatar, aos Jogos Olímpicos de Paris e onde faço um pouco de tudo no desporto. Gosto de ciclismo, basquetebol, ginástica, futebol, História e histórias — também por isso escrevi o livro <i>Futebol numa conversa de café</i>.","email":"diogo.oliveira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"em Dallas","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"diogo-cardoso-oliveira","imagem":{"w":859,"h":1831,"largura":859,"altura":1831,"nome":"WhatsApp Image 2026-06-09 at 00.03.14.jpeg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/2094160?tp=UH&db=IMAGENS&type=JPG","is_vertical":true,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#118;&#105;&#108;&#111;&#46;&#111;&#103;&#111;&#105;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Parecia haver um pacto de não agressão entre Portugal e Espanha, mas era um engodo. Os portugueses adormeceram na <em>siesta </em> e vão para casa. E poucos ousarão dizer que o desfecho foi injusto.","url":"/2026/07/06/desporto/cronica_de_jogo/portugal-adormeceu-siesta-vai-resto-mundial-casa-2180652","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Crónica de jogo","url":"/mundial-2026"},"id":2180652,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":1,"title":"Portugal a caminho da liderança na protecção do oceano","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2099273?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":" ","url":"https://www.publico.pt/estudiop/conteudo_patrocinado/portugal-proteccao-oceano","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Estúdio P Sustentabilidade","url":"https://www.publico.pt/estudiop/conteudo_patrocinado/portugal-proteccao-oceano"},"id":27276,"type":"EXTERNOS","isMultipleRubric":false,"tag":null,"size":30},{"pos":2,"title":"Portugal 0-Espanha 1: as notas aos jogadores portugueses","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2100804?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1059,"nome":"Nuno Sousa","descricao":"Primeiro, foi a informação local. Em Aveiro, durante um ano (o de 2003), ajudei a levantar um dos quatro cadernos regionais que o PÚBLICO chegou a oferecer aos leitores, antes de me tornar editor do entretanto extinto Local Centro. A viagem para norte foi relativamente rápida e, em 2005, assumi a editoria do Local Porto, da qual me despediria no final de 2007, para ocupar o cargo que actualmente desempenho, na chefia da secção de Desporto. Desde então, tenho olhado para a actualidade desportiva com a avidez e o interesse do dia de estreia. E acompanhado o relançamento do site de Desporto, a criação de canais dedicados (Jogos Olímpicos, Europeu, Mundial de futebol) e a edição de suplementos em papel com a mesma lupa que uso para aperfeiçoar o jornal que todos os dias sai para as bancas.","email":"nsousa@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editor de Desporto","profissaoNaAltura":"","slug":"nuno-sousa","imagem":{"w":225,"h":225,"largura":225,"altura":225,"nome":"nsousa.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1951120?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Liga Europa da UEFA","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#115;&#117;&#111;&#115;&#110;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"De 0 a 10, o PÚBLICO pontua os jogadores da selecção no jogo frente a Espanha. Diogo Costa, Nuno Mendes e João Félix estiveram em destaque.","url":"/2026/07/06/desporto/noticia/portugal-0espanha-1-notas-jogadores-portugueses-2180780","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Mundial 2026","url":"https://www.publico.pt/2026/07/06/desporto/noticia/portugal-0espanha-1-notas-jogadores-portugueses-2180780"},"id":2180780,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"Cristiano Ronaldo: “Saio de consciência tranquila, de quem deu sempre tudo”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2100801?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6030,"nome":"Augusto Bernardino","descricao":"","email":"augusto.bernardino@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"augusto-bernardino","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#105;&#100;&#114;&#97;&#110;&#114;&#101;&#98;&#46;&#111;&#116;&#115;&#117;&#103;&#117;&#