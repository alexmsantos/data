ribuicao":"","tipo":"PROJECT_SYNDICATE"},{"id":17032,"nome":"Isaac Arnsdorf","descricao":"Jornalista/The Washington Post","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista/The Washington Post","profissaoNaAltura":"","slug":"isaac-arnsdorf","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"PROJECT_SYNDICATE"},{"id":19550,"nome":"Jeremy Roebuck","descricao":"Jornalista/The Washington Post","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista/The Washington Post","profissaoNaAltura":"","slug":"jeremy-roebuck","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"PROJECT_SYNDICATE"},{"id":19732,"nome":"Joe Heim","descricao":"Jornalista. The Washington Post","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista. The Washington Post","profissaoNaAltura":"","slug":"joe-heim","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Apesar da presença de Donald Trump e de algumas das principais figuras da Administração Trump, o jantar dos correspondentes teve um nível de segurança inferior ao de outros eventos.","url":"/2026/04/26/mundo/noticia/jantar-correspondentes-nao-nivel-seguranca-alto-2172628","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Casa Branca","url":"https://www.publico.pt/2026/04/26/mundo/noticia/jantar-correspondentes-nao-nivel-seguranca-alto-2172628"},"id":2172628,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"Ferrovia: foco no eixo Porto – Lisboa esqueceu importantes zonas económicas do país","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2084242?tp=UH&db=IMAGENS&type=JPG","author":[{"id":4119,"nome":"Camilo Soldado","descricao":"","email":"camilo.soldado@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"camilo-soldado","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#100;&#97;&#100;&#108;&#111;&#115;&#46;&#111;&#108;&#105;&#109;&#97;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Investigadores reuniram base de dados com horários, passageiros e níveis de serviço entre 1971 e 2021, que mostra desequilíbrio territorial e a contradição do argumento económico para encerrar linhas.","url":"/2026/04/26/local/noticia/ferrovia-foco-eixo-porto-lisboa-esqueceu-importantes-zonas-economicas-pais-2172486","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Rede ferroviária","url":"https://www.publico.pt/2026/04/26/local/noticia/ferrovia-foco-eixo-porto-lisboa-esqueceu-importantes-zonas-economicas-pais-2172486"},"id":2172486,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Sporting tira mais um dedo da taça de campeão nacional","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2084274?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6063,"nome":"Diogo Cardoso Oliveira","descricao":"Ver desporto, escrever e contar histórias: costumo dizer que sou pago para fazer algo que faria <i>pro-bono</i>. Tudo começou numa t-shirt branca, feita na escola primária, que já identificava um gaiato com más ideias: dizia “Diogo, o jornalista”. Feito um raide incompleto pela aviação, formei-me em Comunicação Social, época em que fazia do jornal universitário <i>Pontivirgula</i> uma tela para rascunhos do que estaria por vir. Comecei a carreira como estagiário no PÚBLICO, no mês em que Éder decidiu dar um chuto aos franceses. Ainda estive no <i>Record</i>, antes de fazer parte do início do site <i>Bancada</i>. Voltei para o PÚBLICO, que já me levou ao Mundial do Qatar, aos Jogos Olímpicos de Paris e onde faço um pouco de tudo no desporto. Gosto de ciclismo, basquetebol, ginástica, futebol, História e histórias — também por isso escrevi o livro <i>Futebol numa conversa de café</i>.","email":"diogo.oliveira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"diogo-cardoso-oliveira","imagem":{"w":1064,"h":1345,"largura":1064,"altura":1345,"nome":"WhatsApp Image 2025-04-24 at 20.31.38.jpeg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1995019?tp=UH&db=IMAGENS&type=JPG","is_vertical":true,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#118;&#105;&#108;&#111;&#46;&#111;&#103;&#111;&#105;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Mesmo sem deslumbrarem, os “leões” fizeram o suficiente para levarem o triunfo deste jogo. Penálti cometido por Morita acabou por ser decisivo para o empate, depois do golo inicial de Rafael Nel.","url":"/2026/04/26/desporto/cronica_de_jogo/sporting-tira-dedo-taca-campeao-nacional-2172623","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Crónica de jogo","url":"/futebol-nacional"},"id":2172623,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"FC Porto vence o Estrela da Amadora e pode encomendar as faixas","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2084267?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3960,"nome":"Jorge Miguel Matias","descricao":"Sou licenciado em Ciências da Comunicação pela Faculdade de Ciências Sociais e Humanas da Universidade Nova de Lisboa e frequentei ainda uma formação adicional em Jornalismo promovida pelo semanário Expresso. Tenho trabalhado na área do desporto desde o início da minha actividade profissional, primeiro na já extinta Gazeta dos Desportos, depois no PÚBLICO, projecto que abracei de forma definitiva em 1998, embora já antes tivesse uma colaboração regular com o jornal. Actualmente, exerço funções de editor. À margem do desporto, colaborei também com revistas como a \"Rotas e Destinos\" ou a \"National Geographic\".","email":"jmatias@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editor de Desporto","profissaoNaAltura":"Editor de Desporto","slug":"jorge-miguel-matias","imagem":{"w":216,"h":216,"largura":216,"altura":216,"nome":"jorgemiguelmatias-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1758433?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#105;&#116;&#97;&#109;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Os “azuis e brancos” deram mais um passo rumo ao título de campeão nacional. Se até este domingo só um colapso impediria a festa, agora só um colapso e uma hecatombe.","url":"/2026/04/26/desporto/cronica_de_jogo/fc-porto-vence-estrela-amadora-encomendar-faixas-2172618","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Crónica de jogo","url":"/futebol-nacional"},"id":2172618,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30}]
