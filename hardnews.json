issaoActual":"Jornalista","profissaoNaAltura":"","slug":"augusto-bernardino","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#105;&#100;&#114;&#97;&#110;&#114;&#101;&#98;&#46;&#111;&#116;&#115;&#117;&#103;&#117;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Primeiro triunfo de uma equipa da segunda divisão na Taça de Portugal espanta mundo do futebol, que nos principais campeonatos da UEFA conta apenas 13 casos semelhantes desde 1894.","url":"/2026/05/25/desporto/noticia/torreense-caso-unico-portugal-raridade-europa-2175975","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Desporto","url":"/desporto"},"id":2175975,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":27,"title":"BCE chama todos os grandes bancos europeus para falar sobre Anthropic","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2090829?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19360,"nome":"Diogo Cavaleiro","descricao":"Estagiei no PÚBLICO em 2009 no Local Lisboa, tendo no ano seguinte entrado no <em>Jornal de Negócios</em>, onde fiquei por quase nove anos. O sector bancário foi aquele em que me especializei, tendo publicado um livro – <em>Caixa Negra</em> – sobre décadas de gestão e polémica na Caixa Geral de Depósitos, em 2017. Em 2019, segui para o <em>Expresso</em>, continuando na mesma área, onde fiquei até Maio de 2025. Regresso agora ao PÚBLICO para continuar esse trabalho, integrando a secção de Economia. Licenciado em Ciências da Comunicação, tenho pós-graduações em Ciência Política – Relações Internacionais, na vertente de Estudos Europeus, e em Compliance.","email":"diogo.cavaleiro@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"diogo-cavaleiro","imagem":{"w":null,"h"