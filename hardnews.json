ra","descricao":"","email":"cferreira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"cristina-ferreira","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Cristisna ferreira nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1153416?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#114;&#101;&#102;&#99;","contribuicao":"texto","tipo":"INTERNO"},{"id":3976,"nome":"Nuno Ferreira Santos","descricao":"","email":"nuno.santos@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"Fotojornalista","slug":"nuno-ferreira-santos","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#111;&#116;&#110;&#97;&#115;&#46;&#111;&#110;&#117;&#110;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"Para o economista Alfredo Marques, que foi um alto quadro da UE na Concorrência, as decisões em matéria de privatizações são um misto de conveniência política, de interesses próprios e de ignorância.","url":"/2026/06/28/economia/entrevista/temo-intencao-fundo-soberano-colocar-recursos-debaixo-logica-mercado-2179470","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista com Alfredo Marques","url":""},"id":2179470,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"Milhões de europeus sob altas temperaturas, França conta mil mortes em excesso","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098723?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19634,"nome":"