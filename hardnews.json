[{"pos":0,"title":"Valor mediano das novas rendas subiu 9,1% no primeiro trimestre","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098309?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1068,"nome":"Luís Villalobos","descricao":"Comecei a trabalhar como jornalista profissional em 1992, na secção de economia do Semanário. Em 1994 apostei na vida de free-lancer, enquanto frequentava o curso de História, tendo colaborado para vários jornais e revistas. Em 2000 entrei para a revista Fortuna, da qual já era colaborador. Três anos depois tive a minha estreia nos diários, no Diário Económico, de onde transitei como editor para a Exame no final de 2005. Em 2007, cheguei ao PÚBLICO, para editar o suplemento de Economia. Actualmente, sou redactor da secção. Ganhei três prémios, o último dos quais na categoria nacional de imprensa e online do Ano Europeu do Combate à Pobreza e Exclusão Social. Sou co-autor do livro, “Negócios Vigiados”, sobre a PIDE e as empresas, e coordenei a obra “Quero um emprego!”, de Elisabete Sá, Raquel Almeida Correia e Ana Rute Silva.","email":"luis.villalobos@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"luis-villalobos","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Luis Villalobos.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1527219?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":",Sistema de gerenciamento de conteúdo","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#111;&#98;&#111;&#108;&#97;&#108;&#108;&#105;&#118;&#46;&#115;&#105;&#117;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Número de novos contratos cresceu apenas 0,7% face a ao primeiro trimestre de 2025.","url":"/2026/06/26/economia/noticia/valor-mediano-novas-rendas-subi