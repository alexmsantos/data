type=JPG","author":[{"id":4038,"nome":"João Pedro Pincha","descricao":"Se não tivesse passado seis meses em Barcelona, provavelmente nunca me teria interessado por escrever sobre Lisboa. Foi na Catalunha que descobri, enquanto estagiava na televisão local, que a esquina mais próxima pode ser tão interessante como o outro lado do mundo. Meses depois, quando entrei no PÚBLICO pela primeira vez, já só queria estagiar na secção Local. E assim me iniciei a acompanhar tudo o que se passava na capital. Ainda passei brevemente pelo <i>O Corvo</i> antes de ajudar a fundar o <i>Observador</i>, onde estive quase três anos. Depois de cinco anos a acompanhar para o PÙBLICO a actualidade lisboeta e arredores, escrevo agora para a secção Mundo.","email":"joao.pincha@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"joao-pedro-pincha","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Joao P Pincha.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1332529?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#104;&#99;&#110;&#105;&#112;&#46;&#111;&#97;&#111;&#106;","contribuicao":"","tipo":"INTERNO"},{"id":15939,"nome":"Fernando Costa","descricao":"","email":"fernando.costa@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"fernando-costa","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"fernando costa.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1868660?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&