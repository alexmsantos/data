alidades que nos rodeiam.","email":"aline.flor@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"aline-flor","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Aline Flor z.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1530339?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#114;&#111;&#108;&#102;&#46;&#101;&#110;&#105;&#108;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"A confirmação foi deixada à Assembleia da República pela ministra do Ambiente e Energia. As atenções da tutela voltam-se agora para a operacionalização do Fundo Social para o Clima.","url":"/2026/04/25/azul/noticia/governo-comprometese-concluir-pagamentos-atraso-vale-eficiencia-2026-2172443","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Fundo Ambiental","url":"https://www.publico.pt/2026/04/25/azul/noticia/governo-comprometese-concluir-pagamentos-atraso-vale-eficiencia-2026-2172443"},"id":2172443,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":10,"title":"Com licença igualitária rejeitada, há pais italianos a redefinir o seu papel <em>online</em>","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2084055?tp=UH&db=IMAGENS&type=JPG","author":[{"id":890,"nome":"Reuters","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"reuters","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"AGENCIAS"}],"shares":0,"description":"O Parlamento italiano rejeitou, em Fevereiro, a proposta de licença parental igualitária. Mas há homens a ex