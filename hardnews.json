[{"pos":0,"title":"Exame de Matemática incluirá matérias que alunos não deram, mas são opcionais","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2077473?tp=UH&db=IMAGENS&type=JPG","author":[{"id":495,"nome":"Andreia Sanches","descricao":"Entrei no PÚBLICO em 1996. Tinha 22 anos, terminado o curso de Ciências da Comunicação na Universidade Nova de Lisboa e estava no jornal onde queria, de facto, começar a fazer jornalismo. Estagiei no Internacional, quando ainda fazíamos fila para aceder ao computador da redacção que estava ligado à Internet. Seguiu-se a Educação, onde fiquei vários anos, quando aquela era uma secção autónoma, diária. Já na Sociedade, o leque de temas sobre os quais passei a escrever alargou-se – a pobreza e as desigualdades, a exclusão e as políticas de protecção social são alguns dos que tenho acompanhado de forma mais sistemática. Em 2013 foi publicado o meu primeiro livro. Chama-se \"Os Anjos Não Comem Chocolate\" e tem como ponto de partida uma reportagem que fiz no PÚBLICO sobre pais que perderam os seus filhos. Ao longo dos últimos anos desempenhei funções de editora do P2, editora da Sociedade, editora-executiva e directora-adjunta.","email":"asanches@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Redactora principal","profissaoNaAltura":"","slug":"andreia-sanches","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"andreia-sanches-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1748990?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Andreia C. Faria","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#104;&#99;&#110;&#97;&#115;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Novas aprendizagens só vigoram em 2027, mas houve dez turmas a antecipá-las. MECI diz que ninguém tem de responder sobre o que não aprendeu. SPM critica “mudança de regras”. APM não.","url":"/2026/03/28/sociedade/noticia/exame-matematica-12-ano-incluira-materias-alunos-nao-deram-ministerio-esclarece-sao-opcionais-2169344","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Acesso ao Ensino Superior 2026","url":"https://www.publico.pt/2026/03/28/sociedade/noticia/exame-matematica-12-ano-incluira-materias-alunos-nao-deram-ministerio-esclarece-sao-opcionais-2169344"},"id":2169344,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":1,"title":"Prémio de 1,4 milhões apoia projectos que combatem a pobreza infantil em Portugal","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2065971?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Estão abertas as candidaturas ao Prémio BPI Fundação ”la Caixa” Infância, cujo objectivo é auxiliar quem luta para quebrar o círculo vicioso de crianças e adolescentes em situação de vulnerabilidade.","url":"/2026/02/23/estudiop/noticia/premio-14-milhoes-apoia-projectos-combatem-pobreza-infantil-portugal-2164226","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"BPI La Caixa","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1779903?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/02/23/estudiop/noticia/premio-14-milhoes-apoia-projectos-combatem-pobreza-infantil-portugal-2164226"},"id":2164226,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":2,"title":"Assis e Santos Silva avisam que ignorar PS no Constitucional é traição à democracia","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2077718?tp=UH&db=IMAGENS&type=JPG","author":[{"id":18811,"nome":"Adriana Castro","descricao":"Jornalista","email":"adriana.castro@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"adriana-castro","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#114;&#116;&#115;&#97;&#99;&#46;&#97;&#110;&#97;&#105;&#114;&#100;&#97;","contribuicao":"","tipo":"INTERNO"},{"id":3966,"nome":"Adriano Miranda","descricao":"Nasci em Aveiro, em 1966, estudei na Escola Secundária José Estevão em Aveiro e depois rumei ao Porto para estudar na Cooperativa Árvore. Fiz a minha especialização em Fotografia no AR.CO em Lisboa.  Em 1994 ingressei no PÚBLICO como Fotojornalista. Fui Editor de Fotografia durante 4 anos e agora estou na redacção do Porto. O PÚBLICO é a minha segunda casa. Com orgulho! \r\n´","email":"amiranda@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"adriano-miranda","imagem":{"w":null,"h":null,"largura":216,"altura":216,"nome":"1044361-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1889075?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Augusto Santos Silva","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#100;&#110;&#97;&#114;&#105;&#109;&#97;","contribuicao":"","tipo":"INTERNO"},{"id":3520,"nome":"David Santiago","descricao":"","email":"david.santiago@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editor de Política","profissaoNaAltura":"Editor de Política","slug":"david-santiago","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"David Santiago.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1765612?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#103;&#97;&#105;&#116;&#110;&#97;&#115;&#46;&#100;&#105;&#118;&#97;&#100;","contribuicao":"","tipo":"INTERNO"},{"id":157,"nome":"Maria Lopes","descricao":"Entrei para o PÚBLICO, vinda da universidade, quando se vivia a excitação das vésperas da primeira Exposição Mundial em Portugal. Calcorreei a Expo-98 de fio a pavio, de caderno, caneta e, por vezes, de Polaroid na mão. Esses poucos meses ensinaram-me a conjugar o verbo tão português “desenrascar-se”.\r\nNestes mais de 20 anos, passei depois pelas secções Local, Media (por duas vezes) e Economia. Estive no lançamento do suplemento Digital – que apesar do nome existiu apenas em papel – e pertenci à equipa do irreverente projecto Sexta, o jornal gratuito que o PÚBLICO partilhou com A Bola, em 2007 e 2008. Em simultâneo, durante dez anos, escrevi também para o Motores (da Fugas), vivendo os automóveis sob uma perspectiva menos técnica e mais prazenteira. Desde 2009 que integro a secção de Política e tento manter debaixo de olho o panorama dos media. \r\n\r\n","email":"maria.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"maria-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Maria_C_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737865?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#97;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"No segundo dia de congresso socialista serão entregues as listas aos órgãos nacionais do partido e vão decorrer vários debates temáticos no âmbito da iniciativa “oficina do