":null,"site":null,"url":null,"localizacao":"","profissaoActual":null,"profissaoNaAltura":"","slug":"pedro-keul","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#108;&#117;&#101;&#107;&#112;","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Marta Kostyuk é a primeira semifinalista ucraniana de Roland-Garros.","url":"/2026/06/02/desporto/noticia/autoritario-alexander-zverev-avanca-meiasfinais-rolandgarros-2176986","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Ténis","url":"https://www.publico.pt/2026/06/02/desporto/noticia/autoritario-alexander-zverev-avanca-meiasfinais-rolandgarros-2176986"},"id":2176986,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":21,"title":"FNAC Live: um dia para respirar cultura junto ao Tejo","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2092532?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"À beira do Tejo e com a música a fazer-se ouvir nos Jardins da Torre de Belém, o FNAC Live voltou a reunir milhares de pessoas num dia de cultura ao ar livre.","url":"/2026/06/02/estudiop/noticia/fnac-live-dia-respirar-cultura-junto-tejo-2176802","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"FNAC","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1574680?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/02/estudiop/noticia/fnac-live-dia-respirar-cultura-junto-tejo-2176802"},"id":2176802,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"“Sou, então, um traidor?”, o grito de Kamel Daoud e a viagem de Erika Fatland","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2092984?tp=UH&db=IMAGENS&type=JPG","author":[{"id":498,"nome":"Isabel Coutinho","descricao":"Adoro histórias, principalmente as que me são contadas pelos outros. É por isso que, apesar de licenciada em Filosofia, quis ser jornalista. Pertenço ao grupo de estagiários que participaram no lançamento do PÚBLICO em 1990. Apesar de ter nascido no Porto, trabalho na redacção em Lisboa. No jornal, tive Fantasias — histórias à volta de objectos na revista de domingo Magazine —, trabalhei na Agenda (fazia os Números & Factos) e entrei em 1991 para a Cultura. Em 1992, integrei a equipa que cobriu os seis meses em que Portugal presidiu à União Europeia. Desde 1996, que assino uma coluna sobre o futuro dos livros e a relação entre as novas tecnologias e a literatura: Ciberescritas. Fiz parte da equipa da revista Pública. Fui editora do suplemento literário Mil Folhas, de Fevereiro de 2002 a Fevereiro de 2007. E também fui editora da Cultura.","email":"isabel.coutinho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"isabel-coutinho","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Isabel_Coutinho.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/738284?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#110;&#105;&#116;&#117;&#111;&#99;&#46;&#108;&#101;&#98;&#97;&#115;&#105;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O argelino lança o ensaio <em>Por Vezes É Preciso Trair</em> e a norueguesa viajou por três continentes para cruzar o passado e o presente das antigas colónias portuguesas em <em>Os Navegadores</em>. \r\n","url":"/2026/06/02/culturaipsilon/noticia/entao-traidor-grito-kamel-daoud-viagem-erika-fatland-2176959","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Saída de livros","url":"https://www.publico.pt/2