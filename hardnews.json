.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"em Linköping, na Suécia","profissaoActual":"Jornalista e Editor Online","profissaoNaAltura":"","slug":"pedro-guerreiro","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"pguerreiro.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1835785?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Tour Challenger ATP","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#114;&#105;&#101;&#114;&#114;&#101;&#117;&#103;&#46;&#111;&#114;&#100;&#101;&#112;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O caça sueco candidato à substituição dos F-16 portugueses tem um co-piloto de inteligência artificial, pode descolar e aterrar na estrada e é um produto de décadas de vizinhança tensa com os russos.","url":"/2026/05/03/mundo/reportagem/gripen-ef-aviao-veio-frio-2173208","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Reportagem","url":"/defesa"},"id":2173208,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"Chega já quis 20 CPI, agora quer à <em>Operação Influencer</em> mas só pode impor em Setembro","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2085616?tp=UH&db=IMAGENS&type=JPG","author":[{"id":18186,"nome":"Joana Mesquita","descricao":"","email":"joana.mesquita@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"joana-mesquita","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#116;&#105;&#117;&#113;&#115;&#101;&#109;&#46;&#97;&#110;&#97;&#111;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Chega já defendeu, pelo menos, 20 comissões de inquérito, embora só três tenham avançado. Ventura garante agora CPI à <em>Operação Influencer,</em> mas, se Parlamento não aprovar, terá de esperar.","url":"/2026/05/03/politica/noticia/chega-ja-quis-20-comissoes-inquerito-quer-operacao-influencer-so-impor-setembro-2173292","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Comissão de inquérito","url":"https://www.publico.pt/2026/05/03/politica/noticia/chega-ja-quis-20-comissoes-inquerito-quer-operacao-influencer-so-impor-setembro-2173292"},"id":2173292,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Jan Martínez Ahrens: “A verdade é algo que requer tempo, dinheiro e esforço”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2085225?tp=UH&db=IMAGENS&type=JPG","author":[{"id":749,"nome":"Helena Pereira","descricao":"Comecei a ser jornalista em 1996, no PÚBLICO, na editoria de Política, depois de um estágio na TSF. Em 2006, participei na fundação do semanário SOL, como jornalista de Política e, mais tarde, na fundação do jornal Observador, como editora de Política. Em 2016, passei para o Expresso também como editora de Política até ser convidada a regressar ao PÚBLICO em 2018 para ser editora executiva. Nasci num belo ano, 1974, na Maternidade Alfredo da Costa, em Lisboa, e sou mãe de gémeos, o Jaime e a Júlia.","email":"helena.pereira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editora executiva","profissaoNaAltura":"Editora executiva","slug":"helena-pereira","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"helena-pereira-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1739855?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Público","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#101;&#112;&#46;&#97;&#110;&#101;&#108;&#101;&#104;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O diário espanhol <em>El País</em> celebra 50 anos no dia 4 de Maio. Nasceu um ano depois da morte de Franco e tem 450 mil assinantes digitais. O director diz que os leitores querem “saber a verdade”.","url":"/2026/05/03/sociedade/entrevista/director-el-pais-verdade-algo-requer-tempo-dinheiro-esforco-2172958","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista com o director do <em>El País</em>","url":""},"id":2172958,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"Retirada de 5000 soldados dos EUA da Alemanha reforça necessidade de defesa europeia","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2085601?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6310,"nome":"Inês Chaíça","descricao":"","email":"ines.chaica@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ines-chaica","imagem":{"w":null,"h":null,"largura":544,"altura":459,"nome":"Inês_profile_pic-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/2003976?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#99;&#105;&#97;&#104;&#99;&#46;&#115;&#101;&#110;&#105;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Com a saída anunciada de 15% dos efectivos na Alemanha, que pode acontecer nos próximos seis a 12 meses, volta-se aos números registados antes da invasão da Ucrânia pela Rússia.","url":"/2026/05/02/mundo/noticia/retirada-5000-soldados-eua-alemanha-reforca-necessidade-defesa-europeia-2173318","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Estados Unidos","url":"https://www.publico.pt/2026/05/02/mundo/noticia/retirada-5000-soldados-eua-alemanha-reforca-necessidade-defesa-europeia-2173318"},"id":2173318,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Quem é Lua Afonso, a estudante de 18 anos da Covilhã elogiada no Parlamento?","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2085509?tp=UH&db=IMAGENS&type=JPG","author":[{"id":5669,"nome":"Claudia Carvalho Silva","descricao":"Nasci em Neuchâtel, na Suíça – daí que escreva o meu nome sem acento. Mais tarde, já em Portugal, estive dividida entre as ciências e as letras, num ímpeto constante de querer fazer e aprender tudo ao mesmo tempo. Decidi deixar de lado a certeza de que o coração não tem vontade e estudar Jornalismo na Faculdade de Letras da Universidade de Coimbra. Passei pelo jornal universitário <i>A Cabra</i>, a revista <i>Via Latina</i> e o Festival Caminhos do Cinema Português. E, no final de 2015, cheguei ao PÚBLICO para estagiar na secção Local, onde descobri algumas das histórias que Lisboa tem para contar. Depois de abraçar o desafio online, integrei a equipa fundadora do Azul, o nosso projecto dedicado à crise climática, que editei durante dois anos. Agora, estou no P3. E aprendo todos os dias.","email":"claudia.silva@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"claudia-carvalho-silva","imagem":{"w":null,"h":null,"largura":437,"altura":572,"nome":"CLAUDIACARVALHOSILVA_REDIMENSIONADA-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1440637?tp=UH&db=IMAGENS&type=PNG","is_vertical":true,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#118;&#108;&#105;&#115;&#46;&#97;&#105;&#100;&#117;&#97;&#108;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Do piano ao espaço, da corrida à patinagem artística, da leitura à escrita, muitos são os interesses (e os prémios) de Lua Afonso. No Verão, estará na NASA a representar a Europa numa competição.","url":"/2026/05/02/p3/perfil/18-anos-soma-premio-atras-premio-elogiada-parlamento-lua-afonso-2173272","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"p3"},"brand":null,"rubric":{"name":"Perfil","url":"/jovens"},"id":2173272,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"FC Porto fez a festa do campeonato com milhares de adeptos no Dragão","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2085639?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1059,"nome":"Nuno Sousa","descricao":"Primeiro, foi a informação local. Em Aveiro, durante um ano (o de 2003), ajudei a levantar um dos quatro cadernos regionais que o PÚBLICO chegou a oferecer aos leitores, antes de me tornar editor do entretanto extinto Local Centro. A viagem para norte foi relativamente rápida e, em 2005, assumi a editoria do Local Porto, da qual me despediria no final de 2007, para ocupar o cargo que actualmente desempenho, na chefia da secção de Desporto. Desde então, tenho olhado para a actualidade desportiva com a avidez e o interesse do dia de estreia. E acompanhado o relançamento do site de Desporto, a criação de canais dedicados (Jogos Olímpicos, Europeu, Mundial de futebol) e a edição de suplementos em papel com a mesma lupa que uso para aperfeiçoar o jornal que todos os dias sai para as bancas.","email":"nsousa@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editor de Desporto","profissaoNaAltura":"","slug":"nuno-sousa","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"nsousa.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1951120?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Liga Europa da UEFA","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#115;&#117;&#111;&#115;&#110;","contribuicao":"","tipo":"INTERNO"},{"id":7165,"nome":"Miguel Dantas","descricao":"","email":"miguel.dantas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"miguel-dantas","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#110;&#97;&#100;&#46;&#108;&#101;&#117;&#103;&#105;&#109;","contribuicao":"","tipo":"INTERNO"},{"id":6063,"nome":"Diogo Cardoso Oliveira","descricao":"Ver desporto, escrever e contar histórias: costumo dizer que sou pago para fazer algo que faria <i>pro-bono</i>. Tudo começou numa t-shirt branca, feita na escola primária, que já identificava um gaiato com más ideias: dizia “Diogo, o jornalista”. Feito um raide incompleto pela aviação, formei-me em Comunicação Social, época em que fazia do jornal universitário <i>Pontivirgula</i> uma tela para rascunhos do que estaria por vir. Comecei a carreira como estagiário no PÚBLICO, no mês em que Éder decidiu dar um chuto aos franceses. Ainda estive no <i>Record</i>, antes de fazer parte do início do site <i>Bancada</i>. Voltei para o PÚBLICO, que já me levou ao Mundial do Qatar, aos Jogos Olímpicos de Paris e onde faço um pouco de tudo no desporto. Gosto de ciclismo, basquetebol, ginástica, futebol, História e histórias — também por isso escrevi o livro <i>Futebol numa conversa de café</i>.","email":"diogo.oliveira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"diogo-cardoso-oliveira","imagem