 tempos.","url":"/2026/05/16/fugas/reportagem/cairo-silencioso-cairo-caotico-viceversa-2172454","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Reportagem","url":"/egipto"},"id":2172454,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":212,"nome":"Egipto","slug":"egipto","tagEn":"","isPrincipal":false,"isVisible":true,"urlRoute":"/tegipto","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAberto":false,"follow_type":null,"descricao":null,"imagem":null,"html":null,"isForForuns":false,"isUsedInForuns":false},"size":30},{"pos":12,"title":"UE ignorou peritos e atribuiu estatuto estratégico a projectos de lítio portugueses","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2088759?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6488,"nome":"Aline Flor","descricao":"Natural do Rio de Janeiro, vivo em Portugal há quase 30 anos. Criei raízes. Fui directora do Jornal Universitário do Porto, passei pela Ciência e Tecnologia no Canal Superior, editei notícias do portal AEIOU.pt. Fiz um mestrado em Cinema Documental que me abriu os olhos (e ouvidos) para a riqueza de cada encontro com o outro. Cheguei ao PÚBLICO para integrar a equipa de áudio, onde produzi podcasts em áreas desde a igualdade de género às questões europeias. Hoje sou editora do Azul, a nossa secção dedicada à crise climática e sustentabilidade, e aventurei-me num segundo mestrado: Economia e Gestão do Ambiente. Gosto de ouvir e de contar as histórias que ficam à margem e acredito que temos sempre algo a aprender quando encaramos o desafio de traduzir no preto e branco dos caracteres as infinitas tonalidades que nos rodeiam.","email":"aline.flor@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"aline-flor","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Aline Flor z.jpg","legenda":null,"autor":null,