d":0,"name":"BPI La Caixa","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1779903?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/02/23/estudiop/noticia/premio-14-milhoes-apoia-projectos-combatem-pobreza-infantil-portugal-2164226"},"id":2164226,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":2,"title":"Qual é a importância de Diego Garcia, a base norte-americana atacada pelo Irão?","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2076084?tp=UH&db=IMAGENS&type=JPG","author":[{"id":4123,"nome":"João Ruela Ribeiro","descricao":"","email":"joao.ruela@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"joao-ruela-ribeiro","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#108;&#101;&#117;&#114;&#46;&#111;&#97;&#111;&#106;","contribuicao":"","tipo":"INTERNO"},{"id":11646,"nome":"Infografia | PÚBLICO","descricao":"","email":"infografia@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"infografia-publico","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#105;&#102;&#97;&#114;&#103;&#111;&#102;&#110;&#105;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Pela primeira vez desde o início do conflito, o Irão usou mísseis balísticos de alcance intermédio para atacar a importante base militar no oceano Índico.","url":"/2026/03/21/mundo/noticia/importancia-diego-garcia-base-norteamericana-atacada-irao-2168704","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"EUA","url":"https://www.publico.pt/2026/03/21/mundo/noticia/importancia-diego-garcia-base-norteamericana-atacada-irao-2168704"},"id":2168704,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"O que ficou do Pinhal de Leiria? Toneladas de lenha, mais vento e calor","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2075943?tp=UH&db=IMAGENS&type=JPG","author":[{"id":18051,"nome":"Paula Sofia Luz","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"paula-sofia-luz","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Paula Sofia Luz.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/2062595?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"","contribuicao":"texto","tipo":"INTERNO"},{"id":3966,"nome":"Adriano Miranda","descricao":"Nasci em Aveiro, em 1966, estudei na Escola Secundária José Estevão em Aveiro e depois rumei ao Porto para estudar na Cooperativa Árvore. Fiz a minha especialização em Fotografia no AR.CO em Lisboa.  Em 1994 ingressei no PÚBLICO como Fotojornalista. Fui Editor de Fotografia durante 4 anos e agora estou na redacção do Porto. O PÚBLICO é a minha segunda casa. Com orgulho! \r\n´","email":"amiranda@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"adriano-miranda","imagem":{"w":null,"h":null,"largura":216,"altura":216,"nome":"1044361-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1889075?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Augusto Santos Silva","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#100;&#110;&#97;&#114;&#105;&#109;&#97;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"O ICNF acredita que vai ser capaz de recolher as toneladas de lenha que ficaram no chão. O que não ardeu em 2017 foi agora derrubado. Especialistas alertam: haverá menos sombra, mais calor e vento.","url":"/2026/03/21/local/reportagem/ficou-pinhal-leiria-nada-toneladas-lenha-vento-calor-2168656","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Reportagem","url":"/florestas"},"id":2168656,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"“Sou racista 24h por dia. Nunca me aconteceu nada.” Acusações por racismo sobem 40%\r\n","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2075822?tp=UH&db=IMAGENS&type=JPG","author":[{"id":455,"nome":"Joana Gorjão Henriques","descricao":"Entrei para o PÚBLICO no final de 1999, para estagiar na Cultura, onde fiquei durante dez anos. Entre fim de 2009 e de 2011 fiz uma pausa de dois anos, primeiro para ser bolseira da Nieman Foundation for Journalism na Universidade de Harvard, EUA; e depois para estudar Sociologia na London School of Economics, em Londres. Integro a secção de Sociedade, escrevendo sobre temas ligados a imigração, racismo, direitos humanos. Sou autora de 3 séries que deram livros: Racismo em português, sobre o racismo durante o sistema colonial, Racismo à Portuguesa, retrato de desigualdades raciais em Portugal e Colonos em Angola e Moçambique. Retornados em Portugal, que deu também origem ao documentário Racismo, uma descolonização em curso. Recebi a medalha de ouro de Direitos Humanos da Assembleia da República e alguns prémios: o Prémio Gazeta duas vezes, o Prémio AMI - Jornalismo contra a Indiferença por duas vezes, o prémio de Jornalismo de imprensa escrita de Direitos Humanos e Integração, da Comissão Nacional da UNESCO por duas vezes, o prémio de imprensa escrita Comunicação \"Pela Diversidade Cultural\" do Alto Comissariado para as Migrações, também por duas vezes, o prémio de jornalismo Corações com Coroa duas vezes, o prémio Os Direitos da Criança em Notícia  e fiquei na lista final dos prémio ibero-americanos da Fundação Gabo.","email":"jgh@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"joana-gorjao-henriques","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#104;&#103;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Um dos 311 inquéritos por crimes de ódio abertos em 2025 resultou em acusação este ano. Acusações sobem, mas continuam a representar cerca de 2,3% dos processos. Este sábado é dia contra o racismo.","url":"/2026/03/21/sociedade/noticia/racista-24h-dia-aconteceu-nada-acusacoes-racismo-sobem-40-2168596","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Discriminação","url":"https://www.publico.pt/2026/03/21/sociedade/noticia/racista-24h-dia-aconteceu-nada-acusacoes-racismo-sobem-40-2168596"},"id":2168596,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Morreu Robert Mueller, ex-líder do FBI que investigou mão russa nas eleições de 2016","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2076119?tp=UH&db=IMAGENS&type=JPG","author":[{"id":973,"nome":"PÚBLICO","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"publico","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Mueller, que concluiu que Moscovo interferiu na votação que elegeu Donald Trump pela primeira vez, morre aos 81 anos.","url":"/2026/03/21/mundo/noticia/morreu-robert-mueller-exdirector-fbi-investigou-interferenc