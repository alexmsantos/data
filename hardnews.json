ramalho.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1328997?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#108;&#97;&#109;&#97;&#114;&#46;&#111;&#103;&#97;&#105;&#116;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"A última vez que um humano pisou a Lua foi em 1972. Agora, o intuito é regressar – e para ficar. Há motivações científicas, mas sobretudo a ambição de ter recursos que podem estar escondidos na Lua.","url":"/2026/03/31/ciencia/noticia/queremos-voltar-lua-2169683","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Exploração espacial","url":"https://www.publico.pt/2026/03/31/ciencia/noticia/queremos-voltar-lua-2169683"},"id":2169683,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":24,"title":"“Não precisamos de duas bases lunares, mas sim de uma única base lunar internacional”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2078178?tp=UH&db=IMAGENS&type=JPG","author":[{"id":7026,"nome":"Tiago Ramalho","descricao":"","email":"tiago.ramalho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"tiago-ramalho","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"tiagoramalho.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1328997?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#108;&#97;&#109;&#97;&#114;&#46;&#111;&#103;&#97;&#105;&#116;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O regresso dos humanos à