ra":472,"altura":472,"nome":"rosa soares.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1390182?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#114;&#97;&#111;&#115;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"José Coutinho, director de subscrição da Zurich, diz que a tempestade <i>Kristin</i> deixou evidente a falta de um fundo de catástrofe, mas também a fraca cobertura de seguros por particulares e empre","url":"/2026/02/18/economia/entrevista/proximos-anos-preco-seguros-ira-aumentar-face-probabilidade-catastrofes-2165093","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista","url":"/catastrofes-naturais"},"id":2165093,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":13,"title":"Autarquias pedem ajuda ao Governo para gerir impacto da imigração","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2063702?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19963,"nome":"Catarina Pinho","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"jornalista estagiária","profissaoNaAltura":"Jornalista Estagiária","slug":"catarina-pinho","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Territórios rurais “geram riqueza ao país”, mas “não têm retorno do Estado” para responder à sobrecarga que o crescimento da imigração causou na habitação, escolas e centros de saúde dos concelhos.","url":"/2026/02/18/sociedade/noticia/recolha-lixo-falta-interpretes-casas-autarquias-pedem-ajuda-governo-gerir-impacto-imigracao-2163357","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Imigração","url":"https://www.publico.pt/2026/02/18/sociedade/noticia/recolha-lixo-falta-interpretes-casas-autarquias-pedem-ajuda-governo-gerir-impacto-imigracao-2163357"},"id":2163357,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":14,"title":"Elvis, esse ilustre desconhecido","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2067836?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1034,"nome":"Mário Lopes","descricao":"A culpa é de um gira-discos e dos discos que o meu pai rodava no gira-discos. A música chegou primeiro. Como com a maioria dos adolescentes, a música moldou-me gostos e atitudes, os discos foram guias para a descoberta do mundo. Através deles, cheguei a livros, a cinema, a nomes e mais nomes e a outros discos, outros livros, outros filmes. Foi pela música que cheguei ao jornalismo. Primeiro no Blitz, onde entrei estagiário no final do curso de Ciências da Comunicação e que seria, posteriormente, a casa do meu primeiro emprego. Depois no Diário de Notícias, onde a música começou a significar mais jornalismo, aberto a mais que bandas e discos. Ao PÚBLICO cheguei em 2005. Para escrever maioritariamente sobre música. Para, através da música, chegar a outros universos da cultura. E para, através da cultura, tentar compreender melhor o mundo e, escrevendo sobre ela, tentar mostrá-lo o mais claramente possível. A adolescência já lá vai há muito. Discos, livros, filmes, continuam a ser guias de descoberta. Assim sendo, continuarei.","email":"mario.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"mario-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Mario_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/860961?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#