cricao":"","email":"rafaela.relvas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"rafaela-burd-relvas","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#118;&#108;&#101;&#114;&#46;&#97;&#108;&#101;&#97;&#102;&#97;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Executivo volta a rejeitar que imóveis que foram a hasta pública tenham sido vendidos abaixo do preço de mercado e mantém intenção de vender edifícios que poderiam ter centenas de casas públicas.","url":"/2026/06/22/economia/noticia/governo-nao-ve-fundamento-travar-venda-imoveis-casas-publicas-2178817","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Habitação","url":"https://www.publico.pt/2026/06/22/economia/noticia/governo-nao-ve-fundamento-travar-venda-imoveis-casas-publicas-2178817"},"id":2178817,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":11,"title":"Há 50 anos, o calor que sentíamos era até cinco graus menos intenso","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2096868?tp=UH&db=IMAGENS&type=JPG","author":[{"id":177,"nome":"Andréia Azevedo Soares","descricao":"Nasci no Rio de Janeiro, onde estudei jornalismo na Universidade Federal. Mudei-me para Portugal em 1999. Trabalho no PÚBLICO desde 2000, com duas interrupções – uma para um doutoramento em Comunicação de Ciência no Imperial College, em Londres, e outra para colaborar com a revista científica WHO Bulletin, em Genebra. Já fui estagiária, colaboradora, repórter e sub-editora em diferentes secções deste jornal. A ciência e a literatura são as áreas sobre as quais mais gosto de escrever; fascina-me o modo como o escritor e o cientista se empenham para detalhar e compreender o mundo que nos rodeia, incluindo os seres vivos que nele habitam.\r\n\r\n\r\n\r\n","email":"aasoares@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"andreia-azevedo-soares","imagem":{"w":null,"h":null,"largura":501,"altura":498,"nome":"andreia_soares-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1725026?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#114;&#97;&#111;&#115;&#97;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Estudo da <em>Nature Climate Change</em> mostra que a sensação térmica extrema se intensificou na Europa, com noites mais quentes, mais dias de risco e uma época de calor mais longa.\r\n\r\n","url":"/2026/06/22/azul/noticia/ha-50-anos-calor-sentiamos-ate-5-graus-celsius-menos-intenso-hoje-2178850","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Clima","url":"https://www.publico.pt/2026/06/22/azul/noticia/ha-50-anos-calor-sentiamos-ate-5-graus-celsius-menos-intenso-hoje-2178850"},"id":2178850,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":12,"title":"Já há três mortos em França devido à onda de calor de mais de 40°C na Europa\r\n","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2097335?tp=UH&db=IMAGENS&type=JPG","author":[{"id":890,"nome":"Reuters","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"reuters","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"AGENCIAS"},{"id":973,"nome":"PÚBLICO","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"lo