.anibal@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"sergio-anibal","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Sergio_Anibal.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737905?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#108;&#97;&#98;&#105;&#110;&#97;&#46;&#111;&#105;&#103;&#114;&#101;&#115;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Reforma antecipada de Mário Centeno foi feita com acordo de Álvaro Santo Pereira e ao abrigo das regras do fundo de pensões do Banco de Portugal para os trabalhadores admitidos antes de Março de 2009.","url":"/2026/03/16/economia/noticia/banco-portugal-confirma-acordo-saida-centeno-reforma-sera-paga-fundo-pensoes-2168064","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Banco de Portugal","url":"https://www.publico.pt/2026/03/16/economia/noticia/banco-portugal-confirma-acordo-saida-centeno-reforma-sera-paga-fundo-pensoes-2168064"},"id":2168064,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Como se constrói uma rede de intermediação financeira com escala nacional","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2071333?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"A Rede Doutor Finanças demonstrou que o crescimento exige a força de uma marca reconhecida pelos consumidores, presença física próxima das famílias e uma estrutura operacional robusta.","url":"/2026/03/10/estudiop/noticia/constroi-rede-intermediacao-financeira-escala-nacional-2166675","comments":2,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Doutor Finanças","Ima