[{"pos":0,"title":"Crianças abandonadas: MP pede prisão preventiva para mãe e para o seu companheiro","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2090405?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1050,"nome":"Mariana Oliveira","descricao":"Nasci no Porto em 1978 e fiz a licenciatura em Direito na Faculdade de Direito da Universidade do Porto. Quando optei por este curso, já tinha a intenção de me tornar jornalista, seguindo o conselho de alguns profissionais da classe. Depois de terminar a licenciatura, candidatei-me à Formação Geral – Especialização em Jornalismo no Centro Protocolar de Formação Profissional para Jornalistas (Cenjor), em Lisboa. Por isso vivi na capital quase oito meses, entre Dezembro de 2001 e Julho de 2002. Nesse mês, decidi regressar ao Porto para fazer o estágio integrado nessa formação. Fui jornalista estagiária no PÚBLICO entre Julho e Outubro e comecei a trabalhar em Fevereiro de 2003. No início, cobri mais intensivamente áreas ligadas à protecção civil. Actualmente, dedico-me à área da Justiça.","email":"meoliveira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"mariana-oliveira","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#118;&#105;&#108;&#111;&#101;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Primeiro interrogatório judicial demorou cerca de quatro horas, tendo terminado por volta da meia-noite. Medidas de coacção vão ser anunciadas pela juíza de instrução de Setúbal este sábado de manhã.","url":"/2026/05/23/sociedade/noticia/criancas-abandonadas-mp-pede-prisao-preventiva-mae-companheiro-2175768","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Justiça","url":"https://www.publico.pt/2026/05/23/sociedade/noticia/criancas-abandonadas-mp-pede-prisao-preventiva-mae-companheiro-2175768"},"id":2175768,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":1,"title":"Entre fraldas e assaduras, como cuidar da pele do seu bebé?","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2082889?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Manter a pele do bebé suave e prevenir assaduras são duas preocupações dos pais. <em>Quanto mais creme, melhor</em> é um mito: o produto certo, usado no momento certo, é o que traz resultados.","url":"/2026/05/13/estudiop/noticia/fraldas-assaduras-cuidar-pele-bebe-2172008","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Halibut - Muda Fraldas","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2086740?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/05/13/estudiop/noticia/fraldas-assaduras-cuidar-pele-bebe-2172008"},"id":2172008,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":2,"title":"Entre o desafio, a estabilidade e o sonho: a história de cinco jovens na vida militar","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2090335?tp=UH&db=IMAGENS&type=JPG","author":[{"id":18811,"nome":"Adriana Castro","descricao":"Jornalista","email":"adriana.castro@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"adriana-castro","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#114;&#116;&#115;&#97;&#99;&#46;&#97;&#110;&#97;&#105;&#114;&#100;&#97;","contribuicao":"texto","tipo":"INTERNO"},{"id":3966,"nome":"Adriano Miranda","descricao":"Nasci em Aveiro, em 1966, estudei na Escola Secundária José Estevão em Aveiro e depois rumei ao Porto para estudar na Cooperativa Árvore. Fiz a minha especialização em Fotografia no AR.CO em Lisboa.  Em 1994 ingressei no PÚBLICO como Fotojornalista. Fui Editor de Fotografia durante 4 anos e agora estou na redacção do Porto. O PÚBLICO é a minha segunda casa. Com orgulho! \r\n´","email":"amiranda@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"adriano-miranda","imagem":{"w":216,"h":216,"largura":216,"altura":216,"nome":"1044361-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1889075?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Augusto Santos Silva","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#100;&#110;&#97;&#114;&#105;&#109;&#97;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"Querer ajudar, procurar um desafio ou mudar de vida. Maria, Ana, Rúben, Leonardo e Fábio chegaram ao Exército por motivos diferentes, mas partilham a ambição de construir uma carreira militar.","url":"/2026/05/22/politica/reportagem/desafio-estabilidade-sonho-historia-cinco-jovens-vida-militar-2175730","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Reportagem","url":"/forcas-armadas"},"id":2175730,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"Nos bastidores de <i>Em Sede Própria</i>: chegou a vez de Joana Marques falar","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2090286?tp=UH&db=IMAGENS&type=JPG","author":[{"id":12425,"nome":"Inês Duarte de Freitas","descricao":"","email":"ines.freitas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"ines-duarte-freitas","imagem":{"w":344,"h":320,"largura":344,"altura":320,"nome":"WhatsApp_Image_2023-02-01_at_13.49.04-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1775300?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#105;&#101;&#114;&#102;&#46;&#115;&#101;&#110;&#105;","contribuicao":null,"tipo":"INTERNO"},{"id":3976,"nome":"Nuno Ferreira Santos","descricao":"","email":"nuno.santos@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Fotojornalista","profissaoNaAltura":"Fotojornalista","slug":"nuno-ferreira-santos","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#111;&#116;&#110;&#97;&#115;&#46;&#111;&#110;&#117;&#110;","contribuicao":null,"tipo":"INTERNO"},{"id":3925,"nome":"Joana Bourgard","descricao":"Sou jornalista desde 2007 e, ao longo destes anos de profissão, é a terceira vez que estou no PÚBLICO. Comecei como estagiária, na secção de Fotografia do jornal. Prossegui fotojornalismo no Jornal de Notícias, no Porto, onde fiquei três anos. Foi nessa altura que apareceram os smartphones e as primeiras máquinas fotográficas digitais com a possibilidade de captar imagem em movimento. Tornei-me jornalista multimédia e regressei para Lisboa para fazer parte da equipa de vídeo do PÚBLICO, em 2010. Passado quatro anos juntei-me à equipa multimédia da Rádio Renascença. Por fim, 15 anos depois do estágio no PÚBLICO, regressei em 2022 para editar a secção de Multimédia. Em 2007 fiz parte fundação da <a href=\"https://wilder.pt\">Wilder.pt</a>, um projecto de jornalismo independente dedicado à natureza e biodiversidade.","email":"joana.bourgard@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Editora de Multimédia","profissaoNaAltura":"Editora de Multimédia","slug":"joana-bourgard","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Joana_Bourgard.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737812?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#100;&#114;&#97;&#103;&#114;&#117;&#111;&#98;&#46;&#97;&#110;&#97;&#111;&#106;","contribuicao":null,"tipo":"INTERNO"},{"id":7325,"nome":"Joana Gonçalves","descricao":"Licenciei-me em Ciências da Comunicação pela Universidade Nova de Lisboa e concluí, em 2018, uma pós-graduação em Jornalismo Multiplataforma. No mesmo ano comecei a trabalhar na Renascença, a redacção onde me formei, e aprendi que também na rádio há lugar para a imagem. Cheguei ao PÚBLICO em 2022.","email":"jmgoncalves@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Jornalista multimédia","profissaoNaAltura":"Jornalista multimédia","slug":"joana-goncalves","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#118;&#108;&#97;&#99;&#110;&#111;&#103;&#109;&#106;","contribuicao":null,"tipo":"INTERNO"},{"id":16009,"nome":"Nuno Moura","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Web Designer","profissaoNaAltura":"Web Designer","slug":"nuno-barata-moura","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":null,"tipo":"INTERNO"}],"shares":0,"description":"Foi o julgamento de 2025. Os Anjos acusavam Joana Marques de danos financeiros e &agrave; reputa&ccedil;&atilde;o, consequ&ecirc;ncia de um v&iacute;deo humor&iacute;stico. Em tribunal, a humorista nunca falou. Preferiu faz&ecirc;-lo em palco.","url":"https://www.publico.pt/multimedia/interactivo/joana-marques-bastidores-em-sede-propria","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"Humor","url":"/impar"},"id":27258,"type":"EXTERNOS","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"«The Lady»: caso mediático do Reino Unido é protagonista no canal AXN","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2089860?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"«The Lady», inspirada no caso real de Jane Andrews, antiga assistente de Sarah Ferguson, estreia no canal AXN Portugal no dia 20 de Maio.","url":"/2026/05/19/estudiop/noticia/the-lady-caso-mediatico-reino-unido-protagonista-canal-axn-2175127","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"AXN","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1953085?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/05/19/estudiop/noticia/the-lady-caso-mediatico-reino-unido-protagonista-canal-axn-2175127"},"id":2175127,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Delgado Alves: debate para desclassificar documentos é só para “diabolizar o outro”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2090351?tp=UH&db=IMAGENS&type=JPG","author":[{"id":15507,"nome":"Ana Bacelar Begonha","descricao":"","email":"ana.begonha@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ana-bacelar-begonha","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#104;&#110;&#111;&#103;&#101;&#98;&#46;&#97;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Socialista defende que a desclass