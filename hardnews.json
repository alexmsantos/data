o.pt/2026/03/26/estudiop/noticia/global-teacher-prize-portugal-professores-transformam-vidas-2169175"},"id":2169175,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":20,"title":"Kimi Antonelli continua a voar em Suzuka","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2077666?tp=UH&db=IMAGENS&type=JPG","author":[{"id":206,"nome":"Marco Vaza","descricao":"O desporto tem vencedores e perdedores, heróis e vilões e a história nem sempre é sobre o que ganha. Eu escrevo sobre aquele que marca o golo decisivo, sobre aquele que corre mais do que os outros, sobre aquele que não desiste ou sobre aquele que desistiu quando estava perto do fim. Já assisti ao vivo a grandes goleadas, recordes do mundo, estreias de futuras estrelas e despedidas de mitos. Entrei no PÚBLICO como estagiário em 1999 para a secção de Desporto, onde continuo, depois de uma comissão entre 2006 e 2009 como editor da revista de domingo. Para além de centenas de jogos de futebol, já estive em duas edições dos Jogos Olímpicos (Atenas 2004 e Londres 2012), numa edição dos Mundiais de atletismo (Helsínquia 2005) e noutras competições de muitas modalidades. O desporto dos outros é a minha profissão.","email":"mvaza@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"marco-vaza","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Marco_Vaza.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737861?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#122;&#97;&#118;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Italiano da Mercedes vai sair da <em>pole position</em> no Grande Prémio do Japão, terceira prova do Mundial de Fórmula 1.","url":"/2026/03/28/desporto/noticia/kimi-antonelli-continua-voar-suzuka-2169487","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Fórmula 1","url":"https://www.publico.pt/2026/03/28/desporto/noticia/kimi-antonelli-continua-voar-suzuka-2169487"},"id":2169487,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":21,"title":"Miranda do Douro: <em>bien benidos al reino marabilhoso</em>","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2074222?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1081,"nome":"Patrícia Carvalho","descricao":"Nasci no Porto, fiz a licenciatura em Ciências da Comunicação na Universidade Nova de Lisboa, entre 1993 e 1997, e estagiei no Jornal do Letras. Apesar da insistência de chefes e colegas para ficar pela capital, preferi voltar a casa e estive com a equipa que abriu o 24horas no Porto. Saí ao fim de um ano, para O Comércio do Porto, onde fiquei até ao seu encerramento, em 2005. Antes de ingressar no PÚBLICO, em 2008, colaborei com várias publicações, incluindo a Grande Reportagem, Visão, Notícias de Sábado e Sábado. No PÚBLICO, integro, desde a minha chegada, a equipa do Local Porto, mas fui sempre participando em outras áreas do jornal, com trabalhos para o P2 ou a Pública (que, entretanto, terminaram), a Fugas ou, mais recentemente, a revista 2.","email":"patricia.carvalho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"patricia-carvalho","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Patricia Carvalho.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1381570?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#108;&#97;&#118;&#114;&#97;&#99;&#46;&#97;&#105;&#99;&#105;&#114;&#116;&#97;&#112;","contribuicao":"texto","tipo":"INTERNO"},{"id":3966,"nome":"Adriano Miranda","descricao":"Nasci em Aveiro, em 1966, estudei na Escola Secundária José Estevão em Aveiro e depois rumei ao Porto para estudar na Cooperativa Árvore. Fiz a minha especialização em Fotografia no AR.CO em Lisboa.  Em 1994 ingressei no PÚBLICO como Fotojornalista. Fui Editor de Fotografia durante 4 anos e agora estou na redacção do Porto. O PÚBLICO é a minha segunda casa. Com orgulho! \r\n´","email":"amiranda@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"adriano-miranda","imagem":{"w":null,"h":null,"largura":216,"altura":216,"nome":"1044361-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1889075?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Augusto Santos Silva","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#100;&#110;&#97;&#114;&#105;&#109;&#97;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"Ele é escarpas, miradouros, rapinas, pauliteiros, posta, navalhas, bola doce, burros e capas d’honra. E é também, claro, o mirandês que aqui dá as boas-vindas ao reino maravilhoso de Miranda do Douro.","url":"/2026/03/28/fugas/noticia/miranda-douro-bien-benidos-al-reino-marabilhoso-2167910","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Miranda do Douro","url":"https://www.publico.pt/2026/03/28/fugas/noticia/miranda-douro-bien-benidos-al-reino-marabilhoso-2167910"},"id":2167910,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"VSR: risco acrescido para adultos mais velhos e pessoas com doenças crónicas","isPremium":false,"image":"https://imagens.publi