ull,"url":null,"localizacao":"","profissaoActual":"Jornalista estagiário","profissaoNaAltura":"Jornalista estagiário","slug":"bartolomeu-marcal-grilo","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#108;&#105;&#114;&#103;&#46;&#117;&#101;&#109;&#111;&#108;&#111;&#116;&#114;&#97;&#98;","contribuicao":"texto","tipo":"INTERNO"},{"id":3920,"nome":"Daniel Rocha","descricao":"","email":"drocha@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"daniel-rocha","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Daniel_Rocha.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737766?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#104;&#99;&#111;&#114;&#100;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"Na Praça das Flores, nasceu Lisboa na sua versão mais moderna, onde os habitantes que resistem acolhem os recém-chegados, do francês ao indiano. E ali nasceu um minimundo em plena cidade.","url":"/2026/06/28/local/noticia/praca-flores-retrato-bairro-cosmopolita-2162505","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Lisboa","url":"https://www.publico.pt/2026/06/28/local/noticia/praca-flores-retrato-bairro-cosmopolita-2162505"},"id":2162505,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":28,"title":"Anselmo Braamcamp: atenção ao novo quarteirão cultural do Porto","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2097478?tp=UH&db=IMAGENS&type=JPG","author":[{"id":13993,"nome":"Ana Isabel Pereira","descricao":"Comecei o meu percurso profissional no extinto \"O Comércio do Porto\". A cidade é uma inquietação desde então. Desde antes, muito provavelmente. Passei por vários órgãos de comunicação social, como freelancer, trabalhei quase sempre sobre e a partir da cidade do Porto, fui co-fundadora de um jornal digital local, o Porto24. E nos últimos anos trabalhei em Multimédia e em gestão de projectos. Cheguei ao PÚBLICO no final de 2020 para lançar e ajudar a produzir um projecto de live streaming, o Ao Vivo. A cidade e as cidades em geral são constante motivo de reflexão, tento contribuir para a sua problematização nas \"Conversas Urbanas\". Outro bichinho que trago de experiências anteriores são os vinhos, que agora volto a acompanhar na Fugas.","email":"ana.pereira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"ana-isabel-pereira","imagem":{"w":null,"h":null,"largura":1059,"altura":1059,"nome":"AIP-junho2021-quadrado.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1597168?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#101;&#112;&#46;&#97;&#110;&#97;","contribuicao":"texto","tipo":"INTERNO"},{"id":3620,"nome":"Manuel Roberto","descricao":"","email":"manuel.roberto@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"Fotojornalista","slug":"manuel-roberto","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Manuel Roberto.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1059727?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#116;&#114;&#101;&#98;&#111;&#114;&#46;&#108;&#101;&#117;&#110;&#97;&#109;","contribuicao":"","tipo":"INTERNO"},{"id":3977,"nome":"Paulo Pimenta","descricao":"","email":"paulo.pimenta@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"Fotojornalista","slug":"paulo-pimenta","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#116;&#110;&#101;&#109;&#105;&#112;&#46;&#111;&#108;&#117;&#97;&#112;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"Na zona alta do Bonfim, parece à primeira vista uma rua pacata, de interior de quarteirão. E, sim, a Anselmo Braamcamp é sossegada, mas esconde um fervilhar cultural que vale a pena conhecer melhor.","url":"/2026/06/27/fugas/reportagem/anselmo-braamcamp-atencao-novo-quarteirao-cultural-porto-2179037","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Reportagem","url":"/roteiros"},"id":2179037,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":1015,"nome":"ROTEIROS","slug":"roteiros","tagEn":"","isPrincipal":false,"isVisible":false,"urlRoute":"/troteiros","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAberto":false,"follow_type":null,"descricao":null,"imagem":null,"html":null,"isForForuns":false,"isUsedInForuns":false},"size":30},{"pos":29,"title":"Julho é mês de François Truffaut, um extremista discreto","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2097918?tp=UH&db=IMAGENS&type=JPG","author":[{"id":885,"nome":"Vasco Câmara","descricao":"Foi depois de ter entrado pela casa que Gloria Swanson teve em Sintra, onde vi junto à piscina um animal empalhado, que me deixaram, aqui no PÚBLICO, meter as mãos no cinema. Isto foi no início deste projecto jornalístico. Eu fui um dos 25 estagiários admitidos depois de um curso de meses que começou com 500 candidatos de todo o país. Após a história da estrela dos anos 20 que vinha descansar perto da praia das Maçãs, alguém me disse: “Faça as malas, amanhã vai para Cannes”. E foi, no ano do fósforo a arder no ecrã gigante do Palais des Festivals, o ano de “Wild at Heart” de Lynch. Se não fossem os filmes não saberia o que estaria a fazer aqui – e isso é verdade para o bigger picture: sem os filmes não saberia o que fazer.","email":"vasco.camara@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"vasco-camara","imagem":{"w":null,"h":null,"largura":216,"altura":216,"nome":"vasco-camara-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1747423?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Cannes","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#97;&#109;&#97;&#99;&#46;&#111;&#99;&#115;&#97;&#118;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"A retrospectiva <em>Ao Sol da Nouvelle Vague</em> que arranca dia 1 no Trindade, no Porto, e no Nimas, em Lisboa, pode ser uma (re)descoberta e baralhar a opinião sobre um cineasta “burguês” e “consensual”.","url":"/2026/06/28/culturaipsilon/noticia/julho-mes-francois-truffaut-extremista-discreto-2179341","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Cinema","url":"https://www.publico.pt/2026/06/28/culturaipsilon/noticia/julho-mes-francois-truffaut-extremista-discreto-2179341"},"id":2179341,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30}]
