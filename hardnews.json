s.aspx/1172095?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#103;&#114;&#111;&#98;&#46;&#97;&#110;&#97;&#105;&#108;&#105;&#108;","contribuicao":"","tipo":"INTERNO"},{"id":3520,"nome":"David Santiago","descricao":"","email":"david.santiago@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editor de Política","profissaoNaAltura":"","slug":"david-santiago","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"David Santiago.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1765612?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#103;&#97;&#105;&#116;&#110;&#97;&#115;&#46;&#100;&#105;&#118;&#97;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Além de Luís Neves, tomaram posse os três secretários de Estado que são reconduzidos. Novo ministro justifica transição para o Governo por ter sentido um “apelo”.","url":"/2026/02/23/politica/noticia/luis-neves-tomou-posse-ministro-administracao-interna-reservas-pj-2165677","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Ministro da Administração Interna","url":"https://www.publico.pt/2026/02/23/politica/noticia/luis-neves-tomou-posse-ministro-administracao-interna-reservas-pj-2165677"},"id":2165677,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":28,"title":"Parceiros sociais ainda longe de acordo, mas mais próximos sobre a parentalidade","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2069146?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3150,"nome":"Raquel Martins","descricao":"Aos 15 anos decidi que queria mudar o mundo e, para desgosto da minha professora de Português, quis ser jornalista. Fiz o curso de Ciências da Comunicação na Universidade Nova, frequentei o Cenjor e andei indecisa entre a rádio e a imprensa. Depois de uma breve passagem pela rádio (Antena 3 e Rádio Expo), acabei por entrar no jornalismo económico um pouco por acaso. Primeiro, no Diário Económico – onde escrevi sobre ambiente, autarquias, política e, mais tarde, sobre trabalho e função pública – depois no Jornal de Negócios. Foi por isso que, em 2009, fiz uma formação na Universidade Católica sobre legislação laboral. Estou no PÚBLICO desde 2010. Acompanho os assuntos relacionados com trabalho, emprego e administração pública (há quem diga, com humor, que o Código do Trabalho é o meu livro de cabeceira.) Defendo que o jornalismo tem um papel cada vez mais importante na descodificação da avalanche de informação que todos os dias circula nas mais diversas plataformas.","email":"raquel.martins@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"raquel-martins","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"raquel-martins-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1991256?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Debi Thomas","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#110;&#105;&#116;&#114;&#97;&#109;&#46;&#108;&#101;&#117;&#113;&#97;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Governo convocou uma reunião da concertação social para 3 de Março. Até lá, vão continuar as reuniões técnicas. Governo garante que continua a fazer “um investimento” num acordo.","url":"/2026/02/23/economia/noticia/parceiros-sociais-longe-acordo-aproxima%C3%A7%C3%B5es-t%C3%A9cnicas-parentalidade-2165709","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Legislação laboral","url":"https://www.publico.pt/2026/02/23/economia/noticia/parceiros-sociais-longe-acordo-aproxima%C3%A7%C3%B5es-t%C3%A9cnicas-parentalidade-2165709"},"id":2165709,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":29,"title":"Rui Moreira escapa a limite de idade por ser embaixador na OCDE a t&iacute;tulo excepcional\r\n","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2069099?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3898,"nome":"Liliana Borges","descricao":"","email":"liliana.borges@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"liliana-pascoal-borges","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"liliana-borges.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1172095?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#103;&#114;&#111;&#98;&#46;&#97;&#110;&#97;&#105;&#108;&#105;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Manuel Lobo Antunes deixa o cargo por ter ultrapassado o limite de idade. Rui Moreira, apesar de ser mais velho, n&atilde;o est&aacute; sujeito a essa limita&ccedil;&atilde;o por se tratar de uma nomea&ccedil;&atilde;o a t&iacute;tulo excepcional.\r\n","url":"/2026/02/23/politica/noticia/rui-moreira-escapa-limite-idade-embaixador-ocde-t%C3%ADtulo-excepcional-2165679","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"OCDE","url":"https://www.publico.pt/2026/02/23/politica/noticia/rui-moreira-escapa-limite-idade-embaixador-ocde-t%C3%ADtulo-excepcional-2165679"},"id":