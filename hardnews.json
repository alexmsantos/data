/16/politica/noticia/ps-pede-novo-adiamento-eleicoes-orgaos-externos-parlamento-2168069","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Assembleia da República","url":"https://www.publico.pt/2026/03/16/politica/noticia/ps-pede-novo-adiamento-eleicoes-orgaos-externos-parlamento-2168069"},"id":2168069,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":15,"title":"Deve a velocidade máxima mudar em certas vias de Lisboa? Câmara admite avaliar","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2073984?tp=UH&db=IMAGENS&type=JPG","author":[{"id":217,"nome":"Samuel Alemão","descricao":"","email":"smalemao@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"samuel-alemao","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Samuel Alemao.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1990666?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#97;&#109;&#101;&#108;&#97;&#109;&#115;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Reconhecendo “relevância para a segurança rodoviária e para a gestão da mobilidade”, autarquia pondera fazer estudo recomendado pela assembleia municipal. Em algumas vias poderá aumentar velocidade.","url":"/2026/03/16/local/noticia/velocidade-maxima-mudar-certas-vias-lisboa-camara-admite-avaliacao-2167850","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Segurança Rodoviária","url":"https://www.publico.pt/2026/03/16/local/noticia/velocidade-maxima-mudar-certas-vias-lisboa-camara-admite-avaliacao-2167850"},"id":2167850,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},