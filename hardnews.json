ments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Livros","url":"https://www.publico.pt/2026/06/25/culturaipsilon/noticia/arranque-atribulado-festival-babell-leva-organizacao-arranjar-sessao-especial-2179476"},"id":2179476,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":12,"title":"CP opera com autocarros e táxis em linhas onde os comboios podem circular","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098177?tp=UH&db=IMAGENS&type=JPG","author":[{"id":366,"nome":"Carlos Cipriano","descricao":"","email":"carlos.cipriano@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"carlos-cipriano","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#97;&#105;&#114;&#112;&#105;&#99;&#46;&#115;&#111;&#108;&#114;&#97;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Empresa opera com autocarros e táxis em 178 quilómetros de vias férreas que estão operacionais e onde os seus comboios podem circular.","url":"/2026/06/25/local/noticia/cp-opera-autocarros-taxis-linhas-onde-comboios-podem-circular-2179015","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Comboios","url":"https://www.publico.pt/2026/06/25/local/noticia/cp-opera-autocarros-taxis-linhas-onde-comboios-podem-circular-2179015"},"id":2179015,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":13,"title":"Poupar mais de 600 euros por ano? É possível","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2091934?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"O Continente, a Galp e a NOS juntaram-se para criar o maior programa de poupança do país. Conheça as vantagens para as suas compras e abastecimentos do dia-a-dia – e saiba como aderir.","url":"/2026/06/19/estudiop/noticia/poupar-600-euros-ano-possivel-2176370","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Continente","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1064970?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/19/estudiop/noticia/poupar-600-euros-ano-possivel-2176370"},"id":2176370,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":14,"title":"António José Seguro encontra-se com Macron a 1 de Julho em Paris","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098221?tp=UH&db=IMAGENS&type=JPG","author":[{"id":157,"nome":"Maria Lopes","descricao":"Entrei para o PÚBLICO, vinda da universidade, quando se vivia a excitação das vésperas da primeira Exposição Mundial em Portugal. Calcorreei a Expo-98 de fio a pavio, de caderno, caneta e, por vezes, de Polaroid na mão. Esses poucos meses ensinaram-me a conjugar o verbo tão português “desenrascar-se”.\r\nNestes mais de 20 anos, passei depois pelas secções Local, Media (por duas vezes) e Economia. Estive no lançamento do suplemento Digital – que apesar do nome existiu apenas em papel – e pertenci à equipa do irreverente projecto Sexta, o jornal gratuito que o PÚBLICO partilhou com A Bola, em 2007 e 2008. Em simultâneo, durante dez anos, escrevi também para o Motores (da Fugas), vivendo os automóveis sob uma perspectiva menos técnica e mais prazenteira. Desde 2009 que integro a secção de Política e tento manter debaixo de olho o panorama dos media. \r\n\r\n","email":"maria.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"maria-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Maria_C_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737865?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#97;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Primeira viagem do Presidente da República a França não incluirá encontro com a comunidade lusa. Antes, passa por Barcelona para o prémio da União Internacional dos Arquitectos a Souto Moura.","url":"/2026/06/25/politica/noticia/antonio-jose-seguro-encontrase-macron-1-julho-paris-2179499","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Presidente da República","url":"https://www.publico.pt/2026/06/25/politica/noticia/antonio-jose-seguro-encontrase-macron-1-julho-paris-2179499"},"id":2179499,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":15,"title":"Incentivo fiscal do CDS à natalidade é “insuficiente”, mas chegou para passar","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098241?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3898,"nome":"Liliana Borges","descricao":"","email":"liliana.borges@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"liliana-pascoal-borges","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"liliana-borges.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1172095?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#103;&#114;&#111;&#98;&#46;&#97;&#110;&#97;&#105;&#108;&#105;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Medida do CDS-PP para reforçar incentivos fiscais à natalidade foi aprovada no Parlamento com apoio alargado, apesar de críticas generalizadas de insuficiência da proposta.","url":"/2026/06/25/politica/noticia/incentivo-fiscal-natalidade-proposto-cds-insuficiente-chegou-passar-2179514","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Parlamento","url":"https://www.publico.pt/2026/06/25/politica/noticia/incentivo-fiscal-natalidade-proposto-cds-insuficiente-chegou-passar-2179514"},"id":2179514,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":16,"title":"Festival Art Explora chegou a Cascais","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2097367?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"O festival itinerante francês instalou-se na Marina de Cascais até dia 28 de Junho, com entrada gratuita.","url":"/2026/06/23/estudiop/noticia/festival-art-explora-chegou-cascais-2179093","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Festival Art Explora","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2097407?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/23/estudiop/noticia/festival-art-explora-chegou-cascais-2179093"},"id":2179093,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":17,"title":"David Clayton-Thomas (1941-2026), a voz imponente dos Blood, Sweat & Tears","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098223?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1034,"nome":"Mário Lopes","descricao":"A culpa é de um gira-discos e dos discos que o meu pai rodava no gira-discos. A música chegou primeiro. Como com a maioria dos adolescentes, a música moldou-me gostos e atitudes, os discos foram guias para a descoberta do mundo. Através deles, cheguei a livros, a cinema, a nomes e mais nomes e a outros discos, outros livros, outros filmes. Foi pela música que cheguei ao jornalismo. Primeiro no Blitz, onde entrei estagiário no final do curso de Ciências da Comunicação e que seria, posteriormente, a casa do meu primeiro emprego. Depois no Diário de Notícias, onde a música começou a significar mais jornalismo, aberto a mais que bandas e discos. Ao PÚBLICO cheguei em 2005. Para escrever maioritariamente sobre música. Para, através da música, chegar a outros universos da cultura. E para, através da cultura, tentar compreender melhor o mundo e, escrevendo sobre ela, tentar mostrá-lo o mais claramente possível. A adolescência já lá vai há muito. Discos, livros, filmes, continuam a ser guias de descoberta. Assim sendo, continuarei.","email":"mario.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"mario-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Mario_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/860961?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#111;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Dono de uma voz crua e poderosa como a dos bluesmen e soulmen que tinha por referência, marcou os anos 1970 à frente de uma banda que reunia rock, blues, jazz e r&b. Tinha 84 anos.","url":"/2026/06/25/culturaipsilon/noticia/david-claytonthomas-19412026-voz-imponente-blood-sweat-tears-2179498","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Música","url":"https://www.publico.pt/2026/06/25/culturaipsilon/noticia/david-claytonthomas-19412026-voz-imponente-blood-sweat-tears-2179498"},"id":2179498,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":18,"title":"Portugal vai ter “procura enorme” de energia, antevê a EDP","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098128?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19360,"nome":"Diogo Cavaleiro","descricao":"Estagiei no PÚBLICO em 2009 no Local Lisboa, tendo no ano seguinte entrado no <em>Jornal de Negócios</em>, onde fiquei por quase nove anos. O sector bancário foi aquele em que me especializei, tendo publicado um livro – <em>Caixa Negra</em> – sobre décadas de gestão e polémica na Caixa Geral de Depósitos, em 2017. Em 2019, segui para o <em>Expresso</em>, continuando na mesma área, onde fiquei até Maio de 2025. Regresso agora ao PÚBLICO para continuar esse trabalho, integrando a secção de Economia. Licenciado em Ciências da Comunicação, tenho pós-graduações em Ciência Política – Relações Internacionais, na vertente de Estudos Europeus, e em Compliance.","email":"diogo.cavaleiro@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"diogo-cavaleiro","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Diogo Cavaleiro.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/2051033?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#114;&#105;&#101;&#108;&#97;&#118;&#97;&#99;&#46;&#111;&#103;&#111;&#105;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Aos 50 anos da EDP, presidente acredita que centros de dados e renováveis vão sustentar futuro. Garante que a eléctrica tem sabido adaptar-se às mudanças e que compras de empresas são sempre hipótese.","url":"/2026/06/25/economia/noticia/portugal-vai-procura-enorme-energia-gracas-centro-dados-anteve-edp-2179453","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"EDP","url":"https://www.publico.pt/2026/06/25/economia/noticia/portugal-vai-procura-enorme-energia-gracas-centro-dados-anteve-edp-2179453"},"id":2179453,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":19,"title":"Festival MED: música, arte e gastronomia para dar a volta ao mundo em Loulé","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2097541?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Sérgio Godinho estreia-se no evento que entre 25 e 28 de Junho dá vida ao centro histórico da cidade algarvia, com street food, arte nas ruas e muitas experiências culturais.","url":"/2026/06/23/estudiop/noticia/festival-med-musica-arte-gastronomia-dar-volta-mundo-loule-2179163","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Festival MED","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2097524?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/23/estudiop/noticia/festival-med-musica-arte-gastronomia-dar-volta-mundo-loule-2179163"},"id":2179163,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":20,"title":"Crise de <em>chips </em>faz disparar os preços dos MacBook e iPad","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098188?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19739,"nome":"Laura Ferreira","descricao":"","email":"laura.ferreira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"laura-ferreira","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#114;&#101;&#102;&#46;&#97;&#114;&#117;&#97;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"As subidas chegam aos 400 euros em alguns modelos. Os aumentos atingem toda a gama de iPads e MacBooks, com os portáteis profissionais entre os mais afectados.","url":"/2026/06/25/enter/noticia/crise-chips-faz-disparar-precos-macbook-ipad-2179450","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Apple","url":"https://www.publico.pt/2026/06/25/enter/noticia/crise-chips-faz-disparar-precos-macbook-ipad-2179450"},"id":2179450,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":21,"title":"José Castelo Branco em silêncio no arranque do julgamento que só retoma em Setembro","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098225?tp=UH&db=IMAGENS&type=JPG","author":[{"id":18338,"nome":"Rita Caetano","descricao":"","email":"rscaetano@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"rita-caetano","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#97;&#116;&#101;&#97;&#99;&#115;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Nem Castelo Branco nem Betty Grafstein prestaram declarações na primeira sessão de julgamento. A advogada de defesa quer que as próximas audiências sejam à porta fechada, para preservar “a dignidade”.","url":"/2026/06/25/impar/noticia/violencia-domestica-jose-castelo-branco-silencio-arranque-julgamento-so-retoma-setembro-2179484","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"Pessoas","url":"https://www.publico.pt/2026/06/25/impar/noticia/violencia-domestica-jose-castelo-branco-silencio-arranque-julgamento-so-retoma-setembro-2179484"},"id":2179484,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"Quer mudar de carreira? A solução pode estar numa destas profissões","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2097783?tp=UH&db=IMAGENS&type=PNG","author":[],"shares":0,"description":"As profissões técnicas estão a voltar a ganhar destaque, mas faltam profissionais certificados. Se está a pensar enveredar por uma destas profissões, saiba como a Master D o pode ajudar.","url":"/2026/06/25/estudiop/noticia/quer-mudar-carreira-solucao-estar-profissoes-2179268","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Master D","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2097811?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/25/estudiop/noticia/quer-mudar-carreira-solucao-estar-profissoes-2179268"},"id":2179268,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":23,"title":"Mundial 2026: a melhor versão do México vê-se dentro de casa","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098184?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1059,"nome":"Nuno Sousa","descricao":"Primeiro, foi a informação local. Em Aveiro, durante um ano (o de 2003), ajudei a levantar um dos quatro cadernos regionais que o PÚBLICO chegou a oferecer aos leitores, antes de me tornar editor do entretanto extinto Local Centro. A viagem para norte foi relativamente rápida e, em 2005, assumi a editoria do Local Porto, da qual me despediria no final de 2007, para ocupar o cargo que actualmente desempenho, na chefia da secção de Desporto. Desde então, tenho olhado para a actualidade desportiva com a avidez e o interesse do dia de estreia. E acompanhado o relançamento do site de Desporto, a criação de canais dedicados (Jogos Olímpicos, Europeu, Mundial de futebol) e a edição de suplementos em papel com a mesma lupa que uso para aperfeiçoar o jornal que todos os dias sai para as bancas.","email":"nsousa@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editor de Desporto","profissaoNaAltura":"Editor de Desporto",