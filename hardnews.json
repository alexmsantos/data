tag":null,"size":30},{"pos":15,"title":"Operações de Páscoa da PSP e GNR registam 13 mortos e perto de dois mil acidentes","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2079326?tp=UH&db=IMAGENS&type=JPG","author":[{"id":90,"nome":"Lusa","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"lusa","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"AGENCIA"}],"shares":0,"description":"Quatro pessoas de nacionalidade alemã da mesma família morreram na sexta-feira no IC1","url":"/2026/04/04/sociedade/noticia/operacoes-pascoa-psp-gnr-registam-13-mortos-perto-dois-mil-acidentes-2170219","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Segurança Rodoviária","url":"https://www.publico.pt/2026/04/04/sociedade/noticia/operacoes-pascoa-psp-gnr-registam-13-mortos-perto-dois-mil-acidentes-2170219"},"id":2170219,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":16,"title":"Dados que geram soluções: E-REDES desafia estudantes para a transição energética","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2078147?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"A 7 de Abril, os melhores projectos de mestrado nesta área vão ser reconhecidos na entrega dos prémios Open Data Academy Challenge","url":"/2026/03/31/estudiop/noticia/dados-geram-solucoes-eredes-desafia-estudantes-transicao-energetica-2169729","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"E-REDES","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1584526?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/03/31/estudiop/noticia/dados-geram-solucoes-eredes-desafia-estudantes-transicao-energetica-2169729"},"id":2169729,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":17,"title":"Belo Horizonte A pé, com J.K. e Oscar Niemeyer","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2077151?tp=UH&db=IMAGENS&type=JPG","author":[{"id":124,"nome":"Amílcar Correia","descricao":"Sou redactor principal desde Julho de 2023, escrevo A Coluna Vertebral todas as semanas, coordeno a área dos podcast do jornal e sou um dos autores do podcast P24. Entre Agosto de 2018 e Maio de 2023 fui director adjunto e responsável pelo PÚBLICO online. Antes disso, fui estagiário, jornalista, editor de várias secções, editor de novos projectos, editor executivo e subdirector em várias direcções. Criei e dirigi o P3, de Setembro de 2011 a Outubro de 2016, na sequência de um consórcio constituído pelo PÚBLICO, Faculdade de Engenharia e Reitoria da Universidade do Porto. O P3 recebeu vários prémios, nomeadamente o de Melhor Webdesign da Península Ibérica, na categoria de sites com menos de 12 milhões de visitas mensais, atribuído pela Society for News Design, em 2012. Sou licenciado em Ciências da Comunicação, pela Faculdade de Ciências Sociais e Humanas da Universidade Fernando Pessoa, em 2010, frequentei o curso de Comunicação Social da Escola Superior de Jornalismo do Porto entre 1988 e 1990, e vários cursos de formação do Centro Protocolar de Formação de Jornalistas, em Lisboa. Fui jornalista residente no Knight Center for Journalism in the Americas e no Technology and Information Policy Institute da Universidade do Texas, nos EUA, em 2015. Sou autor de diferentes publicações: “A balada do Níger, lançado em 2007, e \"Da Jugoslávia ao Kosovo, a mais breve história de um conflito\", em 2025. Sou co-autor do artigo “Consumer Attitudes toward News Delivering: An Experimental Evaluation of the Use and Efficacy of Personalized Recommendations”, publicado na revista cientifica Information em Julho de 2020.","email":"acorreia@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Redactor principal","profissaoNaAltura":"Redactor principal","slug":"amilcar-correia","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Amilcar_Correia-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1739387?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#105;&#101;&#114;&#114;&#111;&#99;&#97;","contribuicao":"","tipo":"INTERNO"},{"id":3977,"nome":"Paulo Pimenta","descricao":"","email":"paulo.pimenta@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":", em Belo Horizonte","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"paulo-pimenta","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#116;&#110;&#101;&#109;&#105;&#112;&#46;&#111;&#108;&#117;&#97;&#112;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Belo Horizonte não é um destino turístico. A capital de Minas Gerais, a sexta maior cidade do país, tem uma população de 2,4 milhões e muito a descobrir. A pé, de preferência.","url":"/2026/04/04/fugas/reportagem/belo-horizonte-pe-jk-oscar-niemeyer-2168878","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Reportagem","url":"/brasil"},"id":2168878,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":18,"title":"A <em>Guernica</em> de Picasso volta a ser objecto de disputa entre o País Basco e Madrid","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2079257?tp=UH&db=IMAGENS&type=JPG","author":[{"id":488,"nome":"Lucinda Canelas","descricao":"Quando cheguei aqui, Lisboa estava a preparar-se para a grande exposição dos oceanos e a cidade mudava à beira-rio. Os quatro primeiros meses foram intensos, no recinto da Expo e fora dele, nos festivais que invadiam teatros e auditórios, sempre de Polaroid na mochila. O interesse pela arte, sobretudo a dança, já lá estava, mas pelo caminho foi crescendo e foi mudando. Talvez porque acabei por conversar com coreógrafos que me habituei a admirar nos livros e nos palcos, porque uma reportagem me levou a um sítio arqueológico que eu ainda não conhecia e uma exposição me fez descobrir um fotógrafo, um escritor, um artista ou um historiador de arte com muita coisa para contar sobre os mestres da pintura antiga. Sair em reportagem para caminhar no campo à procura de um mosteiro medieval ou de um castelo nas margens do Guadiana parece-me quase sempre boa ideia.","email":"lcanelas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"lucinda-canelas","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#108;&#101;&#110;&#97;&#99;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Há um novo pedido de empréstimo da célebre pintura que se tornou símbolo dos horrores da Guerra Civil Espanhola. O que dirá agora Pedro Sánchez aos bascos, quando precisa do seu apoio no parlamento?","url":"/2026/04/03/culturaipsilon/noticia/guernica-picasso-volta-objecto-disputa-pais-basco-madrid-2170190","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Artes","url":"https://www.publico.pt/2026/04/03/culturaipsilon/noticia/guernica-picasso-volta-objecto-disputa-pais-basco-madrid-2170190"},"id":2170190,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":19,"title":"As primeiras imagens da missão Ártemis II: a Terra vista do espaço","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2079264?tp=UH&db=IMAGENS&type=JPG","author":[{"id":11076,"nome":"Mariana Durães","descricao":"","email":"mariana.duraes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"mariana-duraes","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#97;&#114;&#117;&#100;&#46;&#97;&#110;&#97;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"A bordo da cápsula Orion, o comandante da missão captou o planeta Terra. “Nenhum de nós conseguiu ir almoçar porque estávamos colados à janela.”","url":"/2026/04/03/ciencia/noticia/primeiras-imagens-missao-artemis-ii-nada-prepara-espectaculo-planeta-2170206","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Espaço","url":"https://www.publico.pt/2026/04/03/ciencia/noticia/primeiras-imagens-missao-artemis-ii-nada-prepara-espectaculo-planeta-2170206"},"id":2170206,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":20,"title":"“Limerência”: “Quando me apaixono, a minha vida é só sobre aquela pessoa”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2078999?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19961,"nome":"Ana Beatriz Ferreira","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"ana-beatriz-ferreira","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O termo tem ganho popularidade nas redes sociais e até entrou no dicionário Priberam em 2024. O que é a “limerência”, que traz ansiedade e comportamentos obsessivos?","url":"/2026/04/04/p3/noticia/limerencia-paixao-obsessiva-apaixono-vida-so-pessoa-2169075","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"p3"},"brand":null,"rubric":{"name":"Psicologia","url":"https://www.publico.pt/2026/04/04/p3/noticia/limerencia-paixao-obsessiva-apaixono-vida-so-pessoa-2169075"},"id":2169075,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":21,"title":"O regresso da Liga, com as decisões à vista","isPremium":false,"image":"","author":[{"id":1059,"nome":"Nuno Sousa","descricao":"Primeiro, foi a informação local. Em Aveiro, durante um ano (o de 2003), ajudei a levantar um dos quatro cadernos regionais que o PÚBLICO chegou a oferecer aos leitores, antes de me tornar editor do entretanto extinto Local Centro. A viagem para norte foi relativamente rápida e, em 2005, assumi a editoria do Local Porto, da qual me despediria no final de 2007, para ocupar o cargo que actualmente desempenho, na chefia da secção de Desporto. Desde então, tenho olhado para a actualidade desportiva com a avidez e o interesse do dia de estreia. E acompanhado o relançamento do site de Desporto, a criação de canais dedicados (Jogos Olímpicos, Europeu, Mundial de futebol) e a edição de suplementos em papel com a mesma lupa que uso para aperfeiçoar o jornal que todos os dias sai para as bancas.","email":"nsousa@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Editor de Desporto","profissaoNaAltura":null,"slug":"nuno-sousa","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"nsousa.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1951120?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Liga Europa da UEFA","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#115;&#117;&#111;&#115;&#110;","contribuicao":null,"tipo":"INTERNO"}],"shares":0,"description":null,"url":"/2026/04/03/newsletter/aquecimento","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Aquecimento","url":""},"id":2170205,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"Em dois anos, 81% dos cibercrimes investigados acabaram arquivados","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2075948?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1050,"nome":"Mariana Oliveira","descricao":"Nasci no Porto em 1978 e fiz a licenciatura em Direito na Faculdade de Direito da Universidade do Porto. Quando optei por este curso, já tinha a intenção de me tornar jornalista, seguindo o conselho de alguns profissionais da classe. Depois de terminar a licenciatura, candidatei-me à Formação Geral – Especialização em Jornalismo no Centro Protocolar de Formação Profissional para Jornalistas (Cenjor), em Lisboa. Por isso vivi na capital quase oito meses, entre Dezembro de 2001 e Julho de 2002. Nesse mês, decidi regressar ao Porto para fazer o estágio integrado nessa formação. Fui jornalista estagiária no PÚBLICO entre Julho e Outubro e comecei a trabalhar em Fevereiro de 2003. No início, cobri mais intensivamente áreas ligadas à protecção civil. Actualmente, dedico-me à área da Justiça.","email":"meoliveira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"mariana-oliveira","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#118;&#105;&#108;&#111;&#101;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Revela relatório do Ministério Público que faz balanço sobre o combate aos crimes de investigação prioritária entre 2023 e 2025. Taxa de acusação dos cibercrimes é a mais baixa de todas.","url":"/2026/04/04/sociedade/noticia/dois-anos-81-cibercrimes-investigados-acabaram-arquivados-2168657","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Justiça","url":"https://www.publico.pt/2026/04/04/sociedade/noticia/dois-anos-81-cibercrimes-investigados-acabaram-arquivados-2168657"},"id":2168657,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":23,"title":"Vasco Cardoso: “Governo só discute se trabalhadores perdem muitos direitos ou todos”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2078186?tp=UH&db=IMAGENS&type=JPG","author":[{"id":15507,"nome":"Ana Bacelar Begonha","descricao":"","email":"ana.begonha@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"ana-bacelar-begonha","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#104;&#110;&#111;&#103;&#101;&#98;&#46;&#97;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Dirigente do PCP critica PS por ter feito “compromissos reformistas” com o Governo no último congresso. Presidente deve vetar pacote laboral porque jurou “cumprir e fazer cumprir a Constituição”.","url":"/2026/04/04/politica/entrevista/vasco-cardoso-governo-so-discute-trabalhadores-perdem-direitos-nao-negociacao-2169765","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista","url":"/legislacao-laboral"},"id":2169765,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":24,"title":"Das 101 mortes por consumo de droga em Portugal em 2023, dez foram nos Açores","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2077740?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1041,"nome":"Ana Dias Cordeiro","descricao":"Os anos que passei fora de Portugal influenciaram aquilo que sou como jornalista. Vivi em Londres, onde fiz uma pós-graduação em Jornalismo Internacional, colaborei no Serviço Mundial da BBC e fui freelancer para o PÚBLICO, depois de ter concluído uma Licenciatura em Economia e de ter trabalhado nos primeiros tempos de vida da revista Visão. Nos quatro anos que depois passei em Paris, fui repórter e produtora das emissões em português para África, na Rádio França Internacional (RFI), e continuei a escrever para o PÚBLICO, onde estou (em Lisboa) desde 2002. Nos vários lugares por onde passei, aprendi com os colegas, editores e directores e com as histórias de pessoas que encontrei em reportagens dentro ou fora de Portugal (Angola, Moçambique, Guiné-Bissau, São Tomé e Príncipe, Paris nas eleições de 2007 ou Nova Iorque em Setembro de 2001). O gosto pela reportagem e pela escrita levaram-me a ser redactora do Mundo e da Cultura, sem deixar de me aventurar por outros temas. Estou na equipa do online e penso que, enquanto gostar de escrever, gostarei de ser jornalista.","email":"acordeiro@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ana-dias-cordeiro","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#114;&#105;&#101;&#100;&#114;&#111;&#99;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Tribunal de Contas aponta “fragilidades estruturais” na política da região para o combate à toxicodependência. Falta uma rede integrada de cuidados antes e depois da desabituação para evitar recaídas.","url":"/2026/04/04/sociedade/noticia/101-mortes-consumo-droga-portugal-2023-dez-acores-2169519","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Saúde","url":"https://www.publico.pt/2026/04/04/sociedade/noticia/101-mortes-consumo-droga-portugal-2023-dez-acores-2169519"},"id":2169519,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":25,"title":"“Sem partidarite”, PS avança para que governação da Lusa seja igual à da RTP","isPremium":true,"i