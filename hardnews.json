[{"pos":0,"title":"Drone russo atinge prédio residencial na Roménia, NATO “pronta para defender” aliado","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2091845?tp=UH&db=IMAGENS&type=JPG","author":[{"id":5355,"nome":"António Saraiva Lima","descricao":"Pertenço a uma geração indefinida e vesti a camisola como poucos. Experimentei Direito, viajei e desviei-me. Pelo meio, escrevi. Licenciei-me em Ciência Política e Relações Internacionais, andei a debater sobre a Europa num <i>think tank</i>, e estagiei numa afamada organização internacional. Continuei a escrever. Tropecei no jornalismo em 2015, e logo no PÚBLICO, para um estágio na inigualável secção Mundo. Três meses de instrução diária, com os melhores dos melhores, que se alongaram para cinco. Sempre a escrever, mas também a perguntar e a ouvir. Ainda testei o ofício diplomático-consular, em Inglaterra, apenas para confirmar que a indefinição que me corria no sangue estava afinal fora de prazo. Voltei para Lisboa, realistei-me no jornalismo, pela mão do <i>i</i> e do <i>Sol</i>, e terminei um mestrado em Estudos Europeus. Permanentemente a escrever. No início de 2018 voltei à casa de partida – precisamente no meio do tabuleiro e deste texto.","email":"antonio.lima@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"antonio-saraiva-lima","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Antonio Saraiva Lima.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1527215?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":",Norges teknisk-naturvitenskaplige universitet","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#109;&#105;&#108;&#46;&#111;&#105;&#110;&#111;&#116;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"descripti