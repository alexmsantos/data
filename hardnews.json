[{"pos":0,"title":"Seguro defende que “transparência dos donativos políticos [a partidos] é essencial”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2084061?tp=UH&db=IMAGENS&type=JPG","author":[{"id":15507,"nome":"Ana Bacelar Begonha","descricao":"","email":"ana.begonha@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"ana-bacelar-begonha","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#104;&#110;&#111;&#103;&#101;&#98;&#46;&#97;&#110;&#97;","contribuicao":"","tipo":"INTERNO"},{"id":19357,"nome":"Filipe Santa-Bárbara","descricao":"","email":"filipe.santabarbara@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"filipe-santabarbara","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#97;&#98;&#114;&#97;&#98;&#97;&#116;&#110;&#97;&#115;&#46;&#101;&#112;&#105;&#108;&#105;&#102;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O Parlamento assinala neste sábado o 52.º aniversário do 25 de Abril. António José Seguro discursa na sessão solene pela primeira vez como Presidente da República.","url":"/2026/04/25/politica/noticia/seguro-discursa-presidente-primeira-25-abril-2172483","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"25 de Abril","url":"https://www.publico.pt/2026/04/25/politica/noticia/seguro-discursa-presidente-primeira-25-abril-2172483"},"id":2172483,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":1,"title":"Natureza sem pressa: pausa revigorante a uma hora de Lisboa","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2082100?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Uma escapadinha na natureza a uma hora de Lisboa","url":"/2026/04/17/estudiop/noticia/natureza-pressa-pausa-revigorante-hora-lisboa-2171598","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Huttopia","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2082090?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/04/17/estudiop/noticia/natureza-pressa-pausa-revigorante-hora-lisboa-2171598"},"id":2171598,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":2,"title":"Paquistão emerge como protagonista na ordem multipolar acelerada pela guerra EUA-Irão","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2083624?tp=UH&db=IMAGENS&type=JPG","author":[{"id":5355,"nome":"António Saraiva Lima","descricao":"Pertenço a uma geração indefinida e vesti a camisola como poucos. Experimentei Direito, viajei e desviei-me. Pelo meio, escrevi. Licenciei-me em Ciência Política e Relações Internacionais, andei a debater sobre a Europa num <i>think tank</i>, e estagiei numa afamada organização internacional. Continuei a escrever. Tropecei no jornalismo em 2015, e logo no PÚBLICO, para um estágio na inigualável secção Mundo. Três meses de instrução diária, com os melhores dos melhores, que se alongaram para cinco. Sempre a escrever, mas também a perguntar e a ouvir. Ainda testei o ofício diplomático-consular, em Inglaterra, apenas para confirmar que a indefinição que me corria no sangue estava afinal fora de prazo. Voltei para Lisboa, realistei-me no jornalismo, pela mão do <i>i</i> e do <i>Sol</i>, e terminei um mestrado em Estudos Europeus. Permanentemente a escrever. No início de 2018 voltei à casa de partida – precisamente no meio do tabuleiro e deste texto.","email":"antonio.lima@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"antonio-saraiva-lima","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Antonio Saraiva Lima.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1527215?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":",Norges teknisk-naturvitenskaplige universitet","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#109;&#105;&#108;&#46;&#111;&#105;&#110;&#111;&#116;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Com muito a perder se conflito se arrastar e alastrar pelo Médio Oriente, vizinho do Irão aproveita boas relações com as grandes potências para assumir papel de mediador entre Washington e Teerão.","url":"/2026/04/25/mundo/noticia/paquistao-emerge-protagonista-ordem-multipolar-acelerada-guerra-euairao-2172339","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Médio Oriente","url":"https://www.publico.pt/2026/04/25/mundo/noticia/paquistao-emerge-protagonista-ordem-multipolar-acelerada-guerra-euairao-2172339"},"id":2172339,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"Trump quer incluir pelotão de fuzilamento nos métodos de execução federais","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2084066?tp=UH&db=IMAGENS&type=JPG","author":[{"id":11829,"nome":"Mark Berman","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"mark-berman","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Administração Trump quer alargar métodos de execução federais, incluindo pelotões de fuzilamento e cadeiras elétricas, revertendo políticas da era Biden sobre a pena de morte.","url":"/2026/04/25/mundo/noticia/administracao-trump-quer-incluir-pelotao-fuzilamento-cadeiras-electricas-metodos-execucao-federais-2172538","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Estados Unidos","url":"https://www.publico.pt/2026/04/25/mundo/noticia/administracao-trump-quer-incluir-pelotao-fuzilamento-cadeiras-electricas-metodos-execucao-federais-2172538"},"id":2172538,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"Grupos armados lançam “ataques coordenados” na capital do Mali","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2084041?tp=UH&db=IMAGENS&type=JPG","author":[{"id":12789,"nome":"Ivo Neto","descricao":"Cheguei ao jornalismo com idade para ter juízo. Foi em 2016, aos 28 anos. Comecei no JN, na imponente torre da Gonçalo Cristóvão, no coração do Porto, como Gestor de Redes Sociais, passando depois para a equipa do Online. Em 2020, semanas antes de o mundo se fechar em casa, entrei para o PÚBLICO para integrar a equipa de editores da secção Online. Sou agora Editor do Mundo. Já escrevi sobre tudo um pouco: Saúde, Ciência, Natureza ou Tecnologia e Desinformação. Mas é de olhar para o Mundo que mais gosto. Pelo meio tirei um doutoramento que me levou a Austin, no Texas. Sou também professor Associado na Universidade da Maia.","email":"ivo.neto@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista e editor na secção Mundo","profissaoNaAltura":"","slug":"ivo-neto","imagem":{"w":null,"h":null,"largura":511,"altura":488,"nome":"2-removebg-preview (1).png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1567262?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Tartan","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#116;&#101;&#110;&#46;&#111;&#118;&#105;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Homens armados atacaram a capital do Mali, Bamaco, e diversos locais em todo o país, informou o Exército maliano, naquilo que parece ser um assalto coordenado envolvendo múltiplos grupos.","url":"/2026/04/25/mundo/noticia/grupos-armados-lancam-ofensiva-coordenada-capital-mali-2172531","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Mali","url":"https://www.publico.pt/2026/04/25/mundo/noticia/grupos-armados-lancam-ofensiva-coordenada-capital-mali-2172531"},"id":2172531,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Aguiar-Branco contra o populismo: \"Fomos aceitando a ideia de que os políticos estão a esconder qualquer coisa\"","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/canal_videos/videoPortal/Images/202604/aguiar_v297843.jpg?tp=VIDEOS","author":[{"id":0,"nome":"ARTV","descricao":null,"email":null,"facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":"","localizacao":null,"profissaoActual":null,"profissaoNaAltura":null,"slug":"artv","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":null,"tipo":"EXTERNO"},{"id":3925,"nome":"Joana Bourgard","descricao":"Sou jornalista desde 2007 e, ao longo destes anos de profissão, é a terceira vez que estou no PÚBLICO. Comecei como estagiária, na secção de Fotografia do jornal. Prossegui fotojornalismo no Jornal de Notícias, no Porto, onde fiquei três anos. Foi nessa altura que apareceram os smartphones e as primeiras máquinas fotográficas digitais com a possibilidade de captar imagem em movimento. Tornei-me jornalista multimédia e regressei para Lisboa para fazer parte da equipa de vídeo do PÚBLICO, em 2010. Passado quatro anos juntei-me à equipa multimédia da Rádio Renascença. Por fim, 15 anos depois do estágio no PÚBLICO, regressei em 2022 para editar a secção de Multimédia. Em 2007 fiz parte fundação da <a href=\"https://wilder.pt\">Wilder.pt</a>, um projecto de jornalismo independente dedicado à natureza e biodiversidade.","email":"joana.bourgard@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Editora de Multimédia","profissaoNaAltura":"Editora de Multimédia","slug":"joana-bourgard","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Joana_Bourgard.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737812?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#100;&#114;&#97;&#103;&#114;&#117;&#111;&#98;&#46;&#97;&#110;&#97;&#111;&#106;","contribuicao":null,"tipo":"INTERNO"}],"shares":0,"description":"<p>O presidente da Assembleia da Rep&uacute;blica foi elogiado por alguns partidos ap&oacute;s a cerim&oacute;nia.</p>\r\n","url":"/2026/04/25/video/aguiarbranco-populismo-aceitando-ideia-politicos-estao-esconder-qualquer-20260425-143702","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Vídeo","url":"/video-"},"id":97843,"type":"VIDEO","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"“A liberdade não desaparece de uma só vez”: leia o discurso do Presidente na íntegra","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2084068?tp=UH&db=IMAGENS&type=JPG","author":[{"id":973,"nome":"PÚBLICO","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"publico","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Intervenção do Presidente da República na sessão solene comemorativa do 52.º aniversário do 25 de Abril de 1974.","url":"/2026/04/25/politica/noticia/liberdade-nao-desaparece-so-desaparece-leia-discurso-presidente-integra-2172544","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"25 de Abril","url":"https://www.publico.pt/2026/04/25/politica/noticia/liberdade-nao-desaparece-so-desaparece-leia-discurso-presidente-integra-2172544"},"id":2172544,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Ataques russos matam sete pessoas e ferem dezenas na Ucrânia. Roménia regista danos","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2084013?tp=UH&db=IMAGENS&type=JPG","author":[{"id":14261,"nome":"Carolina Amado","descricao":"","email":"carolina.amado@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"carolina-amado","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#100;&#97;&#109;&#97;&#46;&#97;&#110;&#105;&#108;&#111;&#114;&#97;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Em Dnipro, no Sudeste da Ucrânia, continuam a decorrer operações de busca nos escombros de um dos edifícios residenciais atingidos. Fragmentos causam, pela primeira vez, danos na Roménia.\r\n","url":"/2026/04/25/mundo/noticia/ataques-russos-matam-quatro-pessoas-ferem-dezenas-ucrania-2172522","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Guerra na Ucrânia","url":"https://www.publico.pt/2026/04/25/mundo/noticia/ataques-russos-matam-quatro-pessoas-ferem-dezenas-ucrania-2172522"},"id":2172522,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"Entrada de ajuda humanitária em Gaza caiu desde o início da guerra com o Irão","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2084062?tp=UH&db=IMAGENS&type=JPG","author":[{"id":973,"n