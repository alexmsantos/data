tps://imagens.publico.pt/imagens.aspx/2097097?tp=UH&db=IMAGENS&type=JPG","author":[{"id":14261,"nome":"Carolina Amado","descricao":"","email":"carolina.amado@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"carolina-amado","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#100;&#97;&#109;&#97;&#46;&#97;&#110;&#105;&#108;&#111;&#114;&#97;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Activista ambiental dedicou-se à protecção das tartarugas marinhas que fazem os ninhos na costa do Líbano durante 25 anos.","url":"/2026/06/21/azul/noticia/mona-khalil-guardia-tartarugas-libano-morta-ataque-israelita-2178951","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Médio Oriente","url":"https://www.publico.pt/2026/06/21/azul/noticia/mona-khalil-guardia-tartarugas-libano-morta-ataque-israelita-2178951"},"id":2178951,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Dois ecrãs num portátil: este é o novo ASUS","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2093935?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"O ASUS Zenbook DUO (2026) junta dois ecrãs OLED num formato surpreendentemente portátil, propondo uma nova forma de trabalhar, criar e organizar ideias em mobilidade.","url":"/2026/06/15/estudiop/noticia/dois-ecras-portatil-novo-asus-2177450","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Asus","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1561864?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/15/estudiop/noticia/dois-ecras-portatil-novo-asus-2177450"},"id":2177450,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"Síndrome dos ovários poliquísticos: “São anos e anos sempre com dores”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2096948?tp=UH&db=IMAGENS&type=PNG","author":[{"id":5669,"nome":"Claudia Carvalho Silva","descricao":"Nasci em Neuchâtel, na Suíça – daí que escreva o meu nome sem acento. Mais tarde, já em Portugal, estive dividida entre as ciências e as letras, num ímpeto constante de querer fazer e aprender tudo ao mesmo tempo. Decidi deixar de lado a certeza de que o coração não tem vontade e estudar Jornalismo na Faculdade de Letras da Universidade de Coimbra. Passei pelo jornal universitário <i>A Cabra</i>, a revista <i>Via Latina</i> e o Festival Caminhos do Cinema Português. E, no final de 2015, cheguei ao PÚBLICO para estagiar na secção Local, onde descobri algumas das histórias que Lisboa tem para contar. Depois de abraçar o desafio online, integrei a equipa fundadora do Azul, o nosso projecto dedicado à crise climática, que editei durante dois anos. Agora, estou no P3. E aprendo todos os dias.","email":"claudia.silva@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"claudia-carvalho-silva","imagem":{"w":null,"h":null,"largura":437,"altura":572,"nome":"CLAUDIACARVALHOSILVA_REDIMENSIONADA-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1440637?tp=UH&db=IMAGENS&type=PNG","is_vertical":true,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#118;&#108;&#105;&#115;&#46;&#97;&#105;&#100;&#117;&#97;&#108;&#99;","contribuicao":"texto","tipo":"INTERNO"},{"id":16232,"nome":"Gabriela Pedro","descricao":"","email":"gabriela.pedro@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista infográfica","profissaoNaAltura":"","slug":"gabriela-pedro","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#114;&#100;&#101;&#112;&#46;&#97;&#108;&#101;&#105;&#114;&#98;&#97;&#103;","contribuicao":"ilustração","tipo":"INTERNO"}],"shares":0,"description":"Dores, “quistos”, ciclos irregulares, acne e dificuldades em engravidar. Os sintomas desta síndrome ainda desconhecida variam muito de mulher para mulher, gerando incerteza e atrasos no diagnóstico.","url":"/2026/06/20/p3/noticia/sindrome-ovarios-poliquisticos-sao-anos-anos-dores-2178891","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"p3"},"brand":null,"rubric":{"name":"Saúde","url":"https://www.publico.pt/2026/06/20/p3/noticia/sindrome-ovarios-poliquisticos-sao-anos-anos-dores-2178891"},"id":2178891,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":9,"title":"A Alemanha resolveu o jogo com a Costa do Marfim com o que tinha no banco","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2097091?tp=UH&db=IMAGENS&type=JPG","author":[{"id":206,"nome":"Marco Vaza","descricao":"O desporto tem vencedores e perdedores, heróis e vilões e a história nem sempre é sobre o que ganha. Eu escrevo sobre aquele que marca o golo decisivo, sobre aquele que corre mais do que os outros, sobre aquele que não desiste ou sobre aquele que desistiu quando estava perto do fim. Já assisti ao vivo a grandes goleadas, recordes do mundo, estreias de futuras estrelas e despedidas de mitos. Entrei no PÚBLICO como estagiário em 1999 para a secção de Desporto, onde continuo, depois de uma comissão entre 2006 e 2009 como editor da revista de domingo. Para além de centenas de jogos de futebol, já estive em duas edições dos Jogos Olímpicos (Atenas 2004 e Londres 2012), numa edição dos Mundiais de atletismo (Helsínquia 2005) e noutras competições de muitas modalidades. O desporto dos outros é a minha profissão.","email":"mvaza@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"marco-vaza","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Marco_Vaza.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737861?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#122;&#97;&#118;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Denis Undav marcou os dois golos do triunfo germânico por 2-1 sobre os marfinenses. “<em>Mannschaft</em>” garantiu presença nos 16 avos-de-final no Mundial 2026.","url":"/2026/06/20/desporto/noticia/alemanha-resolveu-banco-2178950","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Futebol","url":"https://www.publico.pt/2026/06/20/desporto/noticia/alemanha-resolveu-banco-2178950"},"id":2178950,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":10,"title":"A Suécia, depois de golear, foi goleada","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2097079?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3960,"nome":"Jorge Miguel Matias","descricao":"Sou licenciado em Ciências da Comunicação pela Faculdade de Ciências Sociais e Humanas da Universidade Nova de Lisboa e frequentei ainda uma formação adicional em Jornalismo promovida pelo semanário Expresso. Tenho trabalhado na área do desporto desde o início da minha actividade profissional, primeiro na já extinta Gazeta dos Desportos, depois no PÚBLICO, projecto que abracei de forma definitiva em 1998, embora já antes tivesse uma colaboração regular com o jornal. Actualmente, exerço funções de editor. À margem do desporto, colaborei também com revistas como a \"Rotas e Destinos\" ou a \"National Geographic\".","email":"jmatias@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editor de Desporto","profissaoNaAltura":"Editor de Desporto","slug":"jorge-miguel-matias","imagem":{"w":null,"h":null,"largura":216,"altura":216,"nome":"jorgemiguelmatias-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1758433?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#105;&#116;&#97;&#109;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Países Baixos derrotaram de forma indiscutível a selecção escandinava, que fica com a vida complicada para ficar num dos dois primeiros lugares do grupo F.","url":"/2026/06/20/desporto/cronica_de_jogo/suecia-golear-goleada-2178941","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Crónica de jogo","url":"/futebol0"},"id":2178941,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":11,"title":"No Algarve, a banhos longe do mar","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2096102?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3457,"nome":"Mara Gonçalves","descricao":"","email":"mara.goncalves@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"mara-goncalves","imagem":{"w":null,"h":null,"largura":2048,"altura":1365,"nome":"#f25_1 COL (para usar a cara).jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1470491?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#