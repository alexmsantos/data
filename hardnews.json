rço da fiscalização.","url":"/2026/06/22/ciencia/noticia/ordem-medicos-quer-revisao-lei-travar-centros-medicina-integrativa-controlo-2179041","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entidade Reguladora da Saúde","url":"https://www.publico.pt/2026/06/22/ciencia/noticia/ordem-medicos-quer-revisao-lei-travar-centros-medicina-integrativa-controlo-2179041"},"id":2179041,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":17,"title":"Centros de “medicina integrativa” ganharam mais de um milhão em fundos europeus\r\n","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2096439?tp=UH&db=IMAGENS&type=JPG","author":[{"id":7026,"nome":"Tiago Ramalho","descricao":"","email":"tiago.ramalho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"tiago-ramalho","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"tiagoramalho.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1328997?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#108;&#97;&#109;&#97;&#114;&#46;&#111;&#103;&#97;&#105;&#116;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Mesmo sem validade científica e com nomes inviáveis para a Entidade da Reguladora da Saúde, oito clínicas arrecadaram fundos europeus para pagar salários ou projectos de inteligência artificial.\r\n","url":"/2026/06/22/ciencia/noticia/centros-medicina-integrativa-ganharam-milhao-euros-fundos-europeus-2178607","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Pseudociência","url":"https://www.publico.pt/2026/06/22/ciencia/noticia/centros-medicina-integrativa-ganharam-milha