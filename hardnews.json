acebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"daniela-carmo","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#109;&#114;&#97;&#99;&#46;&#97;&#108;&#101;&#105;&#110;&#97;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Ex-secretária de Estado Margarida Tavares diz que proposta da tutela é “desonesta” e que apenas beneficia a indústria. OMS recomendou  proibição da comercialização de bolsas de nicotina com sabores.","url":"/2026/05/26/sociedade/noticia/governo-abre-porta-fabrico-bolsas-nicotina-portugal-sabores-mentol-menta-2175946","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Saúde","url":"https://www.publico.pt/2026/05/26/sociedade/noticia/governo-abre-porta-fabrico-bolsas-nicotina-portugal-sabores-mentol-menta-2175946"},"id":2175946,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Medicina na Católica: onde o futuro da saúde se treina no presente","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2086881?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Está aberto o período de candidaturas da Católica Medical School, cuja metodologia assenta na resolução prática de problemas desde o primeiro dia.","url":"/2026/05/08/estudiop/noticia/medicina-catolica-onde-futuro-saude-treina-presente-2174000","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Católica Medical School","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2000066?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/05/08/estudiop/noticia/medicina-catolica-onde-futuro-saude-treina-presente-2174000"},"id":2174000,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"Sonny Rollins (1930-2026): colosso do improviso, saxofonista livre","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2090913?tp=UH&db=IMAGENS&type=JPG","author":[{"id":136,"nome":"Joana Amaral Cardoso","descricao":"Comecei na secção de Sociedade em 1999, dali fui para o Publico.pt e como colaboradora da revista Pública escrevi sobre tendências sociais e Manias. Em 2006 comecei a debruçar-me sobre uma das áreas que mais me interessam – o audiovisual. Depois, já na secção de Cultura, onde sou hoje jornalista, juntei a isto tudo a cultura popular, o cinema, a moda, o design e interesso-me em aplicar a lente do género a muitos fenómenos.  Em 2009 editei a secção de Televisão da revista TimeOut e mais recentemente dei aulas de Jornalismo de Moda. No Público também editei a secção da Cultura online, fui subeditora da revista Pública e co-editora da revista Fugas. E vejo demasiada televisão.","email":"joana.cardoso@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"joana-amaral-cardoso","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#115;&#111;&#100;&#114;&#97;&#99;&#46;&#97;&#110;&#97;&#111;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Nome maior do jazz, Rollins morreu aos 95 anos na sua casa em Woodstock. Estava reformado desde 2014 e o seu nome ergue-se a solo, mas também na companhia de mestres como Davis, Monk ou Coltrane.","url":"/2026/05/26/culturaipsilon/noticia/sonny-rollins-19302026-colosso-improviso-saxofonista-livre-2175998","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Obituário","url":"https://www.publico.pt/2026/05/26/culturaipsilon/noticia/sonny-rollins-19302026-colosso-improviso-saxofonista-livre-2175998"},"id":2175998,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":9,"title":"PCP e BE entram em novos movimentos sociais, mas “relação é frágil” e “instrumental”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2090838?tp=UH&db=IMAGENS&type=JPG","author":[{"id":15507,"nome":"Ana Bacelar Begonha","descricao":"","email":"ana.begonha@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"ana-bacelar-begonha","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#104;&#110;&#111;&#103;&#101;&#98;&#46;&#97;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Estudo mostra que, entre 2019 e 2023, PCP e BE fizeram parte de movimentos pelo feminismo, clima e habitação através da “dupla militância”. Mantiveram “autonomia”, sem “adaptação mútua”.","url":"/2026/05/26/politica/noticia/pcp-be-entraram-novos-movimentos-sociais-relacao-fragil-instrumental-2175891","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Partidos e movimentos","url":"https://www.publico.pt/2026/05/26/politica/noticia/pcp-be-entraram-novos-movimentos-sociais-relacao-fragil-instrumental-2175891"},"id":2175891,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":10,"title":"Um em cada três portugueses vive com dor crónica*","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2089591?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"A dor interfere no dia-a-dia das pessoas, podendo afectar a qualidade de vida. É por conhecer vastamente essa realidade que se desenvolveu Trifene 400, um aliado na gestão da dor.","url":"/2026/05/20/estudiop/noticia/tres-portugueses-vive-dor-cronica-2170544","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Trifene","ImageUrl":"https://imag