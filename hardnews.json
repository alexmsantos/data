?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#103;&#114;&#111;&#98;&#46;&#97;&#110;&#97;&#105;&#108;&#105;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O Livre tem eleições internas entre 10 e 12 de Julho. Francisco Paupério, que foi candidato às eleições europeias, não será recandidato a nenhum órgão da direcção do partido.","url":"/2026/06/26/politica/noticia/rui-tavares-deixa-coportavoz-livre-partir-julho-jorge-pinto-proximo-candidato-2179543","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Livre","url":"https://www.publico.pt/2026/06/26/politica/noticia/rui-tavares-deixa-coportavoz-livre-partir-julho-jorge-pinto-proximo-candidato-2179543"},"id":2179543,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"Terramoto na Venezuela: há nove mortos lusodescendentes, confirma o MNE","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098279?tp=UH&db=IMAGENS&type=JPG","author":[{"id":17560,"nome":"Leonor Alhinho","descricao":"","email":"leonor.alhinho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"leonor-alhinho","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#110;&#105;&#104;&#108;&#97;&#46;&#114;&#111;&#110;&#111;&#101;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Segundo a televisão estatal, o maior número de vítimas mortais regista-se em La Guaira, região onde houve lusodescendentes afectados e alguns já conseguiram entrar em contacto com as famílias.","url":"/2026/06/26/mundo/noticia/terramoto-venezuela-novo-balanco-aponta-235-mortos-4000-feridos-2179531","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Ao Minuto","url":"https://www.publico.pt/2026/06/26/mundo/noticia/terramoto-venezuela-novo-balanco-aponta-235-mortos-4000-feridos-2179531"},"id":2179531,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Lisboa debate futuro da economia sustentável","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2096801?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Lisboa volta a reunir o mundo da sustentabilidade.","url":"/2026/06/19/estudiop/noticia/lisboa-debate-futuro-economia-sustentavel-2178813","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Sustainability Week 2026","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2096797?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/19/estudiop/noticia/lisboa-debate-futuro-economia-sustentavel-2178813"},"id":2178813,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"Venezuela: “Vamos ter problemas para perceber a dimensão desta catástrofe”\r\n\r\n","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098256?tp=UH&db=IMAGENS&type=JPG","author":[{"id":124,"nome":"Amílcar Correia","descricao":"Sou redactor principal desde Julho de 2023, escrevo A Coluna Vertebral todas as semanas, coordeno a área dos podcast do jornal e sou um dos autores do podcast P24. Entre Agosto de 2018 e Maio de 2023 fui director adjunto e responsável pelo PÚBLICO online. Antes disso, fui estagiário, jornalista, editor de várias secções, editor de novos projectos, editor executivo e subdirector em várias direcções. Criei e dirigi o P3, de Setembro de 2011 a Outubro de 2016, na sequência de um consórcio constituído pelo PÚBLICO, Faculdade de Engenharia e Reitoria da Universidade do Porto. O P3 recebeu vários prémios, nomeadamente o de Melhor Webdesign da Península Ibérica, na categoria de sites com menos de 12 milhões de visitas mensais, atribuído pela Society for News Design, em 2012. Sou licenciado em Ciências da Comunicação, pela Faculdade de Ciências Sociais e Humanas da Universidade Fernando Pessoa, em 2010, frequentei o curso de Comunicação Social da Escola Superior de Jornalismo do Porto entre 1988 e 1990, e vários cursos de formação do Centro Protocolar de Formação de Jornalistas, em Lisboa. Fui jornalista residente no Knight Center for Journalism in the Americas e no Technology and Information Policy Institute da Universidade do Texas, nos EUA, em 2015. Sou autor de diferentes publicações: “A balada do Níger, lançado em 2007, e \"Da Jugoslávia ao Kosovo, a mais breve história de um conflito\", em 2025. Sou co-autor do artigo “Consumer Attitudes toward News Delivering: An Experimental Evaluation of the Use and Efficacy of Personalized Recommendations”, publicado na revista cientifica Information em Julho de 2020.","email":"acorreia@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Redactor principal","profissaoNaAltura":"","slug":"amilcar-correia","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Amilcar_Correia-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1739387?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#105;&#101;&#114;&#114;&#111;&#99;&#97;","contribuicao":"","tipo":"INTERNO"},{"id":19752,"nome":"Tiago Orato","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Sonoplasta","profissaoNaAltura":"","slug":"tiago-orato","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"edição","tipo":"INTERNO"}],"shares":0,"description":"A convidada deste episódio é a lusovenezuelana Nancy Gomes, professora na Universidade Autónoma de Lisboa, que ontem lançou o livro <em>Venezuela, um país em Suspenso</em>.","url":"/2026/06/26/mundo/podcast/nancy-gomes-vamos-problemas-perceber-dimensao-catastrofe-venezuela-2179483","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Podcast","url":"/p24-podcast"},"id":2179483,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Supremo dos EUA abre a porta a que Trump deporte milhares de haitianos e sírios","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098305?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1083,"nome":"Ana Brito","descricao":"","email":"ana.brito@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ana-brito","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#116;&#105;&#114;&#98;&#46;&#97;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Supremo autoriza Trump a revogar estatuto de protecção legal de 348 mil haitianos e seis mil sírios e cria precedente que põe em risco de expulsão um milhão de pessoas de outras nacionalidades.","url":"/2026/06/26/mundo/noticia/supremo-eua-abre-porta-trump-deporte-milhares-haitianos-sirios-2179547","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"EUA","url":"https://www.publico.pt/2026/06/26/mundo/noticia/supremo-eua-abre-porta-trump-deporte-milhares-haitianos-sirios-2179547"},"id":2179547,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"Problemas nos exames revelam “amadorismo” e põem em causa a confiança no sistema","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098243?tp=UH&db=IMAGENS&type=JPG","author":[{"id":495,"nome":"Andreia Sanches","descricao":"Entrei no PÚBLICO em 1996. Tinha 22 anos, terminado o curso de Ciências da Comunicação na Universidade Nova de Lisboa e estava no jornal onde queria, de facto, começar a fazer jornalismo. Estagiei no Internacional, quando ainda fazíamos fila para aceder ao computador da redacção que estava ligado à Internet. Seguiu-se a Educação, onde fiquei vários anos, quando aquela era uma secção autónoma, diária. Já na Sociedade, o leque de temas sobre os quais passei a escrever alargou-se – a pobreza e as desigualdades, a exclusão e as políticas de protecção social são alguns dos que tenho acompanhado de forma mais sistemática. Em 2013 foi publicado o meu primeiro livro. Chama-se \"Os Anjos Não Comem Chocolate\" e tem como ponto de partida uma reportagem que fiz no PÚBLICO sobre pais que perderam os seus filhos. Ao longo dos últimos anos desempenhei funções de editora do P2, editora da Sociedade, editora-executiva e directora-adjunta.","email":"asanches@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Redactora principal","profissaoNaAltura":"","slug":"andreia-sanches","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"andreia-sanches-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1748990?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Andreia C. Faria","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#104;&#99;&#110;&#97;&#115;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"João Marôco integrou o conselho directivo do Instituto de Avaliação Educativa. “Qualquer pessoa que trabalhe em avaliação e avaliação digital tem de perceber que tem de haver um sistema blindado.”","url":"/2026/06/26/sociedade/entrevista/problemas-exames-revelam-amadorismo-poem-causa-confianca-pessoas-sistema-2179486","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista","url":"/exames"},"id":2179486,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":9,"title":"«Dear England»: como se muda uma cultura de fracasso","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2097247?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Enquanto o Mundial ocupa o centro das atenções, «Dear England» recupera a história real por detrás da reinvenção da selecção inglesa liderada por Gareth Southgate. Para assistir no canal AXN Portugal.","url":"/2026/06/22/estudiop/noticia/dear-england-muda-cultura-fracasso-2178775","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"AXN","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1953085?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/22/estudiop/noticia/dear-england-muda-cultura-fracasso-2178775"},"id":2178775,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":10,"title":"Professor Neca: “O estágio em Macau teve motivações políticas. Não foi ajustado”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098073?tp=UH&db=IMAGENS&type=JPG","author":[{"id":4925,"nome":"Nuno Sousa","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Ilustrador","profissaoNaAltura":"Ilustrador","slug":"nuno-sousa","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"},{"id":6030,"nome":"Augusto Bernardino","descricao":"","email":"augusto.bernardino@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"augusto-bernardino","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#105;&#100;&#114;&#97;&#110;&#114;&#101;&#98;&#46;&#111;&#116;&#115;&#117;&#103;&#117;&#97;","contribuicao":"","tipo":"INTERNO"},{"id":20431,"nome":"Margarida Adão","descricao":"","email":"Margarida.Adao@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Sonoplasta","profissaoNaAltura":"Sonoplasta","slug":"margarida-adao","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#97;&#100;&#65;&#46;&#97;&#100;&#105;&#114;&#97;&#103;&#114;&#97;&#77;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Responsável pela análise dos adversários de Portugal no Mundial da Coreia/Japão admite que período de preparação foi erro de palmatória. E revela que Mourinho mudou a forma como elabora relatórios.","url":"/2026/06/26/desporto/noticia/professor-neca-mundial-2002-estagio-macau-motivacoes-politicas-nao-ajustado-2179405","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Podcast 8 Mundiais: eu estive lá","url":"https://www.publico.pt/2026/06/26/desporto/noticia/professor-neca-mundial-2002-estagio-macau-motivacoes-politicas-nao-ajustado-2179405"},"id":2179405,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":11,"title":"Freddy Adu, a criança que nunca teve 14 anos","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098199?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6063,"nome":"Diogo Cardoso Oliveira","descricao":"Ver desporto, escrever e contar histórias: costumo dizer que sou pago para fazer algo que faria <i>pro-bono</i>. Tudo começou numa t-shirt branca, feita na escola primária, que já identificava um gaiato com más ideias: dizia “Diogo, o jornalista”. Feito um raide incompleto pela aviação, formei-me em Comunicação Social, época em que fazia do jornal universitário <i>Pontivirgula</i> uma tela para rascunhos do que estaria por vir. Comecei a carreira como estagiário no PÚBLICO, no mês em que Éder decidiu dar um chuto aos franceses. Ainda estive no <i>Record</i>, antes de fazer parte do início do site <i>Bancada</i>. Voltei para o PÚBLICO, que já me levou ao Mundial do Qatar, aos Jogos Olímpicos de Paris e onde faço um pouco de tudo no desporto. Gosto de ciclismo, basquetebol, ginástica, futebol, História e histórias — também por isso escrevi o livro <i>Futebol numa conversa de café</i>.","email":"diogo.oliveira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"em Houston","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"diogo-cardoso-oliveira","imagem":{"w":null,"h":null,"largura":859,"altura":1831,"nome":"WhatsApp Image 2026-06-09 at 00.03.14.jpeg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/2094160?tp=UH&db=IMAGENS&type=JPG","is_vertical":true,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#118;&#105;&#108;&#111;&#46;&#111;&#103;&#111;&#105;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Chegou ao Benfica em 2007 como “novo Pelé”, mas não justificou o rótulo. Adu foi forçado a ser adu(lto) demasiado cedo. Mudou, ainda assim, o soccer nos Estados Unidos. Por aqui ainda falam dele.","url":"/2026/06/26/desporto/noticia/freddy-adu-crianca-14-anos-2179492","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Mundial 2026","url":"https://www.publico.pt/2026/06/26/desporto/noticia/freddy-adu-crianca-14-anos-2179492"},"id":2179492,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":12,"title":"Sisão à beira da extinção em Portugal após queda de 90% em duas décadas","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098290?tp=UH&db=IMAGENS&type=JPG","author":[{"id":177,"nome":"Andréia Azevedo Soares","descricao":"Nasci no Rio de Janeiro, onde estudei jornalismo na Universidade Federal. Mudei-me para Portugal em 1999. Trabalho no PÚBLICO desde 2000, com duas interrupções – uma para um doutoramento em Comunicação de Ciência no Imperial College, em Londres, e outra para colaborar com a revista científica WHO Bulletin, em Genebra. Já fui estagiária, colaboradora, repórter e sub-editora em diferentes secções deste jornal. A ciência e a literatura são as áreas sobre as quais mais gosto de escrever; fascina-me o modo como o escritor e o cientista se empenham para detalhar e compreender o mundo que nos rodeia, incluindo os seres vivos que nele habitam.\r\n\r\n\r\n\r\n","email":"aasoares@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"andreia-azevedo-soares","imagem":{"w":null,"h":null,"largura":501,"altura":498,"nome":"andreia_soares-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1725026?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#114;&#97;&#111;&#115;&#97;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O 4.º Censo Nacional de Sisão estima que existam apenas 1736 machos em Portugal. Organizações ambientais exigem medidas urgentes para travar o colapso da espécie.","url":"/2026/06/26/azul/noticia/sisao-beira-extincao-portugal-apos-queda-90-duas-decadas-2179540","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Conservação da natureza","url":"https://www.publico.pt/2026/06/26/azul/noticia/sisao-beira-extincao-portugal-apos-queda-90-duas-decadas-2179540"},"id":2179540,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":13,"title":"Poupar mais de 600 euros por ano? É possível","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2091934?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"O Continente, a Galp e a NOS juntaram-se para criar o maior programa de poupança do país. Conheça as vantagens para as suas compras e abastecimentos do dia-a-dia – e saiba como aderir.","url":"/2026/06/19/estudiop/noticia/poupar-600-euros-ano-possivel-2176370","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Continente","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1064970?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/19/estudiop/noticia/poupar-600-euros-ano-possivel-2176370"},"id":2176370,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":14,"title":"Esta é a pior onda de calor de sempre na Europa e a culpa é dos combustíveis fósseis","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098191?tp=UH&db=IMAGENS&type=JPG","author":[{"id":227,"nome":"Clara Barata","descricao":"Gosto de compreender como funciona o mundo. Numa célula, de me espantar como uma máquina biológica esconde a centelha que a transforma numa coisa viva. Nas manobras de bastidores de uma campanha de um político que quer ser eleito Presidente da República, descobre-se um homem e uma teia de interesses tão mais vasta que ele e muito mais que isso: as aspirações, os traumas, os preconceitos e a cultura de um povo que pode ser muito diferente do nosso. Os meus interesses são variados, da ciência à política internacional, ambiente ou tendências sociais, na Europa, nos EUA. Um ponto comum entre eles é sempre a vontade de querer saber como funcionam as coisas — e aplicar uma atitude que aprendi a assumir fazendo jornalismo de ciência, que é não ter medo de fazer perguntas, mesmo que pareçam básicas.","email":"clara.barata@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"clara-barata","imagem":{"w":null,"h":null,"largura":368,"altura":331,"nome":"_RG__foto_Clara_Barata_DSCF4152-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1926383?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#116;&#97;&#114;&#97;&#98;&#46;&#97;&#114;&#97;&#108;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Há 50 anos, uma onda de calor na Europa não chegaria aos valores de hoje. Porquê? Porque em 1976 o aquecimento global estava só a começar e hoje roça 1,5 graus Celsius, dizem cientistas.\r\n","url":"/2026/06/26/azul/noticia/pior-onda-calor-europa-culpa-combustiveis-fosseis-2179477","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Clima","url":"https://www.publico.pt/2026/06/26/azul/noticia/pior-onda-calor-europa-culpa-combustiveis-fosseis-2179477"},"id":2179477,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":15,"title":"Lei da autodeterminação de género adiada para Setembro","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098267?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19357,"nome":"Filipe Santa-Bárbara","descricao":"","email":"filipe.santabarbara@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"filipe-santabarbara","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#97;&#98;&#114;&#97;&#9