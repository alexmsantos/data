co.pt/2026/03/20/desporto/noticia/martinez-chama-guedes-mora-matheus-fernandes-ultimo-teste-mundial-2168573"},"id":2168573,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":13,"title":"Reitores voltam a pedir dinheiro ao Governo para responder às condenações em tribunal","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2074928?tp=UH&db=IMAGENS&type=JPG","author":[{"id":7026,"nome":"Tiago Ramalho","descricao":"","email":"tiago.ramalho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"tiago-ramalho","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"tiagoramalho.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1328997?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#108;&#97;&#109;&#97;&#114;&#46;&#111;&#103;&#97;&#105;&#116;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Imposição judicial de abertura de concursos para cientistas está a preocupar as universidades. Já há nove condenações em tribunal da Universidade de Lisboa. Governo não prevê reforço de verbas.","url":"/2026/03/20/ciencia/noticia/reitores-voltam-pedir-dinheiro-governo-responder-condenacoes-tribunal-2168204","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Emprego científico","url":"https://www.publico.pt/2026/03/20/ciencia/noticia/reitores-voltam-pedir-dinheiro-governo-responder-condenacoes-tribunal-2168204"},"id":2168204,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":14,"title":"Mafalda Livermore desfilia-se do Chega e há desconforto com silêncio de Ventura","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2075631?tp=UH&db=IMAGENS&type=JPG","author":[{"id":18186,"nome":"Joana Mesquita","descricao":"","email":"joana.mesquita@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"joana-mesquita","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#116;&#105;&#117;&#113;&#115;&#101;&#109;&#46;&#97;&#110;&#97;&#111;&#106;","contribuicao":"","tipo":"INTERNO"},{"id":157,"nome":"Maria Lopes","descricao":"Entrei para o PÚBLICO, vinda da universidade, quando se vivia a excitação das vésperas da primeira Exposição Mundial em Portugal. Calcorreei a Expo-98 de fio a pavio, de caderno, caneta e, por vezes, de Polaroid na mão. Esses poucos meses ensinaram-me a conjugar o verbo tão português “desenrascar-se”.\r\nNestes mais de 20 anos, passei depois pelas secções Local, Media (por duas vezes) e Economia. Estive no lançamento do suplemento Digital – que apesar do nome existiu apenas em papel – e pertenci à equipa do irreverente projecto Sexta, o jornal gratuito que o PÚBLICO partilhou com A Bola, em 2007 e 2008. Em simultâneo, durante dez anos, escrevi também para o Motores (da Fugas), vivendo os automóveis sob uma perspectiva menos técnica e mais prazenteira. Desde 2009 que integro a secção de Política e tento manter debaixo de olho o panorama dos media. \r\n\r\n","email":"maria.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"maria-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Maria_C_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737865?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#97;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Exonerada dos serviços sociais de Lisboa, Mafalda Livermore sai do Chega. Depois de Rita Matias pedir a demissão do vereador em Lisboa, Ventura diz que “é uma questão autárquica”.","url":"/2026/03/19/politica/noticia/mafalda-livermore-desfiliase-chega-ha-desconforto-silencio-ventura-2168505","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Chega","url":"https://www.publico.pt/2026/03/19/politica/noticia/mafalda-livermore-desfiliase-chega-ha-desconforto-silencio-ventura-2168505"},"id":2168505,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":15,"title":"Este prémio oferece até 100 mil euros a projectos solidários","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2075258?tp=UH&db=IMAGENS&type=PNG","author":[],"shares":0,"description":"Já estão abertas as candidaturas ao Prémio BPI Fundação ”la Caixa” Solidário. Um galardão que ajuda quem ajuda.","url":"/2026/03/17/estudiop/noticia/premio-oferece-ate-100-mil-euros-projectos-solidarios-2167398","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"BPI La Caixa","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1779903?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/03/17/estudiop/noticia/premio-oferece-ate-100-mil-euros-projectos-solidarios-2167398"},"id":2167398,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":16,"title":"Robô dançarino semeia a confusão em restaurante nos EUA","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2075717?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19406,"nome":"Sérgio Magno","descricao":"","email":"sergio.magno@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"sergio-magno","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#103;&#97;&#109;&#46;&#111;&#105;&#103;&#114;&#101;&#115;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Um humanóide da AgiBot perdeu o controlo durante uma demonstração num restaurante na Califórnia, obrigando os funcionários a uma contenção física para evitar acidentes com os clientes.","url":"/2026/03/20/enter/noticia/robo-dancarino-semeia-confusao-restaurante-eua-2168544","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Robótica","url":"https://www.publico.pt/2026/03/20/enter/noticia/robo-dancarino-semeia-confusao-restaurante-eua-2168544"},"id":2168544,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":17,"title":"<em>Influencer</em> Tiago Grila já tinha sido condenado cinco vezes pela sua condução","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2075791?tp=UH&db=IMAGENS&type=JPG","author":[{"id":12425,"nome":"Inês Duarte de Freitas","descricao":"","email":"ines.freitas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ines-duarte-freitas","imagem":{"w":null,"h":null,"largura":344,"altura":320,"nome":"WhatsApp_Image_2023-02-01_at_13.49.04-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1775300?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#105;&#101;&#114;&#102;&#46;&#115;&#101;&#110;&#105;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O caso recua até 17 de Janeiro de 2024, quando o <em>influencer</em> terá atropelado uma mulher junto ao Bingo da Amadora. Não lhe prestou auxílio, ainda fugiu e nem tinha carta de condução.","url":"/2026/03/20/impar/noticia/influencer-tiago-grila-ja-condenado-cinco-vezes-conducao-2168583","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"Justiça","url":"https://www.publico.pt/2026/03/20/impar/noticia/influencer-tiago-grila-ja-condenado-cinco-vezes-conducao-2168583"},"id":2168583,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":18,"title":"Miguel Cardoso: a poesia pode ser olhar para a língua “como se já tivesse morrido”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2075220?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19703,"nome":"Luís Ricardo Duarte","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"luis-ricardo-duarte","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"texto","tipo":"EXTERNO"},{"id":3983,"nome":"Rui Gaudêncio","descricao":"","email":"rgaudencio@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"rui-gaudencio","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#105;&#99;&#110;&#101;&#100;&#117;&#97;&#103;&#114;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"A partir de uma residência literária em Berlim, Miguel Cardoso escreveu <em>Passageiros</em>, livro que reforça a singularidade do seu canto, entre o circunstancial e o colectivo, a memória e a História.","url":"/2026/03/20/culturaipsilon/entrevista/miguel-cardoso-poesia-vezes-exige-olhemos-lingua-ja-morrido-2167125","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista","url":"/poesia"},"id":2167125,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":1418,"nome":"Poesia","slug":"poesia","tagEn":"","isPrincipal":false,"isVisible":true,"urlRoute":"/tpoesia","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAberto":false,"follow_type":null,"descricao":null,"imagem":null,"html":null,"isForForuns":false,"isUsedInForuns":false},"size":30},{"pos":19,"title":"Amor, uma copa e uma cozinha: Angélica Salvador e Tiago Bonito, o novo casal Michelin","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2074969?tp=UH&db=IMAGENS&type=JPG","author":[{"id":120,"nome":"Sandra Silva Costa","descricao":"Nunca fui bairrista mas também nunca fui de renegar as origens: nasci numa aldeia, Maceda, no concelho de Ovar, e lá vivi até aos 20 anos, mais coisa menos coisa. Nessa altura já estudava Jornalismo, na Universidade de Coimbra. Entrei para o PÚBLICO aos 22, tinha cabelos curtos e um mar de sonhos na cabeça. Vim estagiar, com experiência quase zero — mas justiça seja feita ao Jornal de Ovar, que me deu a primeira oportunidade, ainda nos tempos da faculdade. Estágio cumprido, integrei a secção de Educação, na altura uma editoria autónoma. Estávamos em 1998. Passei ainda pela Sociedade, como jornalista e como editora, até que, em 2008, assumi a edição da Fugas, onde fiquei até Dezembro de 2024. Em Janeiro de 2025, integrei a equipa do Local Porto.","email":"scosta@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"sandra-silva-costa","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"sc.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1091354?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#116;&#115;&#111;&#99;&#115;","contribuicao":"texto","tipo":"INTERNO"},{"id":3917,"nome":"Nelson Garrido","descricao":"Nasci em Vila Nova de Gaia, Portugal. Em 1996 concluí o bacharelato em Tecnologias da Comunicação Audiovisual. No mesmo ano, frequentei uma formação avançada em fotografia na escola Karel de Grote-Hogescholl Antwerpen, na Bélgica, e fiz um estágio em fotografia digital e de grande formato no Studio Brison, também na Bélgica. Em Portugal, trabalhei em regime de freelancer com várias revistas, na área da fotografia de reportagem e de arquitectura. Em 2000, concluí a licenciatura em Comunicação Social e em 2005 a Licenciatura em Fotografia. Em 2005, ganhei três menções honrosas no concurso de fotojornalismo da revista Visão e venci a categoria de fotografia de arquitectura do Euro Press Photo Awards da Fuji Film. Fui premiado no Prémio Estação Imagem|Mora em 2010 e 2011. Desde 1999, sou fotojornalista no PÚBLICO.","email":"ngarrido@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"nelson-garrido","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Nelson_Garrido.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737874?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#100;&#105;&#114;&#114;&#97;&#103;&#110;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"Os dois <em>chefs</em> conquistaram este ano uma estrela para os seus restaurantes no Porto, IN Diferente e Éon. “Foi uma alegria a dobrar.” Agora querem “evoluir, dar continuidade e agregar valor”.","url":"/2026/03/20/fugas/perfil/amor-copa-cozinha-angelica-salvador-tiago-bonito-novo-casal-michelin-2168224","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Perfil","url":"/gastronomia"},"id":2168224,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":1019,"nome":"Gastronomia","slug":"gastronomia","tagEn":"","isPrincipal":false,"isVisible":true,"urlRoute":"/tgastronomia","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAberto":false,"follow_type":null,"descricao":null,"imagem":null,"html":null,"isForForuns":true,"isUsedInForuns":false},"size":30},{"pos":20,"title":"Trovante de novo juntos ao vivo: “Somos iguais ao que éramos quando começámos”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2075595?tp=UH&db=IMAGENS&type=JPG","author":[{"id":52,"nome":"Nuno Pacheco","descricao":"Integrar em 1989 a equipa fundadora do PÚBLICO, após oito anos no Expresso, foi um dos grandes desafios da minha vida, faltavam ainda uns anos para o advento revolucionário da Internet. Que não mudou a essência do que acredito que deve ser o jornalismo: uma mistura de ética, arte e busca incessante do que é novo. E isso é inseparável do tratamento dado à palavra, na forma como se escreve uma história, se formula uma ideia, se incentiva um debate. Por isso sou defensor acérrimo da diversidade da língua portuguesa, nas suas riquíssimas variantes, e adversário do acordo ortográfico de 1990. Em apoio desta posição, invoco o facto de escrever sobre música brasileira há quase duas décadas. Nasci no ano (e no mês) da morte de Carmen Miranda, Agosto de 1955, mas não acho que isso conte para esta história.","email":"nuno.pacheco@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Redactor-principal","profissaoNaAltura":"Redactor-principal","slug":"nuno-pacheco","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Nuno_Pacheco-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1739377?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Nuno Pacheco","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#99;&#101;&#104;&#99;&#97;&#112;&#46;&#111;&#110;&#117;&#110;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Nos 50 anos da fundação do Trovante, o grupo reúne-se para quatro concertos em grandes salas de Lisboa e Porto, com duas noites já esgotadas. Três fundadores explicam porquê.","url":"/2026/03/19/culturaipsilon/noticia/trovante-novo-juntos-vivo-iguais-eramos-comecamos-2168281","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Música","url":"https://www.publico.pt/2026/03/19/culturaipsilon/noticia/trovante-novo-juntos-vivo-iguais-eramos-comecamos-2168281"},"id":2168281,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":21,"title":"Fazer “avançar as artes performativas”, na hibridez e na informalidade: eis a Mula","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2075432?tp=UH&db=IMAGENS&type=JPG","author":[{"id":12716,"nome":"Daniel Dias","descricao":"","email":"daniel.dias@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"daniel-dias","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#105;&#100;&#46;&#108;&#101;&#105;&#110;&#97;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Criado por Cristina Planas Leitão e por Luísa Saraiva, este novo festival focado na dança e na multidisciplinaridade ocupa por dois dias vários espaços independentes do Porto.","url":"/2026/03/20/culturaipsilon/noticia/avancar-artes-performativas-hibridez-informalidade-eis-mula-2168142","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Dança","url":"https://www.publico.pt/2026/03/20/culturaipsilon/noticia/avancar-artes-performativas-hibridez-informalidade-eis-mula-2168142"},"id":2168142,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"VSR: mais prevenção e protecção para os adultos","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2074604?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Mais e melhor prevenção é o que pedem especialistas e representantes de associações de doentes.","url":"/2026/03/18/estudiop/noticia/vsr-prevencao-proteccao-adultos-2167842","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"GSK","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1807717?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/03/18/estudiop/noticia/vsr-prevencao-proteccao-adultos-2167842"},"id":2167842,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":23,"title":"Estúdio do Porto Macedo Cannatà distinguido no prémio alemão de design Buchkunst","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2075516?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19961,"nome":"Ana Beatriz Ferreira","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"ana-beatriz-ferreira","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O estúdio portuense Macedo Cannatà venceu a competição Best Book Design from all over the World com o livro <em>Os Ovários das Papoilas</em>, das autoras Isabel Carvalho e Clara Batalha.","url":"/2026/03/20/p3/noticia/estudio-portuense-macedo-cannata-ganha-bronze-premio-alemao-design-editorial-buchkunst-2168438","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"p3"},"brand":null,"rubric":{"name":"Design","url":"https://www.publico.pt/2026/03/20/p3/noticia/estudio-portuense-macedo-cannata-ganha-bronze-premio-alemao-design-editorial-buchkunst-2168438"},"id":2168438,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":24,"title":"Prazos, expulsões e proibição de entrada: o que muda no retorno de estrangeiros","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2075610?tp=UH&db=IMAGENS&type=JPG","author":[{"id":455,"nome":"Joana Gorjão Henriques","descricao":"Entrei para o PÚBLICO no final de 1999, para estagiar na Cultura, onde fiquei durante dez anos. Entre fim de 2009 e de 2011 fiz uma pausa de dois anos, primeiro para ser bolseira da Nieman Foundation for Journalism na Universidade de Harvard, EUA; e depois para estudar Sociologia na London School of Economics, em Londres. Integro a secção de Sociedade, escrevendo sobre temas ligados a imigração, racismo, direitos humanos. Sou autora de 3 séries que deram livros: Racismo em português, sobre o racismo durante o sistema colonial, Racismo à Portuguesa, retrato de desigualdades raciais em Portugal e Colonos em Angola e Moçambique. Retornados em Portugal, que deu também origem ao documentário Racismo, uma descolonização em curso. Recebi a medalha de ouro de Direitos Humanos da Assembleia da República e alguns prémios: o Prémio Gazeta duas vezes, o Prémio AMI - Jornalismo contra a Indiferença por duas vezes, o prémio de Jornalismo de imprensa escrita de Direitos Humanos e Integração, da Comissão Nacional da UNESCO por duas vezes, o prémio de imprensa escrita Comunicação \"Pela Diversidade Cultural\" do Alto Comissariado para as Migrações, também por duas vezes, o prémio de jornalismo Corações com Coroa duas vezes, o prémio Os Direitos da Criança em Notícia  e fiquei na lista final dos prémio ibero-americanos da Fundação Gabo.","email":"jgh@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"joana-gorjao-henriques","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#104;&#103;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Prazos mais longos de detenção, expulsões mais fáceis, e menos garantias para menores. Proposta aprovada em Conselho de Ministros quase não sofreu alterações face ao que foi apresentado em Dezembro.","url":"/2026/03/19/sociedade/perguntaserespostas/prazos-expulsoes-proibicao-voltar-entrar-pais-muda-lei-retorno-2168493","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Perguntas e Respostas","url":"/imigracao"},"id":2168493,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":25,"title":"Clubes portugueses alcançam recorde em época histórica nas provas da UEFA","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2075748?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1059,"nome":"Nuno Sousa","descricao":"Primeiro, foi a informação local. Em Aveiro, durante um ano (o de 2003), ajudei a levantar um dos quatro cadernos regionais que o PÚBLICO chegou a oferecer aos leitores, antes de me tornar editor do entretanto extinto Local Centro. A viagem para norte foi relativamente rápida e, em 2005, assumi a editoria do Local Porto, da qual me despediria no final de 2007, para ocupar o cargo que actualmente desempenho, na chefia da secção de Desporto. Desde então, tenho olhado para a actualidade desportiva com a avidez e o interesse do dia de estreia. E acompanhado o relançamento do site de Desporto, a criação de canais dedicados (Jogos Olímpicos, Europeu, Mundial de futebol) e a edição de suplementos em papel com a mesma lupa que uso para aperfeiçoar o jornal que todos os dias sai para as bancas.","email":"nsousa@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editor de Desporto","profissaoNaAltura":"","slug":"nuno-sousa","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"nsousa.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1951120?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Liga Europa da UEFA","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#115;&#117;&#111;&#115;&#110;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Nunca Portugal tinha somado tantos pontos para o ranking numa época. Factor casa tem sido determinante, numa campanha que valeu a ultrapassagem aos Países Baixos.","url":"/2026/03/20/desporto/noticia/clubes-portugueses-alcancam-recorde-epoca-historica-provas-uefa-2168555","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Futebol internacional","url":"https://www.publico.pt/2026/03/20/desporto/noticia/clubes-portugueses-alcancam-recorde-epoca-historica-provas-uefa-2168555"},"id":2168555,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":26,"title":"Despejos aumentaram mais de 40% em 2025","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2075581?tp=UH&db=IMAGENS&type=JPG","author":[{"id":15415,"nome":"Rafaela Burd Relvas","descricao":"","email":"rafaela.relvas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"rafaela-burd-relvas","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#118;&#108;&#101;&#114;&#46;&#97;&#108;&#101;&#97;&#102;&#97;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Em 2025, foram emitidos 1447 títulos de desocupação no âmbito de processos de despejo, o que representa um aumento de 44% em relação ao ano anterior. Lisboa e Porto concentram a maioria dos caso