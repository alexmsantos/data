"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"Reportagem","url":"/moda"},"id":2171745,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"Natureza sem pressa: pausa revigorante a uma hora de Lisboa","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2082100?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Uma escapadinha na natureza a uma hora de Lisboa","url":"/2026/04/17/estudiop/noticia/natureza-pressa-pausa-revigorante-hora-lisboa-2171598","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Huttopia","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2082090?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/04/17/estudiop/noticia/natureza-pressa-pausa-revigorante-hora-lisboa-2171598"},"id":2171598,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":23,"title":"Nunca existiu essa coisa chamada world music","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2082383?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1034,"nome":"Mário Lopes","descricao":"A culpa é de um gira-discos e dos discos que o meu pai rodava no gira-discos. A música chegou primeiro. Como com a maioria dos adolescentes, a música moldou-me gostos e atitudes, os discos foram guias para a descoberta do mundo. Através deles, cheguei a livros, a cinema, a nomes e mais nomes e a outros discos, outros livros, outros filmes. Foi pela música que cheguei ao jornalismo. Primeiro no Blitz, onde entrei estagiário no final do curso de Ciências da Comunicação e que seria, posteriormente, a casa do meu primeiro emprego. Depois no Diário de Notícias, onde a música começou a significar mais jornalismo, aberto a mais que bandas e discos. Ao PÚBLICO cheguei em 2005. Para escrever maioritariamente sobre música. Para, através da música, chegar a outros universos da cultura. E para, através da cultura, tentar compreender melhor o mundo e, escrevendo sobre ela, tentar mostrá-lo o mais claramente possível. A adolescência já lá vai há muito. Discos, livros, filmes, continuam a ser guias de descoberta. Assim sendo, continuarei.","email":"mario.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"em Marselha","profissaoActual":"","profissaoNaAltura":"","slug":"mario-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Mario_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/860961?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#111;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Deu visibilidade a músicos fora do eixo anglo-americano mas, ao mesmo tempo, exotizou e excluiu. Que significa hoje? Olivier Rey e Frédérique André, do Babel Music XP, falam do mundo pós world music.","url":"/2026/04/19/culturaipsilon/noticia/existiu-chamada-world-music-2171488","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Música","url":"https://www.publico.pt/2026/04/19/culturaipsilon/noticia/existiu-chamada-world-music-2171488"},"id":2171488,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":24,"title":"Em <em>Abril, Cartazes Mil! </em>Este arquivo quer guardar as mensagens de liberdade","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2082071?tp=UH&db=IMAGENS&type=JPG","author":[{"id":11076,"nome":"Mariana Durães","descricao":"","email":"mariana.duraes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"mariana-duraes","imagem":null,"hasImage":false,"isExter