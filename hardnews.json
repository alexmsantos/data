o.pt/imagens.aspx/2082562?tp=UH&db=IMAGENS&type=PNG","author":[{"id":973,"nome":"PÚBLICO","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"publico","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Durante o tiroteio terão sido alvejadas dez crianças, com idades entre um e 14 anos. O autor pelos disparos terá sido morto pelas autoridades quando tentava fugir do local.","url":"/2026/04/19/mundo/noticia/oito-criancas-mortas-tiroteio-estado-louisiana-eua-2171806","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Tiroteio nos EUA","url":"https://www.publico.pt/2026/04/19/mundo/noticia/oito-criancas-mortas-tiroteio-estado-louisiana-eua-2171806"},"id":2171806,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":11,"title":"E-REDES leva segurança a palco em Tomar e mantém meta de zero acidentes","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2081231?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"No 17º Encontro de Segurança, a E-REDES mobilizou equipas para reduzir acidentes graves e mortais, reforçando a cultura de prevenção.","url":"/2026/04/15/estudiop/noticia/eredes-leva-seguranca-palco-tomar-mantem-meta-zero-acidentes-2171211","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"E-REDES","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1584526?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/04/15/estudiop/noticia/eredes-leva-seguranca-palco-tomar-mantem-meta-zero-acidentes-2171211"},"id":2171211,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":12,"title":"Estádio José Alvalade bate recorde de assistência no <em>derby </em>lisboeta","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2082587?tp=UH&db=IMAGENS&type=JPG","author":[{"id":90,"nome":"Lusa","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"lusa","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"AGENCIA"}],"shares":0,"description":"Assistiram ao jogo entre Sporting e Benfica deste domingo 51.470 espectadores. O anterior máximo registou-se na recepção do Paris Saint-Germain, em Janeiro, com 51.428 adeptos nas bancadas.","url":"/2026/04/19/desporto/noticia/estadio-jose-alvalade-bate-recorde-assistencia-derbi-lisboeta-2171821","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Futebol","url":"https://www.publico.pt/2026/04/19/desporto/noticia/estadio-jose-alvalade-bate-recorde-assistencia-derbi-lisboeta-2171821"},"id":2171821,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":13,"title":"Nunca existiu essa coisa chamada world music","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2082383?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1034,"nome":"Mário Lopes","descricao":"A culpa é de um gira-discos e dos discos que o meu pai rodava no gira-discos. A música chegou primeiro. Como com a maioria dos adolescentes, a música moldou-me gostos e atitudes, os discos foram guias para a descoberta do mundo. Através deles, cheguei a livros, a cinema, a nomes e mais nomes e a outros discos, outros livros, outros filmes. Foi pela música que cheguei ao jornalismo. Primeiro no Blitz, onde entrei estagiário no final do curso de Ciências da Comunicação e que seria, posteriormente, a casa do meu primeiro emprego. Depois no Diário de Notícias, onde a música começou a significar mais jornalismo, aberto a mais que bandas e discos. Ao PÚBLICO cheguei em 2005. Para escrever maioritariamente sobre música. Para, através da música, chegar a outros universos da cultura. E para, através da cultura, tentar compreender melhor o mundo e, escrevendo sobre ela, tentar mostrá-lo o mais claramente possível. A adolescência já lá vai há muito. Discos, livros, filmes, continuam a ser guias de descoberta. Assim sendo, continuarei.","email":"mario.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"em Marselha","profissaoActual":"","profissaoNaAltura":"","slug":"mario-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Mario_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/860961?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#111;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Deu visibilidade a músicos fora do eixo anglo-americano mas, ao mesmo tempo, exotizou e excluiu. Que significa hoje? Olivier Rey e Frédérique André, do Babel Music XP, falam do mundo pós world music.","url":"/2026/04/19/culturaipsilon/noticia/existiu-chamada-world-music-2171488","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Música","url":"https://www.publico.pt/2026/04/19/culturaipsilon/noticia/existiu-chamada-world-music-2171488"},"id":2171488,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":14,"title":"Porque é que a solidão ameaça a democracia? “Porque as pessoas perdem a empatia”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2082535?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1047,"nome":"Natália Faria","descricao":"","email":"nfaria@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalis