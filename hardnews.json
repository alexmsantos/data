url":"/video-"},"id":97841,"type":"VIDEO","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"O Porto que se lê entre o <em>graffiti</em>, a poesia e a arqueologia","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2083976?tp=UH&db=IMAGENS&type=JPG","author":[{"id":4902,"nome":"Andreia Marques Pereira","descricao":"","email":"andreia.pereira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"andreia-marques-pereira","imagem":{"w":null,"h":null,"largura":720,"altura":720,"nome":"#f15_1 COL (para usar a carinha).jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1470490?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#101;&#112;&#46;&#97;&#105;&#101;&#114;&#100;&#110;&#97;","contribuicao":"texto","tipo":"INTERNO"},{"id":3917,"nome":"Nelson Garrido","descricao":"Nasci em Vila Nova de Gaia, Portugal. Em 1996 concluí o bacharelato em Tecnologias da Comunicação Audiovisual. No mesmo ano, frequentei uma formação avançada em fotografia na escola Karel de Grote-Hogescholl Antwerpen, na Bélgica, e fiz um estágio em fotografia digital e de grande formato no Studio Brison, também na Bélgica. Em Portugal, trabalhei em regime de freelancer com várias revistas, na área da fotografia de reportagem e de arquitectura. Em 2000, concluí a licenciatura em Comunicação Social e em 2005 a Licenciatura em Fotografia. Em 2005, ganhei três menções honrosas no concurso de fotojornalismo da revista Visão e venci a categoria de fotografia de arquitectura do Euro Press Photo Awards da Fuji Film. Fui premiado no Prémio Estação Imagem|Mora em 2010 e 2011. Desde 1999, sou fotojornalista no PÚBLICO.","email":"ngarrido@publico.pt","faceboo