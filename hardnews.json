omia/noticia/novo-banco-exigiu-devolucao-premios-gestor-destituiu-justa-causa-2167403","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Banca","url":"https://www.publico.pt/2026/03/10/economia/noticia/novo-banco-exigiu-devolucao-premios-gestor-destituiu-justa-causa-2167403"},"id":2167403,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":16,"title":"Uma nova era na robótica doméstica","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2071581?tp=UH&db=IMAGENS&type=PNG","author":[],"shares":0,"description":"Quarenta anos depois de ter redefinido a limpeza doméstica, a iRobot entra numa nova fase estratégica, preparada para reinventar novamente o conceito de casa inteligente.","url":"/2026/03/06/estudiop/noticia/nova-robotica-domestica-2166762","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"iRobot","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2071580?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/03/06/estudiop/noticia/nova-robotica-domestica-2166762"},"id":2166762,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":17,"title":"Influenciadores: Agrupamento de Escolas do Restelo reforça controlo de entradas","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2072984?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19436,"nome":"João Pinhal","descricao":"","email":"joao.pinhal@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"joao-pinhal","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#108;&#97;&#104;&#110;&#105;&#112;&#46;&#111;&#97;&#111;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O director nega que o influenciador tenha actuado den