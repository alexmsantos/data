nguido com o Prémio de Reportagem Norberto Lopes da Casa da Imprensa 2011/2012, a reportagem “Uma geração a tentar sair de Gaza para dizer: sou de Gaza” com o Prémio de Jornalismo Direitos Humanos & Integração 2019 (imprensa escrita), e a cobertura das eleições alemãs de 2021 com o Prémio de Jornalismo Luso-Alemão 2022.","email":"maria.joao.guimaraes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"maria-joao-guimaraes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Maria_J_Guimaraes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737866?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#97;&#114;&#97;&#109;&#105;&#117;&#103;&#46;&#111;&#97;&#111;&#106;&#46;&#97;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Apesar da hesitação de Teerão, responsável do Paquistão diz que conta que a delegação iraniana esteja presente em Islamabad dentro de “24 a 48 horas”.","url":"/2026/04/20/mundo/noticia/tregua-terminar-negociacoes-eua-irao-permanecem-incertas-2171901","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Médio Oriente","url":"https://www.publico.pt/2026/04/20/mundo/noticia/tregua-terminar-negociacoes-eua-irao-permanecem-incertas-2171901"},"id":2171901,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"Amnistia Internacional acusa líderes “predadores” de minarem o direito internacional","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2082730?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6310,"nome":"Inês Chaíça","descricao":"","email":"ines.chaica@publico.pt","facebook":null,"googlePlus":null,"twitt