a-carmo","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#109;&#114;&#97;&#99;&#46;&#97;&#108;&#101;&#105;&#110;&#97;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Solução para oncologia teve efeito limitado no tempo e as medidas para aumentar cobertura de médicos de família falharam. Médico que coordenou a monitorização do PETS defende plano de emergência 2.0.","url":"/2026/05/29/sociedade/noticia/plano-emergencia-saude-maioria-medidas-estao-concluidas-impacto-reduzido-2176395","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Saúde","url":"https://www.publico.pt/2026/05/29/sociedade/noticia/plano-emergencia-saude-maioria-medidas-estao-concluidas-impacto-reduzido-2176395"},"id":2176395,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"A transição para a mobilidade eléctrica pode ser simples?","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2089908?tp=UH&db=IMAGENS&type=PNG","author":[],"shares":0,"description":"Mudar de um veículo a combustão para um automóvel 100% eléctrico ainda levanta algumas hesitações.  A melhor forma de desconstruir mitos é levar a tecnologia para a rua e testá-la num cenário real.","url":"/2026/05/21/estudiop/noticia/transicao-mobilidade-electrica-simples-2175512","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"HYUNDAI","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2089885?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/05/21/estudiop/noticia/transicao-mobilidade-electrica-simples-2175512"},"id":2175512,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":9,"title":"Foguetão da Blue Origin explode na plataforma de lançamento","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2091840?tp=U