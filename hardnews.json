[{"pos":0,"title":"Dirigente do 1143 acusa deputado do Chega de comprar votos a membros do grupo neonazi","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2068917?tp=UH&db=IMAGENS&type=JPG","author":[{"id":18035,"nome":"Miguel Carvalho","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"miguel-carvalho","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"O deputado do Chega Rui Afonso, líder distrital do partido no Porto, é suspeito de inscrever elementos do movimento neonazi 1143 e comprar votos para disputas eleitorais internas.","url":"/2026/02/22/politica/noticia/dirigente-1143-acusa-deputado-chega-comprar-votos-membros-grupo-neonazi-2165563","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Política","url":"https://www.publico.pt/2026/02/22/politica/noticia/dirigente-1143-acusa-deputado-chega-comprar-votos-membros-grupo-neonazi-2165563"},"id":2165563,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":1,"title":"“O mobiliário urbano deve valorizar a cidade e promover qualidade de vida”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2065788?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Com mais de mil faces digitais instaladas em Portugal e uma presença consolidada nas principais metrópoles globais, a JCDecaux está a transformar a paisagem das nossas cidades.","url":"/2026/02/18/estudiop/noticia/mobiliario-urbano-instrumento-valorizacao-cidade-qualidade-vida-2164147","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"JC DECAUX","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2065751?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/02/18/estudiop/noticia/mobiliario-urbano-instrumento-valorizacao-cidade-qualidade-vida-2164147"},"id":2164147,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":2,"title":"Luís Neves: um polícia que joga com garra e chega a ministro","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2068882?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1050,"nome":"Mariana Oliveira","descricao":"Nasci no Porto em 1978 e fiz a licenciatura em Direito na Faculdade de Direito da Universidade do Porto. Quando optei por este curso, já tinha a intenção de me tornar jornalista, seguindo o conselho de alguns profissionais da classe. Depois de terminar a licenciatura, candidatei-me à Formação Geral – Especialização em Jornalismo no Centro Protocolar de Formação Profissional para Jornalistas (Cenjor), em Lisboa. Por isso vivi na capital quase oito meses, entre Dezembro de 2001 e Julho de 2002. Nesse mês, decidi regressar ao Porto para fazer o estágio integrado nessa formação. Fui jornalista estagiária no PÚBLICO entre Julho e Outubro e comecei a trabalhar em Fevereiro de 2003. No início, cobri mais intensivamente áreas ligadas à protecção civil. Actualmente, dedico-me à área da Justiça.","email":"meoliveira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"mariana-oliveira","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#118;&#105;&#108;&#111;&#101;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Com 30 anos na PJ e um percurso ligado ao combate ao crime violento e ao terrorismo, Luís Neves troca a direcção da Judiciária pelo Ministério da Administração Interna.","url":"/2026/02/21/sociedade/noticia/luis-neves-policia-joga-garra-chega-ministro-2165599","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubr