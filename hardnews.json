lina.amado@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"carolina-amado","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#100;&#97;&#109;&#97;&#46;&#97;&#110;&#105;&#108;&#111;&#114;&#97;&#99;","contribuicao":"","tipo":"INTERNO"},{"id":6310,"nome":"Inês Chaíça","descricao":"","email":"ines.chaica@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ines-chaica","imagem":{"w":null,"h":null,"largura":544,"altura":459,"nome":"Inês_profile_pic-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/2003976?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#99;&#105;&#97;&#104;&#99;&#46;&#115;&#101;&#110;&#105;","contribuicao":"","tipo":"INTERNO"},{"id":17560,"nome":"Leonor Alhinho","descricao":"","email":"leonor.alhinho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"leonor-alhinho","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#110;&#105;&#104;&#108;&#97;&#46;&#114;&#111;&#110;&#111;&#101;&#108;","contribuicao":"","tipo":"INTERNO"},{"id":4038,"nome":"João Pedro Pincha","descricao":"Se não tivesse passado seis meses em Barcelona, provavelmente nunca me teria interessado por escrever sobre Lisboa. Foi na Catalunha que descobri, enquanto estagiava na televisão local, que a esquina mais próxima pode ser tão interessante como o outro lado do mundo. Meses depois, quando entrei no PÚBLICO pela primeira vez, já só queria estagiar na secção Local. E assim me iniciei a acompanhar tudo o que se passava na capital. Ainda passei brevemente pelo <i>O Corvo</i> antes de ajudar a fundar o <i>Observador</i>, onde estive quase três anos. Depois de cinco anos a acompanhar para o PÙBLICO a actualidade lisboeta e arredores, escrevo agora para a secção Mundo.","email":"joao.pincha@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"joao-pedro-pincha","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Joao P Pincha.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1332529?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#104;&#99;&#110;&#105;&#112;&#46;&#111;&#97;&#111;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Dois fortes sismos atingiram a Venezuela na quarta-feira. Estão confirmados 188 mortos e mais de 1500 feridos. Autoridades estimam subida do número de vítimas.","url":"/2026/06/25/mundo/noticia/sismo-venezuela-ja-governo-nao-conhecimento-vitimas-portuguesas-2179391","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Ao Minuto","url":"https://www.publico.pt/2026/06/25/mundo/noticia/sismo-venezuela-ja-governo-nao-conhecimento-vitimas-portuguesas-2179391"},"id":2179391,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"Vai de férias? Jogue pelo seguro e proteja a sua casa","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2092491?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Na altura em que se registam mais ocorrências e sinais de alarme, a líder em segurança profissional monitorizada partilha recomendações para preparar a casa antes da partida e durante as férias.","url":"/2026/06/11/estudiop/noticia/vai-ferias-jogue-seguro-proteja-casa-2176760","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Verisure","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2094800?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/11/estudiop/noticia/vai-ferias-jogue-seguro-proteja-casa-2176760"},"id":2176760,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Filipe Rosas: “Estes dois sismos são intrigantes”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098194?tp=UH&db=IMAGENS&type=JPG","author":[{"id":130,"nome":"Teresa Firmino","descricao":"O homem já tinha ido à Lua há décadas, mas o fax da NASA nunca mais chegava. Tinha acabado o curso de Comunicação Social na Universidade Nova de Lisboa em 1992 e descobria no PÚBLICO o jornalismo de ciência. A Internet não tinha entrado nas nossas vidas, por isso a maneira rápida de receber a imagem (esquemática) de um robô da NASA, que ia simular na Antárctida a exploração do ambiente de Marte, era por fax. Desses tempos distantes mantém-se o gosto pelo jornalismo de ciência, tal como pela aventura que a história desse robô continha. Outras aventuras levaram-me ao mar dos Açores, para acompanhar, aí sim, de perto, o mergulho de um robô submarino, ou à Antárctida com cientistas portugueses. Pelo meio, uma pausa nos EUA, entre 2008-2009, com a bolsa Knight para jornalistas de ciência no MIT.","email":"teresa.firmino@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editora de ciência","profissaoNaAltura":"Editora de ciência","slug":"teresa-firmino","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Teresa_Firmino.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737916?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#105;&#109;&#114;&#105;&#102;&#46;&#97;&#115;&#101;&#114;&#101;&#116;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Geólogo da Faculdade de Ciências da Universidade de Lisboa explica as particularidades dos dois sismos na Venezuela. Não se tratou de um sismo e da sua réplica, foi outra coisa.","url":"/2026/06/25/ciencia/noticia/filipe-rosas-dois-sismos-sao-intrigantes-2179489","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Venezuela","url":"https://www.publico.pt/2026/06/25/ciencia/noticia/filipe-rosas-dois-sismos-sao-intrigantes-2179489"},"id":2179489,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"Prestação Social Única: quem terá direito, quanto poderá receber e o que muda","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098067?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3898,"nome":"Liliana Borges","descricao":"","email":"liliana.borges@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"liliana-pascoal-borges","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"liliana-borges.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1172095?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#103;&#114;&#111;&#98;&#46;&#97;&#110;&#97;&#105;&#108;&#105;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Parlamento aprova nesta quinta-feira a nova Prestação Social Única, que junta 13 apoios sociais 