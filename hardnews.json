8338,"nome":"Rita Caetano","descricao":"","email":"rscaetano@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"rita-caetano","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#97;&#116;&#101;&#97;&#99;&#115;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Crise em Cuba leva ao cancelamento das viagens turísticas a partir de Portugal. Os operadores e as agências propõem destinos alternativos ou o reembolso para quem já comprou os pacotes.","url":"/2026/02/21/fugas/noticia/cuba-desaparece-mapa-operadores-agencias-viagens-portugal-2165312","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Viagens","url":"https://www.publico.pt/2026/02/21/fugas/noticia/cuba-desaparece-mapa-operadores-agencias-viagens-portugal-2165312"},"id":2165312,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Eleitores de Cotrim e Mendes escolheram Seguro na segunda volta por larga margem","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2068846?tp=UH&db=IMAGENS&type=JPG","author":[{"id":18463,"nome":"Susete Francisco","descricao":"","email":"susete.francisco@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"susete-francisco","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#99;&#115;&#105;&#99;&#110;&#97;&#114;&#102;&#46;&#101;&#116;&#101;&#115;&#117;&#115;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Ventura saiu das eleições a reclamar-se líder da direita, mas o eleitorado deste espectro político que voltou às urnas e optou por um dos candidatos preferiu António José Seguro.","url":"/2026/02/22/politica/noticia/eleitores-cotrim-mendes-escolheram-seguro-segunda-volta-larga-margem-2165586","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Presidenciais 2026","url":"https://www.publico.pt/2026/02/22/politica/noticia/eleitores-cotrim-mendes-escolheram-seguro-segunda-volta-larga-margem-2165586"},"id":2165586,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"“A nossa incapacidade de prevenir não é deste Governo, nem do anterior, é histórica”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2068799?tp=UH&db=IMAGENS&type=JPG","author":[{"id":204,"nome":"Andrea Cunha Freitas","descricao":"Tenho uma licenciatura em Jornalismo Internacional e sou jornalista no PÚBLICO desde 1997. Trabalhei na secção do Local e da Sociedade, onde fui editora. Desde 2016 sou jornalista na secção de Ciência.","email":"acfreitas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"andrea-cunha-freitas","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#105;&#101;&#114;&#102;&#99;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Miguel Bastos Araújo faz sobretudo uma reflexão crítica sobre as falhas de um país que reage tarde e mal. É preciso apostar na profissionalização, diz, colocando de lado o debate da regionalização.","url":"/2026/02/22/azul/entrevista/incapacidade-prevenir-nao-governo-anterior-historica-2165250","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista com Miguel Bastos Araújo","url":""},"id":2165250,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Comissão de racismo: presidente diz que não pode contratar, AR alega que nada impede","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2068613?tp=UH&db=IMAGENS&type=JPG","author":[{"id":455,"nome":"Joana Gorjão Henriques","descricao":"Entrei para o PÚBLICO no final de 1999, para estagiar na Cultura, onde fiquei durante dez anos. Entre fim de 2009 e de 2011 fiz uma pausa de dois anos, primeiro para ser bolseira da Nieman Foundation for Journalism na Universidade de Harvard, EUA; e depois para estudar Sociologia na London School of Economics, em Londres. Integro a secção de Sociedade, escrevendo sobre temas ligados a imigração, racismo, direitos humanos. Sou autora de 3 séries que deram livros: Racismo em português, sobre o racismo durante o sistema colonial, Racismo à Portuguesa, retrato de desigualdades raciais em Portugal e Colonos em Angola e Moçambique. Retornados em Portugal, que deu também origem ao documentário Racismo, uma descolonização em curso. Recebi a medalha de ouro de Direitos Humanos da Assembleia da República e alguns prémios: o Prémio Gazeta duas vezes, o Prémio AMI - Jornalismo contra a Indiferença por duas vezes, o prémio de Jornalismo de imprensa escrita de Direitos Humanos e Integração, da Comissão Nacional da UNESCO por duas vezes, o prémio de imprensa escrita Comunicação \"Pela Diversidade Cultural\" do Alto Comissariado para as Migrações, também por duas vezes, o prémio de jornalismo Corações com Coroa duas vezes, o prémio Os Direitos da Criança em Notícia  e fiquei na lista final dos prémio ibero-americanos da Fundação Gabo.","email":"jgh@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"joana-gorjao-henriques","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#104;&#103;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Presidente defende que precisa de diploma para contratar quem tramite as queixas: há pelo menos 23 na gaveta. Secretária-geral da AR diz que “repetidamente” a avisou que nada impede contratação.","url":"/2026/02/21/sociedade/noticia/bloqueio-comissao-racismo-presidente-nao-contratar-ar-alega-ja-nada-impede-2165484","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Racismo","url":"https://www.publico.pt/2026/02/21/sociedade/noticia/bloqueio-comissao-racismo-presidente-nao-contratar-ar-alega-ja-nada-impede-2165484"},"id":2165484,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"Evaya, Nunca Mates o Mandarim, Marquise e Dinis Mota na final do Festival da Canção","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2068891?tp=UH&db=IMAGENS&type=PNG","author":[{"id":6858,"nome":"Rodrigo Nogueira","descricao":"","email":"rodrigo.nogueira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"rodrigo-nogueira","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#117;&#103;&#111;&#110;&#46;&#111;&#103;&#105;&#114;&#100;&#111;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"A primeira semifinal decorreu este sábado à noite em directo dos estúdios da Valentim de Carvalho, em Paço de Arcos.","url":"/2026/02/22/culturaipsilon/noticia/evaya-mates-mandarim-marquise-dinis-mota-final-festival-cancao-2165602","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Festival da Canção","url":"https://www.publico.pt/2026/02/22/culturaipsilon/noticia/evaya-mates-mandarim-marquise-dinis-mota-final-festival-cancao-2165602"},"id":2165602,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":9,"title":"Noreena Hertz: “Estamos a assistir à substituição de pessoas por <i>cha