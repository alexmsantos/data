mail":"leonor.alhinho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"leonor-alhinho","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#110;&#105;&#104;&#108;&#97;&#46;&#114;&#111;&#110;&#111;&#101;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O casal estava desaparecido há uma semana, depois de ambos terem saído de casa para uma consulta da qual nunca regressaram. O carro foi encontrado nesta manhã.","url":"/2026/02/18/sociedade/noticia/encontrados-dois-corpos-dentro-carro-casal-desaparecido-montemorovelho-2165139","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Mau tempo","url":"https://www.publico.pt/2026/02/18/sociedade/noticia/encontrados-dois-corpos-dentro-carro-casal-desaparecido-montemorovelho-2165139"},"id":2165139,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"Mau tempo: valor médio do apoio à recuperação de casas ultrapassa 5900 euros","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2067997?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3150,"nome":"Raquel Martins","descricao":"Aos 15 anos decidi que queria mudar o mundo e, para desgosto da minha professora de Português, quis ser jornalista. Fiz o curso de Ciências da Comunicação na Universidade Nova, frequentei o Cenjor e andei indecisa entre a rádio e a imprensa. Depois de uma breve passagem pela rádio (Antena 3 e Rádio Expo), acabei por entrar no jornalismo económico um pouco por acaso. Primeiro, no Diário Económico – onde escrevi sobre ambiente, autarquias, política e, mais tarde, sobre trabalho e função pública – depois no Jornal de Negócios. Foi por isso que, em 2009, fiz uma formação na Universidade Católica sobre legislação laboral. Estou no PÚBLICO desde 2010. Acompanho os assuntos relacionados com trabalho, emprego e administração pública (há quem diga, com humor, que o Código do Trabalho é o meu livro de cabeceira.) Defendo que o jornalismo tem um papel cada vez mais importante na descodificação da avalanche de informação que todos os dias circula nas mais diversas plataformas.","email":"raquel.martins@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"raquel-martins","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"raquel-martins-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1991256?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Debi Thomas","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#110;&#105;&#116;&#114;&#97;&#109;&#46;&#108;&#101;&#117;&#113;&#97;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Até agora foram recebidas 12.625 candidaturas à recuperação de casas destruídas pelas tempestades.","url":"/2026/02/18/economia/noticia/valor-medio-apoio-recuperacao-casas-ultrapassa-5900-euros-2165169","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Tempestade Kristin","url":"https://www.publico.pt/2026/02/18/economia/noticia/valor-medio-apoio-recuperacao-casas-ultrapassa-5900-euros-2165169"},"id":2165169,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Seguro sempre defendeu a regionalização mas não dá passo em frente","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2067777?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19357,"nome":"Filipe Santa-Bárbara","descricao":"","email":"filipe.santabarbara@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"filipe-santabarbara","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#97;&#98;&#114;&#97;&#98;&#97;&#116;&#110;&#97;&#115;&#46;&#101;&#112;&#105;&#108;&#105;&#102;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Posição histórica do Presidente eleito é pró-regionalização, mas nunca deu passo para que se concretize. Com debate a reacender, Seguro parece estar em sintonia com Montenegro no travão ao processo.","url":"/2026/02/18/politica/noticia/seguro-defendeu-regionalizacao-nao-passo-frente-2165063","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Regionalização","url":"https://www.publico.pt/2026/02/18/politica/noticia/seguro-defendeu-regionalizacao-nao-passo-frente-2165063"},"id":2165063,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"UGT rejeita participar em reunião depois de convocatória “extemporânea” do Governo","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2067968?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1068,"nome":"Luís Villalobos","descricao":"Comecei a trabalhar como jornalista profissional em 1992, na secção de economia do Semanário. Em 1994 apostei na vida de free-lancer, enquanto frequentava o curso de História, tendo colaborado para vários jornais e revistas. Em 2000 entrei para a revista Fortuna, da qual já era colaborador. Três anos depois tive a minha estreia nos diários, no Diário Económico, de onde transitei como editor para a Exame no final de 2005. Em 2007, cheguei ao PÚBLICO, para editar o suplemento de Economia. Actualmente, sou redactor da secção. Ganhei três prémios, o último dos quais na categoria nacional de imprensa e online do Ano Europeu do Combate à Pobreza e Exclusão Social. Sou co-autor do livro, “Negócios Vigiados”, sobre a PIDE e as empresas, e coordenei a 