pre participando em outras áreas do jornal, com trabalhos para o P2 ou a Pública (que, entretanto, terminaram), a Fugas ou, mais recentemente, a revista 2.","email":"patricia.carvalho@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"patricia-carvalho","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Patricia Carvalho.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1381570?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#104;&#108;&#97;&#118;&#114;&#97;&#99;&#46;&#97;&#105;&#99;&#105;&#114;&#116;&#97;&#112;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Cursos no ensino superior têm crescido, mas ainda atraem poucas pessoas. O maior problema é ao nível do pessoal auxiliar: com mão-de-obra escassa, a disponibilidade para formação é quase inexistente.","url":"/2026/03/22/sociedade/noticia/cursos-trabalhar-idosos-existem-procura-andamos-dormir-ha-anos-2166973","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Envelhecimento populacional","url":"https://www.publico.pt/2026/03/22/sociedade/noticia/cursos-trabalhar-idosos-existem-procura-andamos-dormir-ha-anos-2166973"},"id":2166973,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":28,"title":"Marcha pela Vida em Lisboa atingida por objecto incendiário","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2076163?tp=UH&db=IMAGENS&type=JPG","author":[{"id":90,"nome":"Lusa","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"lusa","imagem":null,"hasImage":false,"isExternal":false,"enco