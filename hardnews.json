ito.","url":"/2026/03/25/impar/noticia/cinco-destaques-nostalgia-regresso-miley-cyrus-hannah-montana-2169063","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"Celebridades","url":"https://www.publico.pt/2026/03/25/impar/noticia/cinco-destaques-nostalgia-regresso-miley-cyrus-hannah-montana-2169063"},"id":2169063,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":28,"title":"Novo Opel Astra: continuidade com substância e equilíbrio alemão","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2076217?tp=UH&db=IMAGENS&type=JPG","author":[{"id":7156,"nome":"Pedro Esteves","descricao":"Durante 20 anos fui profissional de saúde, professor, locutor de rádio (TSF) e televisão. Fiz parte da equipa que fundou o Observador, onde falei de música e de tecnologia em formato multimédia. O desafio? Continuar a fazer do PÚBLICO um meio digital de referência.","email":"pesteves@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista e editor online","profissaoNaAltura":"","slug":"pmesteves","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Pedro_Ferreira_Esteves.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1202816?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#118;&#101;&#116;&#115;&#101;&#112;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Já conduzimos os novos Opel Astra, automóveis “<em>made in Germany</em>” de design elegante e comportamento exemplar no segmento. Mas o mais interessante acabou por ser a condução nocturna.","url":"/2026/03/25/fugas/noticia/novo-opel-astra-continuidade-substancia-equilibrio-alemao-2168766","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Motores - Novidade","url":"https://www.publico.pt/2026/03/25/fugas/noticia/novo-opel-astra-continuidade-substancia-equilibrio-alemao-2168766"},"id":2168766,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":29,"title":"Carneiro chama Carlos Tavares e Costa Silva ao congresso para pensar programa do PS","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2076564?tp=UH&db=IMAGENS&type=JPG","author":[{"id":330,"nome":"São José Almeida","descricao":"Estagiária da fundação do PÚBLICO, integro a secção de Política. Desde 1990 acompanho a vida política com a preocupação de uma visão cultural da política. A minha prova de fogo foi o acompanhamento da dissidência do PCP de 1990 a 1994. Seguiu-se a transformação do CDS em PP. Fui repórter parlamentar entre 1995 e 2005. Editei a secção de Nacional de\r\n2005 a 2007. Sou redactora principal desde 2007. Recebi alguns prémios de jornalismo, como o “Pela diversidade. Contra a discriminação” da Comissão Europeia, em 2009. Dos prémios, destaco o primeiro dos dois que recebi da ILGA, em 2006,atribuído por ter introduzido a defesa dos direitos de identidade de gays, lésbicas, transexuais, transgéneros e intersexuais na agenda do jornalismo político português. Desde 2005 que assino a crónica A Semana Política.","email":"sao.jose.almeida@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Redactora principal","profissaoNaAltura":"Redactora principal","slug":"sao-jose-almeida","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"sao-jose-almeida-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1739852?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#100;&#105;&#101;&#109;&#108;&#97;&#46;&#101;&#115;&#111;&#106;&#46;&#111;&#97;&#115;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"PS leva independentes ao congresso para renovar ligação com a sociedade e preparar as propostas para a governação do país que os socialistas querem apresentar nas próximas legislativas.","url":"/2026/03/25/politica/noticia/carneiro-chama-carlos-tavares-costa-silva-congresso-pensar-programa-eleitoral-ps-2168950","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"25.º Congresso do PS","url":"https://www.publico.pt/2026/03/25/politica/noticia/carneiro-chama-carlos-tavares-costa-silva-congresso-pensar-programa-eleitoral-ps-2168950"},"id":2168950,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30}]
