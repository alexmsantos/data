[{"pos":0,"title":"Exames: “Este processo não tem ponta por onde se lhe pegue”, criticam alunos","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2105031?tp=UH&db=IMAGENS&type=JPG","author":[{"id":120,"nome":"Sandra Silva Costa","descricao":"Nunca fui bairrista mas também nunca fui de renegar as origens: nasci numa aldeia, Maceda, no concelho de Ovar, e lá vivi até aos 20 anos, mais coisa menos coisa. Nessa altura já estudava Jornalismo, na Universidade de Coimbra. Entrei para o PÚBLICO aos 22, tinha cabelos curtos e um mar de sonhos na cabeça. Vim estagiar, com experiência quase zero — mas justiça seja feita ao Jornal de Ovar, que me deu a primeira oportunidade, ainda nos tempos da faculdade. Estágio cumprido, integrei a secção de Educação, na altura uma editoria autónoma. Estávamos em 1998. Passei ainda pela Sociedade, como jornalista e como editora, até que, em 2008, assumi a edição da Fugas, onde fiquei até Dezembro de 2024. Em Janeiro de 2025, integrei a equipa do Local Porto.","email":"scosta@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"sandra-silva-costa","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"sc.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1091354?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#116;&#115;&#111;&#99;&#115;","contribuicao":"texto","tipo":"INTERNO"},{"id":3983,"nome":"Rui Gaudêncio","descricao":"","email":"rgaudencio@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"rui-gaudencio","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#