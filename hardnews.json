[{"pos":0,"title":"Trump exige entrega de urânio e reabertura de Ormuz para manter trégua","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2080051?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1083,"nome":"Ana Brito","descricao":"","email":"ana.brito@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ana-brito","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#116;&#105;&#114;&#98;&#46;&#97;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Ataques de Israel ao Líbano são violação do cessar-fogo, diz o Irão, que voltou a ameaçar os navios que queiram passar pelo estreito de Ormuz. Casa Branca garante que o Líbano não faz parte do acordo.","url":"/2026/04/08/mundo/noticia/trump-exige-entrega-uranio-reabertura-ormuz-manter-tregua-2170582","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Médio Oriente","url":"https://www.publico.pt/2026/04/08/mundo/noticia/trump-exige-entrega-uranio-reabertura-ormuz-manter-tregua-2170582"},"id":2170582,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":1,"title":"Três discursos, 14 promulgações e algumas “observações”: um mês de Seguro em Belém","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2079970?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3898,"nome":"Liliana Borges","descricao":"","email":"liliana.borges@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"liliana-pascoal-borges","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"liliana-borges.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1172095?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#103;&#114;&#111;&#98;&#46;&#97;&#110;&#97;&#105;&#108;&#105;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Um mês depois de assumir o cargo de Presidente da República, e ainda com muitas cadeiras vazias por ocupar na sua equipa em Belém, António José Seguro tem feito por cumprir os compromissos assumidos.","url":"/2026/04/08/politica/noticia/tres-discursos-14-promulgacoes-observacoes-mes-seguro-belem-2170580","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Presidente da República","url":"https://www.publico.pt/2026/04/08/politica/noticia/tres-discursos-14-promulgacoes-observacoes-mes-seguro-belem-2170580"},"id":2170580,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":2,"title":"Trump estará a pensar punir países da NATO que não apoiaram guerra contra o Irão","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2080072?tp=UH&db=IMAGENS&type=JPG","author":[{"id":4038,"nome":"João Pedro Pincha","descricao":"Se não tivesse passado seis meses em Barcelona, provavelmente nunca me teria interessado por escrever sobre Lisboa. Foi na Catalunha que descobri, enquanto estagiava na televisão local, que a esquina mais próxima pode ser tão interessante como o outro lado do mundo. Meses depois, quando entrei no PÚBLICO pela primeira vez, já só queria estagiar na secção Local. E assim me iniciei a acompanhar tudo o que se passava na capital. Ainda passei brevemente pelo <i>O Corvo</i> antes de ajudar a fundar o <i>Observador</i>, onde estive quase três anos. Depois de cinco anos a acompanhar para o PÙBLICO a actualidade lisboeta e arredores, escrevo agora para a secção Mundo.","email":"joao.pincha@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissao