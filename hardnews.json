ull,"brand":null,"rubric":{"name":"PTRR","url":"https://www.publico.pt/2026/02/25/politica/noticia/montenegro-ptrr-nao-poe-contas-publicas-causa-nao-exclui-defice-2166071"},"id":2166071,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"Benfica fora da Champions, Vinicius Jr. voltou a dançar","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2069845?tp=UH&db=IMAGENS&type=JPG","author":[{"id":206,"nome":"Marco Vaza","descricao":"O desporto tem vencedores e perdedores, heróis e vilões e a história nem sempre é sobre o que ganha. Eu escrevo sobre aquele que marca o golo decisivo, sobre aquele que corre mais do que os outros, sobre aquele que não desiste ou sobre aquele que desistiu quando estava perto do fim. Já assisti ao vivo a grandes goleadas, recordes do mundo, estreias de futuras estrelas e despedidas de mitos. Entrei no PÚBLICO como estagiário em 1999 para a secção de Desporto, onde continuo, depois de uma comissão entre 2006 e 2009 como editor da revista de domingo. Para além de centenas de jogos de futebol, já estive em duas edições dos Jogos Olímpicos (Atenas 2004 e Londres 2012), numa edição dos Mundiais de atletismo (Helsínquia 2005) e noutras competições de muitas modalidades. O desporto dos outros é a minha profissão.","email":"mvaza@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"marco-vaza","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Marco_Vaza.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737861?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#122;&#97;&#118;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Real Madrid segue para os oitavos-de-final da Liga dos Campeões após triunfo no Bernabéu por 2-1. Rafa ainda deixou os “encarnados” a ganhar durante dois minutos.","url":"/2026/02/25/desporto/cronica_de_jogo/benfica-champions-vinicius-volta-dancar-2166079","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Crónica de jogo","url":"/futebol0"},"id":2166079,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"Borussia e Juventus eliminados da Liga dos Campeões, PSG escapa","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2069844?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6030,"nome":"Augusto Bernardino","descricao":"","email":"augusto.bernardino@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"augusto-bernardino","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#110;&#105;&#100;&#114;&#97;&#110;&#114;&#101;&#98;&#46;&#111;&#116;&#115;&#117;&#103;&#117;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Formação de Turim anulou desvantagem de três golos, mas, com menos um jogador desde o início da segunda parte, estourou no prolongamento.","url":"/2026/02/25/desporto/noticia/liga-campeoes-juventus-borussia-eliminados-psg-escapa-2166076","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Futebol internacional","url":"https://www.publico.pt/2026/02/25/desporto/noticia/liga-campeoes-juventus-borussia-eliminados-psg-escapa-2166076"},"id":2166076,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Cuba diz ter matado quatro pessoas em tiroteio provocado por lancha registada nos EUA","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2069839?tp=UH&db=IMAGENS&type=JPG","author":[{"id":890,"nome":"Reuters","de