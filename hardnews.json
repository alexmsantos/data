comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Prestação Social Única","url":"https://www.publico.pt/2026/06/25/politica/noticia/contrarelogio-duas-reunioes-bastaram-governo-alinhar-ps-garantir-psu-2179502"},"id":2179502,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"Arranque atribulado no Festival Babell leva organização a arranjar sessão especial","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2098233?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19703,"nome":"Luís Ricardo Duarte","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"luis-ricardo-duarte","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Atrasos e problemas com a tradução simultânea marcaram o início da primeira edição de um festival que quer celebrar o livro e a leitura.","url":"/2026/06/25/culturaipsilon/noticia/arranque-atribulado-festival-babell-leva-organizacao-arranjar-sessao-especial-2179476","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Livros","url":"https://www.publico.pt/2026/06/25/culturaipsilon/noticia/arranque-atribulado-festival-babell-leva-organizacao-arranjar-sessao-especial-2179476"},"id":2179476,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":4,"title":"Vai de férias? Jogue pelo seguro e proteja a sua casa","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2092491?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Na altura em que se registam mais ocorrências e sinais de alarme, a líder em segurança profissional monitorizada partilha recomendações para preparar a casa antes da partida e durante as férias.","url":"/2026/06/11/estudiop/noticia/vai-ferias-jogue-seguro-proteja-casa-2176760","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Verisure","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2094800?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/11/estudiop/noticia/vai-ferias-jogue-seguro-proteja-casa-2176760"},"id":2176760,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Idade média dos trabalhadores dos registos e dos docentes agrava-se em 2025","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098246?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3150,"nome":"Raquel Martins","descricao":"Aos 15 anos decidi que queria mudar o mundo e, para desgosto da minha professora de Português, quis ser jornalista. Fiz o curso de Ciências da Comunicação na Universidade Nova, frequentei o Cenjor e andei indecisa entre a rádio e a imprensa. Depois de uma breve passagem pela rádio (Antena 3 e Rádio Expo), acabei por entrar no jornalismo económico um pouco por acaso. Primeiro, no Diário Económico – onde escrevi sobre ambiente, autarquias, política e, mais tarde, sobre trabalho e função pública – depois no Jornal de Negócios. Foi por isso que, em 2009, fiz uma formação na Universidade Católica sobre legislação laboral. Estou no PÚBLICO desde 2010. Acompanho os assuntos relacionados com trabalho, emprego e administração pública (há quem diga, com humor, que o Código do Trabalho é o meu livro de cabeceira.) Defendo que o jornalismo tem um papel cada vez mais importante na descodificação da avalanche de informação que todos os dias circula nas mais diversas plataformas.","email":"raquel.martins@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"raquel-martins","imagem":{"w":225,"h":225,"largura":225,"altura":225,"nome":"raquel-martins-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1991256?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Debi Thomas","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#110;&#105;&#116;&#114;&#97;&#109;&#46;&#108;&#101;&#117;&#113;&#97;&#114;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Entre 2011 e 2025, a média etária dos trabalhadores dos Estado agravou-se. O número de dirigentes atingiu níveis máximos e as prestações de serviços recuaram.","url":"/2026/06/25/economia/noticia/idade-media-trabalhadores-registos-docentes-agravase-2025-2179517","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Função Pública","url":"https://www.publico.pt/2026/06/25/economia/noticia/idade-media-trabalhadores-registos-docentes-agravase-2025-2179517"},"id":2179517,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"Gonzalo Plata foi ouro para o Equador frente à Alemanha","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2098259?tp=UH&db=IMAGENS&type=JPG","author":[{"id":206,"nome":"Marco Vaza","descricao":"O desporto tem vencedores e perdedores, heróis e vilões e a história nem sempre é sobre o que ganha. Eu escrevo sobre aquele que marca o golo decisivo, sobre aquele que corre mais do que os outros, sobre aquele que não desiste ou sobre aquele que desistiu quando estava perto do fim. Já assisti ao vivo a grandes goleadas, recordes do mundo, estreias de futuras estrelas e despedidas de mitos. Entrei no PÚBLICO como estagiário em 1999 para a secção de Desporto, onde continuo, depois de uma comissão entre 2006 e 2009 como editor da revista de domingo. Para além de centenas de jogos de futebol, já estive em duas edições dos Jogos Olímpicos (Atenas 2004 e Londres 2012), numa edição dos Mundiais de atletismo (Helsínquia 2005) e noutras competições de muitas modalidades. O desporto dos outros é a minha profissão.","email":"mvaza@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"marco-vaza","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Marco_Vaza.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737861?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#122;&#97;&#118;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Um golo do ex-Sporting valeu aos sul-americanos um triunfo de reviravolta por 2-1 sobre os germânicos e a continuidade no Mundial 2026.","url":"/2026/06/25/desporto/noticia/gonzalo-plata-ouro-equador-frente-alemanha-2179525","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Futebol","url":"https://www.publico.pt/2026/06/25/desporto/noticia/gonzalo-plata-ouro-equador-frente-alemanha-2179525"},"id":2179525,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Lisboa debate futuro da economia sustentável","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2096801?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Lisboa volta a reunir o mundo da sustentabilidade.","url":"/2026/06/19/estudiop/noticia/lisboa-debate-futuro-economia-sustentavel-2178813","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Sustainability Week 2026","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2096797?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/06/19/estudiop/noticia/lisboa-debate-futuro-economia-sustentavel-2178813"},"id":2178813,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{