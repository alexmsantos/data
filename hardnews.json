lse,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#103;&#114;&#111;&#98;&#46;&#97;&#110;&#97;&#105;&#108;&#105;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"O chefe de Estado destacou a convergência entre os dois países no plano europeu e internacional, sublinhando também o apoio espanhol à candidatura portuguesa ao Conselho de Segurança da ONU.","url":"/2026/04/20/politica/noticia/seguro-ve-convergencia-essencial-pede-parceria-estrategica-madrid-2171907","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Diplomacia","url":"https://www.publico.pt/2026/04/20/politica/noticia/seguro-ve-convergencia-essencial-pede-parceria-estrategica-madrid-2171907"},"id":2171907,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":5,"title":"Ricardo Araújo Pereira: “Eu recomendo auto-estima baixa a toda a gente”","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/canal_videos/videoPortal/Images/202604/thumb_semtexto_video_opcao297828.jpg?tp=VIDEOS","author":[{"id":281,"nome":"Ana Sá Lopes","descricao":"Sempre quis ser jornalista, ao mesmo tempo que automobilista de Fórmula 1 (não tenho carta de condução) e arqueóloga, por causa de Michel Vaillant e Blake e Mortimer. Acabei por começar a escrever coisas no jornal da terra onde vivi desde criança, a Gazeta das Caldas, de Caldas da Rainha. Como toda a minha geração de jornalistas, andei pelas rádios piratas, a Rádio Litoral Oeste e a Rádio Margem. Concorri a um concurso de estagiários para o extinto semanário \"O Jornal\" e para meu júbilo fui uma das seleccionadas. Fui muito feliz por lá, como na fundação do PÚBLICO, um momento transcendental na vida de todos os que passámos por isso. No PÚBLICO trabalhei essencialmente na secção política, fui jornalista parlamentar, \"fiz\" o PSD, umas reportagens razoáveis em Angola e Timor-Leste e fui durante uns anos editora de política. Saí do jornal no fim de 2005, passei dois anos no Diário de Notícias, onde fui redactora-principal e depois editora de política. Saí do DN em 2008 para fazer parte da equipa fundadora do i. No i fui directora adjunta de Janeiro de 2011 até à minha saída em  Julho de 2018, quando o director Manuel Carvalho me convidou para ser directora-adjunta do PÚBLICO. Com a remodelação da direcção editorial do PÚBLICO, passei a redactora principal em Setembro deste ano.","email":"ana.sa.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Redactora-principal","profissaoNaAltura":"Redactora-principal","slug":"ana-sa-lopes","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"ana-sa-lopes-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1739858?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Ana Sousa Dias","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#97;&#115;&#46;&#97;&#110;&#97;","contribuicao":null,"tipo":"INTERNO"},{"id":19752,"nome":"Tiago Orato","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"Sonoplasta","profissaoNaAltura":"Sonoplasta","slug":"tiago-orato","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":null,"tipo":"INTERNO"},{"id":16083,"nome":"Ana Zayara Coelho","descricao":"","email":"ana.zayara@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":null,"profissaoActual":"","profissaoNaAltura":"","slug":"ana-zayara-coelho","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#97;&#121;&#97;&#122;&#46;&#9