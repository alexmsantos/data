:"https://imagens.publico.pt/imagens.aspx/2092399?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6283,"nome":"Joana Lobo Antunes","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Cientista, comunicadora de ciência","profissaoNaAltura":"Cientista, comunicadora de ciência","slug":"joana-lobo-antunes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Joana_L_Antunes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1145238?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Como trabalham os cientistas em equipa? Como nascem as ideias, como se tratam os dados, como se decidem que é o autor? Conversámos com Guilherme Milhano, que trabalha em física de partículas.","url":"/2026/06/01/ciencia/depoimento/cientista-ilha-precisa-comunidade-2173809","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Depoimento","url":"/divulgacao-cientifica"},"id":2173809,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":21,"title":"Um filme que dificilmente irá para o top dos mais vistos, mas devia\r\n\r\n","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2091583?tp=UH&db=IMAGENS&type=JPG","author":[{"id":136,"nome":"Joana Amaral Cardoso","descricao":"Comecei na secção de Sociedade em 1999, dali fui para o Publico.pt e como colaboradora da revista Pública escrevi sobre tendências sociais e Manias. Em 2006 comecei a debruçar-me sobre uma das áreas que mais me interessam – o audiovisual. Depois, já na secção de Cultura, onde sou hoje jornalista, juntei a isto tudo a cultura popular, o cinema, a moda, o design e interesso-me em aplicar a lente do género a muitos fenómenos.  Em 2009 editei a secção de Televisão da revista TimeOut e mais recentemente dei aulas de Jornalismo de Moda. No Público também editei a secção da Cultura online, fui subeditora da revista Pública e co-editora da revista Fugas. E vejo demasiada televisão.","email":"joana.cardoso@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"joana-amaral-cardoso","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#115;&#111;&#100;&#114;&#97;&#99;&#46;&#97;&#110;&#97;&#111;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"<em>Espaço para Dançar</em> é um documentário feito ao longo de cinco anos sobre uma bailarina que está no espectro do autismo. A sua descoberta tornada <em> performance</em> é espaçosa.","url":"/2026/06/01/culturaipsilon/noticia/filme-dificilmente-ira-top-vistos-2176291","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Televisão","url":"https://www.publico.pt/2026/06/01/culturaipsilon/noticia/filme-dificilmente-ira-top-vistos-2176291"},"id":2176291,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"Casal comprou todas as casas de uma rua em Gaia. Agora quer remover moradores","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2092285?tp=UH&db=IMAGENS&type=JPG","author":[{"id":4119,"nome":"Camilo Soldado","descricao":"","email":"camilo.soldado@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"camilo-soldado","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#100;&#97;&#100;&#108;&#111;&#115;&#46;&#111;&#108;&#105;&#109;&#97;&#99;","contribuicao":"texto","tipo":"INTERNO"},{"id":3966,"nome":"Adriano Miranda","desc