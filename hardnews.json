4,"altura":320,"nome":"WhatsApp_Image_2023-02-01_at_13.49.04-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1775300?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#105;&#101;&#114;&#102;&#46;&#115;&#101;&#110;&#105;","contribuicao":"","tipo":"INTERNO"},{"id":19752,"nome":"Tiago Orato","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Sonoplasta","profissaoNaAltura":"","slug":"tiago-orato","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"edição e música","tipo":"INTERNO"}],"shares":0,"description":"No <i>podcast</i> <i>A Vida não É o Que Aparece</i> convidamos personalidades que têm uma profissão que também passa pelas redes sociais e percebemos que o que vemos é apenas uma amostra de tudo o que são e fazem.","url":"/2026/02/17/impar/podcast/matilde-breyner-perda-gestacional-vezes-senti-sozinha-2164744","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"Podcast","url":"/podcast-vida-n-q-aparece"},"id":2164744,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":23,"title":"“O trabalho doméstico corre sempre o risco de voltar a tornar-se invisível”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2065555?tp=UH&db=IMAGENS&type=JPG","author":[{"id":455,"nome":"Joana Gorjão Henriques","descricao":"Entrei para o PÚBLICO no final de 1999, para estagiar na Cultura, onde fiquei durante dez anos. Entre fim de 2009 e de 2011 fiz uma pausa de dois anos, primeiro para ser bolseira da Nieman Foundation for Journalism na Universidade de Harvard, EUA; e depois para estudar Sociologia na London School of Economics, em Londres. Integro a secção de Sociedade, escrevendo sobre temas ligados a imigração, racismo, direitos humanos. Sou autora de 3 séries que deram livros: Racismo em português, sobre o racismo durante o sistema colonial, Racismo à Portuguesa, retrato de desigualdades raciais em Portugal e Colonos em Angola e Moçambique. Retornados em Portugal, que deu também origem ao documentário Racismo, uma descolonização em curso. Recebi a medalha de ouro de Direitos Humanos da Assembleia da República e alguns prémios: o Prémio Gazeta duas vezes, o Prémio AMI - Jornalismo contra a Indiferença por duas vezes, o prémio de Jornalismo de imprensa escrita de Direitos Humanos e Integração, da Comissão Nacional da UNESCO por duas vezes, o prémio de imprensa escrita Comunicação \"Pela Diversidade Cultural\" do Alto Comissariado para as Migrações, também por duas vezes, o prémio de jornalismo Corações com Coroa duas vezes, o prémio Os Direitos da Criança em Notícia  e fiquei na lista final dos prémio ibero-americanos da Fundação Gabo.","email":"jgh@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"joana-gorjao-henriques","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#104;&#103;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Autora de um livro que se tornou uma referência sobre o trabalho doméstico feito por mulheres, Leopoldina Fortunati participou em Lisboa no encontro <i>Nós estamos contigo na casa</i>.","url":"/2026/02/17/sociedade/entrevista/leopoldina-fortunati-trabalho-domestico-corre-risco-voltar-tornarse-invisivel-ate-proprias-mulheres-2163620","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Entrevista","url":"/igualdade-genero"},"id":2163620,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":24,"title":"Como reduzir a solidão dos idosos nas cidades? É apostar em jardins de proximidade","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2067071?tp=UH&db=IMAGENS&type=JPG","author":[{"id":177,"nome":"Andréia Azevedo Soares","descricao":"Nasci no Rio de Janeiro, onde estudei jornalismo na Universidade Federal. Mudei-me para Portugal em 1999. Trabalho no PÚBLICO desde 2000, com duas interrupções – uma para um doutoramento em Comunicação de Ciência no Imperial College, em Londres, e outra para colaborar com a revista científica WHO Bulletin, em Genebra. Já fui estagiária, colaboradora, repórter e sub-editora em diferentes secções deste jornal. A ciência e a literatura são as áreas sobre as quais mais gosto de escrever; fascina-me o modo como o escritor e o cientista se empenham para detalhar e compreender o mundo que nos rodeia, incluindo os seres vivos que nele habitam.\r\n\r\n\r\n\r\n","email":"aasoares@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"andreia-azevedo-soares","imagem":{"w":null,"h":null,"largura":501,"altura":498,"nome":"andreia_soares-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1725026?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#114;&#97;&#111;&#115;&#97;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Estudo realizado com mais de 600 residentes no Porto revela que viver muito perto de árvores pode ajudar a combater o isolamento. A biodiversidade também oferece um amortecedor contra a solidão.","url":"/2026/02/17/azul/noticia/reduzir-solidao-idosos-cidades-apostar-jardins-proximidade-2164710","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Solidão","url":"https://www.publico.pt/2026/02/17/azul/noticia/reduzir-solidao-idosos-cidades-apostar-jardins-proximidade-2164710"},"id":2164710,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":25,"title":"Oeiras volta ao jazz no mês do Carnaval, com sete concertos e uma <i>masterclass</i>","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2066507?tp=UH&db=IMAGENS&type=JPG","author":[{"id":52,"nome":"Nuno Pacheco","descricao":"Integrar em 1989 a equipa fundadora do PÚBLICO, após oito anos no Expresso, foi um dos grandes desafios da minha vida, faltavam ainda uns anos para o advento revolucionário da Internet. Que não mudou a essência do que acredito que deve ser o jornalismo: uma mistura de ética, arte e busca incessante do que é novo. E isso é inseparável do tratamento dado à palavra, na forma como se escreve uma história, se formula uma ideia, se incentiva um debate. Por isso sou defensor acérrimo da diversidade da língua portuguesa, nas suas riquíssimas variantes, e adversário do acordo ortográfico de 1990. Em apoio desta posição, invoco o facto de escrever sobre música brasileira há quase duas décadas. Nasci no ano (e no mês) da morte de Carmen Miranda, Agosto de 1955, mas não acho que isso conte para esta história.","email":"nuno.pacheco@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Redactor-principal","profissaoNaAltura":"","slug":"nuno-pacheco","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Nuno_Pacheco-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1739377?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":"Nuno Pacheco","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#99;&#101;&#104;&#99;&#97;&#112;&#46;&#111;&#110;&#117;&#110;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Esgotadas as lotações no ano da estreia, 2025, o Festival Internacional de Jazz de Oeiras está de regresso já nesta quarta-feira com um programa diversificado e algumas surpresas.","url":"/2026/02/18/culturaipsilon/noticia/oeiras-volta-jazz-mes-carnaval-sete-concertos-masterclass-2164492","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Música","url":"https://www.publico.pt/2026/02/18/culturaipsilon/noticia/oeiras-volta-jazz-mes-carnaval-sete-concertos-masterclass-2164492"},"id":2164492,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":26,"title":"Negociações entre os EUA e o Irão progridem, mas ainda há trabalho pela frente","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2067847?tp=UH&db=IMAGENS&type=JPG","author":[{"id":4123,"nome":"João Ruela Ribeiro","descricao":"","email":"joao.ruela@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"joao-ruela-ribeiro","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#108;&#101;&#117;&#114;&#46;&#111;&#97;&#111;&#106;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Delegações dos dois países estiveram reunidas em Genebra para discutir acordo sobre o programa nuclear. As duas partes vão elaborar esboços do acordo para um futuro encontro.","url":"/2026/02/17/mundo/noticia/negociacoes-eua-irao-progridem-ha-trabalho-frente-2165098","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Médio Oriente","url":"https://www.publico.pt/2026/02/17/mundo/noticia/negociacoes-eua-irao-progridem-ha-trabalho-frente-2165098"},"id":2165098,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":27,"title":"Governo lança até 400 milhões para empresas e admite rever tecto de apoios agrícolas","i