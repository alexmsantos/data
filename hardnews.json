s.publico.pt/imagens.aspx/2074992?tp=UH&db=IMAGENS&type=JPG","author":[{"id":177,"nome":"Andréia Azevedo Soares","descricao":"Nasci no Rio de Janeiro, onde estudei jornalismo na Universidade Federal. Mudei-me para Portugal em 1999. Trabalho no PÚBLICO desde 2000, com duas interrupções – uma para um doutoramento em Comunicação de Ciência no Imperial College, em Londres, e outra para colaborar com a revista científica WHO Bulletin, em Genebra. Já fui estagiária, colaboradora, repórter e sub-editora em diferentes secções deste jornal. A ciência e a literatura são as áreas sobre as quais mais gosto de escrever; fascina-me o modo como o escritor e o cientista se empenham para detalhar e compreender o mundo que nos rodeia, incluindo os seres vivos que nele habitam.\r\n\r\n\r\n\r\n","email":"aasoares@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"andreia-azevedo-soares","imagem":{"w":null,"h":null,"largura":501,"altura":498,"nome":"andreia_soares-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1725026?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#114;&#97;&#111;&#115;&#97;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Decisão negativa da APA, apoiada num parecer do ICNF, trava projecto solar e turístico na zona do Alqueva. Empresas promotoras levantam dúvidas sobre a coerência do licenciamento ambiental.","url":"/2026/03/17/azul/noticia/colonia-morcegos-leva-chumbo-projecto-solar-turistico-alentejo-2168220","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Energia solar","url":"https://www.publico.pt/2026/03/17/azul/noticia/colonia-morcegos-leva-chumbo-projecto-solar-turistico-alentejo-2168220"},"id":2168220,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":9,"title":"Porto vai renegociar estacionamento à superfície para aumentar lugares de residentes","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2075007?tp=UH&db=IMAGENS&type=JPG","author":[{"id":4119,"nome":"Camilo Soldado","descricao":"","email":"camilo.soldado@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"camilo-soldado","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#100;&#97;&#100;&#108;&#111;&#115;&#46;&#111;&#108;&#105;&#109;&#97;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Autarquia vai conversar com a concessionária, mas ainda não são conhecidas as condições nem a dimensão do aumento. Orçamento municipal cresceu 98 milhões com incorporação de saldo de gerência.","url":"/2026/03/17/local/noticia/porto-vai-renegociar-estacionamento-superficie-aumentar-lugares-residentes-2168254","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Urbanismo","url":"https://www.publico.pt/2026/03/17/local/noticia/porto-vai-renegociar-estacionamento-superficie-aumentar-lugares-residentes-2168254"},"id":2168254,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":10,"title":"Megaprojecto na Fundição de Oeiras volta à discussão. Associação levanta preocupações","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2072039?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6052,"nome":"Teresa Serafim","descricao":"Estou no PÚBLICO desde 2016, depois de ter estudado Ciências da Comunicação na Faculdade de Ciências Sociais e Humanas da Universidade Nova de Lisboa. Escrevi durante sete anos sobre temas ligados à Ciência e estou agora na secção Local Lisboa do jornal.","email":"teresa.serafim@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"teresa-serafim","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Teresa Serafim.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1686947?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#109;&#105;&#102;&#97;&#114;&#101;&#115;&#46;&#97;&#115;&#101;&#114;&#101;&#116;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Para a Fundição de Oeiras, prevê-se a demolição de quase todas as estruturas existentes e a construção de edifícios, como um de 17 pisos. Moradores estão preocupados com densidade do projecto.","url":"/2026/03/17/local/noticia/megaprojecto-fundicao-oeiras-volta-discussao-associacao-levanta-preocupacoes-2166964","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Oeiras","url":"https://www.publico.pt/2026/03/17/local/noticia/megaprojecto-fundicao-oeiras-volta-discussao-associacao-levanta-preocupacoes-2166964"},"id":2166964,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":11,"title":"Buscas por causa de financiamento à Ryanair incluíram gabinete de Berta Cabral","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2074982?tp=UH&db=IMAGENS&type=JPG","author":[{"id":963,"nome":"Ana Henriques","descricao":"","email":"abhenriques@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"ana-henriques","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Ana_Henriques.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737742?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#117;&#113;&#105;&#114;&#110;&#101;&#104;&#98;&#97;","contribuicao":"","tipo":"INTERNO"},{"id":11437,"nome":"Rui Pedro Paiva","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"rui-pedro-paiva","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"INTERNO"},{"id":1068,"nome":"Luís Villalobos","descricao":"Comecei a trabalhar como jornalista profissional em 1992, na secção de economia do Semanário. Em 1994 apostei na vida de free-lancer, enquanto frequentava o curso de História, tendo colaborado para vários jornais e revistas. Em 2000 entrei para a revista Fortuna, da qual já era colaborador. Três anos depois tive a minha estreia nos diários, no Diário Económico, de onde transitei como editor para a Exame no final de 2005. Em 2007, cheguei ao PÚBLICO, para editar o suplemento de Economia. Actualmente, sou redactor da secção. Ganhei três prémios, o último dos quais na categoria nacional de imprensa e online do Ano Europeu do Combate à Pobreza e Exclusão Social. Sou co-autor do livro, “Negócios Vigiados”, sobre a PIDE e as empresas, e coordenei a obra “Quero um emprego!”, de Elisabete Sá, Raquel Almeida Correia e Ana Rute Silva.","email":"luis.villalobos@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"luis-villalobos","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Luis Villalobos.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1527219?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":",Sistema de gerenciamento de conteúdo","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#111;&#98;&#111;&#108;&#97;&#108;&#108;&#105;&#118;&#46;&#115;&#105;&#117;&#108;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Governo Regional dos Açores visado em inquérito onde se investiga a prática de fraude na obtenção de subsídio, prevaricação, participação económica em negócio e abuso de poder.","url":"/2026/03/17/sociedade/noticia/buscas-causa-esquema-financiamento-ryanair-incluiram-gabinete-berta-cabral-2168229","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Açores","url":"https://www.publico.pt/2026/03/17/sociedade/noticia/buscas-causa-esquema-financiamento-ryanair-incluiram-gabinete-berta-cabral-2168229"},"id":2168229,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":12,"title":"Restaurant Week da Lisbon Insiders garante menus exclusivos de 25 a 50 euros","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2074933?tp=UH&db=IMAGENS&type=JPG","author":[{"id":633,"nome":"Alexandra Prado Coelho","descricao":"Quando entrei no PÚBLICO, em 1989, entre os estagiários que participaram na aventura da fundação do jornal, queria muito trabalhar na secção Internacional. O mundo estava a mudar, em Berlim o Muro caía, Saddam Hussein invadia o Kuwait , usávamos telex e nem sonhávamos com a Internet. Durante 15 anos viajei pelo Médio Oriente, Rússia, Europa, Afeganistão. Depois, foi tempo de mudar e passei para a Cultura, onde escrevi sobre cinema, teatro, arquitectura, design, literatura. Em 2011 passei a acompanhar a área da alimentação – dos produtores aos restaurantes, das novas tendências gastronómicas à saúde. Porque, se há tema que cruza todos os países, culturas e pessoas, é o da comida.","email":"apc@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profis