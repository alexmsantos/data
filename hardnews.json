 Júlia.","email":"helena.pereira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Editora executiva","profissaoNaAltura":"Editora executiva","slug":"helena-pereira","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"helena-pereira-nova.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1739855?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":",Público","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#101;&#112;&#46;&#97;&#110;&#101;&#108;&#101;&#104;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"A proposta de Lei das Grandes Opções para 2025-2029, que deu entrada nesta terça-feira no Parlamento, estabelece nova meta de efectivos das Forças Armadas.","url":"/2026/04/21/politica/noticia/governo-fixa-nova-meta-3700-efectivos-militares-ate-fim-2027-2172060","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Forças Armadas","url":"https://www.publico.pt/2026/04/21/politica/noticia/governo-fixa-nova-meta-3700-efectivos-militares-ate-fim-2027-2172060"},"id":2172060,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"Efectivos da nova Brigada de Trânsito vão ser quase os mesmos que os actuais","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2082926?tp=UH&db=IMAGENS&type=JPG","author":[{"id":963,"nome":"Ana Henriques","descricao":"","email":"abhenriques@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"ana-henriques","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Ana_Henriques.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737742?tp=UH&db=