aoNaAltura":"","slug":"andrea-cunha-freitas","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#105;&#101;&#114;&#102;&#99;&#97;","contribuicao":"","tipo":"INTERNO"},{"id":7050,"nome":"Ana Maia","descricao":"","email":"amaia@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ana-maia","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#105;&#97;&#109;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Relatório <em>Lancet Countdown</em> sobre saúde e alterações climáticas na Europa divulgado esta terça-feira. Portugal surge como exemplo na área das renováveis, mas também vulnerável em muitas áreas.","url":"/2026/04/21/azul/noticia/impactos-saude-calor-extremo-portugal-espanha-sao-paises-vulneraveis-2171880","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Europa","url":"https://www.publico.pt/2026/04/21/azul/noticia/impactos-saude-calor-extremo-portugal-espanha-sao-paises-vulneraveis-2171880"},"id":2171880,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"Ucrânia sugeriu chamar “<em>Donnyland</em>” a território no Donbass para agradar a Trump","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2083069?tp=UH&db=IMAGENS&type=JPG","author":[{"id":5355,"nome":"António Saraiva Lima","descricao":"Pertenço a uma geração indefinida e vesti a camisola como poucos. Experimentei Direito, viajei e desviei-me. Pelo meio, escrevi. Licenciei-me em Ciência Política e Relações Internacionais, andei a debater sobre a Europa num <i>think tank</i>, e estagiei numa afamada organização internacional. Continuei a escrever. Tropecei no jornalismo em 2015, e logo no PÚBLICO, para um estágio na inigualável secção Mundo. Três meses de instrução diária, com os melhores dos melhores, que se alongaram para cinco. Sempre a escrever, mas também a perguntar e a ouvir. Ainda testei o ofício diplomático-consular, em Inglaterra, apenas para confirmar que a indefinição que me corria no sangue estava afinal fora de prazo. Voltei para Lisboa, realistei-me no jornalismo, pela mão do <i>i</i> e do <i>Sol</i>, e terminei um mestrado em Estudos Europeus. Permanentemente a escrever. No início de 2018 voltei à casa de partida – precisamente no meio do tabuleiro e deste texto.","email":"antonio.lima@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"antonio-saraiva-lima","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Antonio Saraiva Lima.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1527215?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":",Norges teknisk-naturvitenskaplige universitet","translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#109;&#105;&#108;&#46;&#111;&#105;&#110;&#111;&#116;&#110;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Fontes com conhecimento sobre as negociações entre Kiev e Washington ouvidas pelo <em>New York Times</em> dizem que a área em causa, na província de Donetsk, poderia servir como zona desmilitarizada.\r\n","url":"/2026/04/22/mundo/noticia/ucrania-sugeriu-chamar-donnyland-territorio-donbass-captar-interesse-trump-2172099","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Guerra na Ucrânia","url":"https://www.publico.pt/2026/04/22/mundo/noticia/ucrania-sugeriu-chamar-donnyland-territorio-donbass-captar-interesse-trump-2172099"},"id":2172099,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Influenciadores nas escolas: Inspecção de Educação continua a investigar directores","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2083023?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6039,"nome":"Cristiana Faria Moreira","descricao":"","email":"cristiana.moreira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"cristiana-faria-moreira","imagem":{"w":null,"h":null,"largura":225,"altura":225,"nome":"Cristiana Faria Moreira.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1602146?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#111;&#109;&#46;&#97;&#110;&#97;&#105;&#116;&#115;&#105;&#114;&#99;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Ministro admite falhas nas escolas que permitiram a entrada de influenciadores e quer reforçar controlo de entidades externas. E diz que não há desinvestimento no Plano Nacional de Leitura.","url":"/2026/04/22/sociedade/noticia/influenciadores-escolas-inspeccao-educacao-continua-investigar-directores-2172083","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Educação","url":"https://www.publico.pt/2026/04/22/sociedade/noticia/influenciadores-escolas-inspeccao-educacao-continua-investigar-directores-2172083"},"id":2172083,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"“Já pesquisei tudo e ainda não sei o que fazer”: o novo problema das famílias","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2080261?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Neste artigo, Cláudio Santos, administrador da Rede Doutor Finanças, reflecte sobre co