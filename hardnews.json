2100?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Uma escapadinha na natureza a uma hora de Lisboa","url":"/2026/04/17/estudiop/noticia/natureza-pressa-pausa-revigorante-hora-lisboa-2171598","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Huttopia","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2082090?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/04/17/estudiop/noticia/natureza-pressa-pausa-revigorante-hora-lisboa-2171598"},"id":2171598,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":2,"title":"Entidade para a Transparência só fiscalizou 10% das declarações de políticos até 2026","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2083829?tp=UH&db=IMAGENS&type=JPG","author":[{"id":820,"nome":"Álvaro Vieira","descricao":"Entrei no PÚBLICO em 1996, por uma porta grande: a pequena delegação de Coimbra, onde se tinham feito grandes profissionais. Foram-me deixando ficar. O meu percurso, até então, passara quase exclusivamente pela rádio. Foi no PÚBLICO que conclui que os jornais que tinha feito na escola haviam de querer dizer alguma coisa. Na delegação de Coimbra, fiz um bocado de tudo, mas sobretudo Cultura. Na redacção do Porto, onde também comecei a trabalhar em 2005 e me fixei em 2007, trabalhei essencialmente como editor nas secções Local, Política e Opinião.","email":"avieira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"alvaro-vieira","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Alvaro_Vieira.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737728?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#105;&#118;&#97;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Órgão que funciona junto do Tribunal Constitucional só concluiu a verificação de 883 das 8620 declarações de rendimentos, património, interesses e incompatibilidades recebidas entre 20024 e 2025.","url":"/2026/04/25/politica/noticia/entidade-transparencia-so-fiscalizou-10-declaracoes-politicos-ate-2026-2172341","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Transparência","url":"https://www.publico.pt/2026/04/25/politica/noticia/entidade-transparencia-so-fiscalizou-10-declaracoes-politicos-ate-2026-2172341"},"id":2172341,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"O Porto que se lê entre o <em>graffiti</em>, a poesia e a arqueologia","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2083976?tp=UH&db=IMAGENS&type=JPG","author":[{"id":4902,"nome":"Andreia Marques Pereira","descricao":"","email":"andreia.pereira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"andreia-marques-pereira","imagem":{"w":null,"h":null,"largura":720,"altura":720,"nome":"#f15_1 COL (para usar a carinha).jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1470490?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#114;&#101;&#112;&#46;&#97;&#105;&#101;&#114;&#100;&#110;&#97;","contribuicao":"texto","tipo":"INTERNO"},{"id":3917,"nome":"Nelson Garrido","descricao":"Nasci em Vila Nova de Gaia, Portugal. Em 1996 concluí o bacharelato em Tecnologias da Comunicação Audiovisual. No mesmo ano, frequentei uma formação avançada em fotografia na escola Karel de Grote-Hogescholl Antwerpen, na Bélgica, e fiz um estágio em fotografia digital e de grande formato no Studio Brison, também na Bélgica. Em Portugal, trabalhei em regime de freelancer com várias revistas, na área da fotografia de reportagem e de arquitectura. Em 2000, concluí a licenciatura em Comunicação Social e em 2005 a Licenciatura em Fotografia. Em 2005, ganhei três menções honrosas no concurso de fotojornalismo da revista Visão e venci a categoria de fotografia de arquitectura do Euro Press Photo Awards da Fuji Film. Fui premiado no Prémio Estação Imagem|Mora em 2010 e 2011. Desde 1999, sou fotojornalista no PÚBLICO.","email":"ngarrido@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"nelson-garrido","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Nelson_Garrido.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737874?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#100;&#105;&#114;&#114;&#97;&#103;&#110;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"Nem sempre é nas grandes vistas que o Porto melhor se mostra. Às vezes, está num mural, noutras numa casa da Foz transformada em biblioteca poética. Há várias maneiras de a cidade se guardar.","url":"/2026/04/25/fugas/reportagem/porto-le-graffiti-poesia-arqueologia-2171031","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"fugas"},"brand":null,"rubric":{"name":"Reportagem","url":"/passeios"},"id":2171031,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":8441,"nome":"Passeios","slug":"passeios","tagEn":"","isPrincipal":false,"isVisible":true,"urlRoute":"/tpasseios","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAber