MultipleRubric":false,"tag":null,"size":30},{"pos":19,"title":"Obesidade: vencer o desafio da (in)visibilidade crónica","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2090236?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"No Dia Nacional de Luta Contra a Obesidade, contam-se histórias que não podem esperar, no MAAT Central.","url":"/2026/05/23/estudiop/noticia/obesidade-vencer-desafio-invisibilidade-cronica-2175533","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Lilly","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2071063?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/05/23/estudiop/noticia/obesidade-vencer-desafio-invisibilidade-cronica-2175533"},"id":2175533,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":20,"title":"Bad Bunny aterrou em Lisboa e de um estádio fez uma ilha, Porto Rico","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2091156?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1034,"nome":"Mário Lopes","descricao":"A culpa é de um gira-discos e dos discos que o meu pai rodava no gira-discos. A música chegou primeiro. Como com a maioria dos adolescentes, a música moldou-me gostos e atitudes, os discos foram guias para a descoberta do mundo. Através deles, cheguei a livros, a cinema, a nomes e mais nomes e a outros discos, outros livros, outros filmes. Foi pela música que cheguei ao jornalismo. Primeiro no Blitz, onde entrei estagiário no final do curso de Ciências da Comunicação e que seria, posteriormente, a casa do meu primeiro emprego. Depois no Diário de Notícias, onde a música começou a significar mais jornalismo, aberto a mais que bandas e discos. Ao PÚBLICO cheguei em 2005. Para escrever maioritariamente sobre música. Para, através da música, chegar a outros universos da cultura. E para, através da cultura, tentar compreender melhor o mundo e, escrevendo sobre ela, tentar mostrá-lo o mais claramente possível. A adolescência já lá vai há muito. Discos, livros, filmes, continuam a ser guias de descoberta. Assim sendo, continuarei.","email":"mario.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"mario-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Mario_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/860961?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#111;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Entre o palco montado como salão de baile e uma casa típica, Bad Bunny foi elegância clássica a bailar salsa e rei do perreo muito moderno. Duas horas e meia de festa e celebração no Estádio da Luz.","url":"/2026/05/27/culturaipsilon/critica/bad-bunny-aterrou-lisboa-estadio-fez-ilha-porto-rico-2176143","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Crítica","url":"/musica"},"id":2176143,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":708,"nome":"Música","slug":"musica","tagEn":"","isPrincipal":false,"isVisible":true,"urlRoute":"/tmusica","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAberto":false,"follow_type":null,"descricao":null,"imagem":null,"html":null,"isForForuns":true,"isUsedInForuns":false},"size":30},{"pos":21,"title":"No Monte da Caparica, moradores fizeram um filme para mostrar a sua vida comunitária","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2091028?tp=UH&db=IMAGENS&type=JPG","author":[{"id":6052,"nome":"Teresa Serafim","descricao":"Estou no PÚBLICO desde 2016, depois de ter estudado Ciências da Comunicação na Facul