,"url":"/2026/03/10/politica/noticia/aliados-desavindos-momentos-escalada-tensao-passos-montenegro-2167248","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"PSD","url":"https://www.publico.pt/2026/03/10/politica/noticia/aliados-desavindos-momentos-escalada-tensao-passos-montenegro-2167248"},"id":2167248,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Dia Mundial da Obesidade: menos estigma mais acção (urgente)","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2071252?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Substituir o julgamento e o estigma por mais empatia e acção é o apelo neste Dia Mundial da Obesidade.","url":"/2026/03/04/estudiop/noticia/dia-mundial-obesidade-menos-estigma-accao-urgente-2166540","comments":1,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Lilly","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2071063?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/03/04/estudiop/noticia/dia-mundial-obesidade-menos-estigma-accao-urgente-2166540"},"id":2166540,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"Finanças investigam forte aumento de exportações para parceiros da Rússia","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2072937?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1053,"nome":"Sérgio Aníbal","descricao":"Sou jornalista desde 1998, tendo começado pouco tempo depois de ter concluído a minha licenciatura em economia no ISEG. Nesse ano, fiz um estágio não-remunerado de três meses no Semanário Económico, jornal onde acabei por ficar durante seis anos, como redactor, primeiro, e como editor da secção de Economia, no final. Passei depois pelo Jornal de Negócios e pelo Diário de Notícias, chegando finalmente ao PÚBLICO em 2006. Sempre a cobrir temas económicos. Nos últimos anos, a crise financeira internacional e a crise da dívida soberana europeia têm ocupado grande parte do meu tempo e atenção.","email":"sergio.anibal@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"sergio-anibal","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Sergio_Anibal.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737905?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#108;&#97;&#98;&#105;&#110;&#97;&#46;&#111;&#105;&#103;&#114;&#101;&#115;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"As sanções travaram as exportações portuguesas para a Rússia. Mas, ao mesmo tempo, as vendas para países terceiros, por exemplo de cortiça, aumentaram. As Finanças garantem que estão a investigar.\r\n","url":"/2026/03/10/economia/noticia/exportacoes-paises-proximos-russia-dispararam-financas-investigam-2167340","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Guerra na Ucrânia","url":"https://www.publico.pt/2026/03/10/economia/noticia/exportacoes-paises-proximos-russia-dispararam-financas-investigam-2167340"},"id":2167340,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":9,"title":"<em>Operação Marquês</em>: novo advogado de Sócrates pede para abandonar defesa","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2072981?tp=UH&db=IMAGENS&type=JPG","author":[{"id":963,"nome":"Ana Henriques","descricao":"","email":"abhenriques@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ana-henriques","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Ana_Henriques.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737742?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#117;&#113;&#105;&#114;&#110;&#101;&#104;&#98;&#97;","contribuicao":"","tipo":"INTERNO"},{"id":1050,"nome":"Mariana Oliveira","descricao":"Nasci no Porto em 1978 e fiz a licenciatura em Direito na Faculdade de Direito da Universidade do Porto. Quando optei por este curso, já tinha a intenção de me tornar jornalista, seguindo o conselho de alguns profissionais da classe. Depois de terminar a licenciatura, candidatei-me à Formação Geral – Especialização em Jornalismo no Centro Protocolar de Formação Profissional para Jornalistas (Cenjor), em Lisboa. Por isso vivi na capital quase oito meses, entre Dezembro de 2001 e Julho de 2002. Nesse mês, decidi regressar ao Porto para fazer o estágio integrado nessa formação. Fui jornalista estagiária no PÚBLICO entre Julho e Outubro e comecei a trabalhar em Fevereiro de 2003. No início, cobri mais intensivamente áreas ligadas à protecção civil. Actualmente, dedico-me à área da Justiça.","email":"meoliveira@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"mariana-oliveira","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#105;&#101;&#118;&#105;&#108;&#111;&#101;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Marco António Amaro foi nomeado de “forma automática e aleatória” pelo sistema informático e pediu agora dispensa.","url":"/2026/03/10/sociedade/noticia/operacao-marques-novo-advogado-oficioso-socrates-pede-abandonar-defesa-2167374","comments":0,"spoonsored":false,"isOpinion":false,"hom