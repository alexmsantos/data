,"author":[{"id":12425,"nome":"Inês Duarte de Freitas","descricao":"","email":"ines.freitas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ines-duarte-freitas","imagem":{"w":null,"h":null,"largura":344,"altura":320,"nome":"WhatsApp_Image_2023-02-01_at_13.49.04-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1775300?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#105;&#101;&#114;&#102;&#46;&#115;&#101;&#110;&#105;","contribuicao":"texto","tipo":"INTERNO"},{"id":3983,"nome":"Rui Gaudêncio","descricao":"","email":"rgaudencio@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Fotojornalista","profissaoNaAltura":"","slug":"rui-gaudencio","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#105;&#99;&#110;&#101;&#100;&#117;&#97;&#103;&#114;","contribuicao":"fotografia","tipo":"INTERNO"}],"shares":0,"description":"<em>Arte & Moda</em> reúne 140 peças de alta-costura com 100 obras do Museu Gulbenkian numa reflexão sobre beleza, explica o curador Eloy Martínez de la Pera Celada, que trabalhou quatro anos na exposição.","url":"/2026/04/18/impar/reportagem/gulbenkian-ja-mostrou-arte-faltavalhe-moda-2171745","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":{"name":"impar"},"brand":null,"rubric":{"name":"Reportagem","url":"/moda"},"id":2171745,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":21,"title":"“Já pesquisei tudo e ainda não sei o que fazer”: o novo problema das famílias","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2080261?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Neste artigo, Cláudio Santos, administrador da Rede Doutor Finanças, reflecte sobre como, num mercado financeiro com tantas ofertas, o desafio é identificar a melhor solução para cada caso.","url":"/2026/04/16/estudiop/noticia/ja-pesquisei-nao-sei-novo-problema-familias-2170663","comments":2,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"Doutor Finanças","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2071323?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/04/16/estudiop/noticia/ja-pesquisei-nao-sei-novo-problema-familias-2170663"},"id":2170663,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":22,"title":"Nunca existiu essa coisa chamada world music","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2082383?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1034,"nome":"Mário Lopes","descricao":"A culpa é de um gira-discos e dos discos que o meu pai rodava no gira-discos. A música chegou primeiro. Como com a maioria dos adolescentes, a música moldou-me gostos e atitudes, os discos foram guias para a descoberta do mundo. Através deles, cheguei a livros, a cinema, a nomes e mais nomes e a outros discos, outros livros, outros filmes. Foi pela música que cheguei ao jornalismo. Primeiro no Blitz, onde entrei estagiário no final do curso de Ciências da Comunicação e que seria, posteriormente, a casa do meu primeiro emprego. Depois no Diário de Notícias, onde a música começou a significar mais jornalismo, aberto a mais que bandas e discos. Ao PÚBLICO cheguei em 2005. Para escrever maioritariamente sobre música. Para, através da música, chegar a outros universos da cultura. E para, através da cultura, tentar compreender melhor o mundo e, escrevendo sobre ela, tentar mostrá-lo o mais claramente possível. A adolescência já lá vai há muito. Discos, livros, filmes, continuam a ser guias de descoberta. Assim sendo, continuarei.","email":"mario.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"em Marselha","profissaoActual":"","profissaoNaAltura":"","slug":"mario-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Mario_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/860961?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#111;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Deu visibilidade a músicos fora do eixo anglo-americano mas, ao mesmo tempo, exotizou e excluiu. Que significa hoje? Olivier Rey e Frédérique André, do Babel Music XP, falam do mundo pós world music.","url":"/2026/04/19/culturaipsilon/noticia/existiu-chamada-world-music-2171488","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Música","url":"https://www.publico.pt/2026/04/19/culturaipsilon/noticia/existiu-chamada-world-music-2171488"},"id":2171488,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":23,"title":"Leapmotor C10 REEV, um “eléctrico” para acabar com a ansiedade de autonomia","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2081041?tp=UH&db=IMAGENS&type=JPG","author":[{"id":7156,"nome":"Pedro Esteves","descricao":"Durante 20 anos fui profissional de saúde, professor, locutor de rádio (TSF) e televisão. Fiz parte da equipa que fundou o Observador, onde falei de música e de tecnologia em formato multimédia. O desafio? Continuar a fazer do PÚBLICO um meio digital de referência.","email":"pesteves@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista e editor online","profissaoNa