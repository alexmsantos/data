ooglePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"lusa","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"","contribuicao":"","tipo":"AGENCIA"}],"shares":0,"description":"À luz dos actuais estautos, Miguel Albuquerque deixaria de ser líder do PSD/Madeira em 2029, quando terminasse o mandato como chefe do executivo madeirense.","url":"/2026/04/18/politica/noticia/psdmadeira-altera-estatutos-permitir-albuquerque-continue-lideranca-2171742","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Congresso","url":"https://www.publico.pt/2026/04/18/politica/noticia/psdmadeira-altera-estatutos-permitir-albuquerque-continue-lideranca-2171742"},"id":2171742,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":9,"title":"Bloco quer ouvir presidente da CIG e ministra da Cultura sobre identidade de género","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2082414?tp=UH&db=IMAGENS&type=JPG","author":[{"id":157,"nome":"Maria Lopes","descricao":"Entrei para o PÚBLICO, vinda da universidade, quando se vivia a excitação das vésperas da primeira Exposição Mundial em Portugal. Calcorreei a Expo-98 de fio a pavio, de caderno, caneta e, por vezes, de Polaroid na mão. Esses poucos meses ensinaram-me a conjugar o verbo tão português “desenrascar-se”.\r\nNestes mais de 20 anos, passei depois pelas secções Local, Media (por duas vezes) e Economia. Estive no lançamento do suplemento Digital – que apesar do nome existiu apenas em papel – e pertenci à equipa do irreverente projecto Sexta, o jornal gratuito que o PÚBLICO partilhou com A Bola, em 2007 e 2008. Em simultâneo, durante dez anos, escrevi também para o Motores (da Fugas), vivendo os automóveis sob uma perspectiva menos técnica e mais prazenteira. Desde 2009 que integro a secção de Política e tento manter debaixo de olho o panorama dos media. \r\n\r\n","email":"maria.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"maria-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Maria_C_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737865?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#97;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Pedido surge depois de o PÚBLICO ter noticiado que os técnicos da CIG produziram um parecer crítico dos projectos sobre autodeterminação de género, mas o que chegou à AR foi uma “nota técnica”.","url":"/2026/04/18/politica/noticia/bloco-quer-ouvir-presidente-cig-ministra-cultura-urgencia-identidade-genero-2171743","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Assembleia da República","url":"https://www.publico.pt/2026/04/18/politica/noticia/bloco-quer-ouvir-presidente-cig-ministra-cultura-urgencia-identidade-genero-2171743"},"id":2171743,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":10,"title":"Como transformar armazéns vazios em negócios rentáveis?","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2080206?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"A falta de espaço nas cidades está a impulsionar o crescimento de espaços de <em>self-storage</em> — e a  SSolid está a transformar armazéns vazios em negócios rentáveis.","url":"/2026/04/13/estudiop/noticia/transformar-armazens-vazios-negocios-rentaveis-2170661","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"SSolid","ImageUrl":"https://imagens.publico.pt/imagens.aspx/2080134?tp=UH&db=IMAGENS","slug":