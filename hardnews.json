33?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#114;&#105;&#101;&#108;&#97;&#118;&#97;&#99;&#46;&#111;&#103;&#111;&#105;&#100;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Riscos para a inflação, energia afectada e ameaças ao crescimento: tudo factores que levam Christine Lagarde a manter-se em funções no Banco Central Europeu. E deixa uma promessa: “não vamos hesitar”.","url":"/2026/04/14/economia/noticia/capita-lagarde-nao-sai-antecipadamente-bce-nuvens-horizonte-2171212","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Banca Central","url":"https://www.publico.pt/2026/04/14/economia/noticia/capita-lagarde-nao-sai-antecipadamente-bce-nuvens-horizonte-2171212"},"id":2171212,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":8,"title":"Demolição do Edifício Transparente avança já em 2027","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2081192?tp=UH&db=IMAGENS&type=JPG","author":[{"id":3419,"nome":"Mariana Correia Pinto","descricao":"","email":"mariana.pinto@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"mariana-correia-pinto","imagem":{"w":null,"h":null,"largura":216,"altura":216,"nome":"mariana correia pinto.JPG","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1446489?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#111;&#116;&#110;&#105;&#112;&#46;&#97;&#110;&#97;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"A “componente técnica” está por definir e o autarca do Porto