brand":null,"rubric":{"name":"Irão","url":"https://www.publico.pt/2026/03/16/mundo/noticia/uniao-europeia-resiste-pressao-trump-recusa-envolverse-guerra-irao-2168113"},"id":2168113,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":17,"title":"Ricardo Ribeiro e esta voz que é janela aberta para a vastidão do mundo","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2074941?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1034,"nome":"Mário Lopes","descricao":"A culpa é de um gira-discos e dos discos que o meu pai rodava no gira-discos. A música chegou primeiro. Como com a maioria dos adolescentes, a música moldou-me gostos e atitudes, os discos foram guias para a descoberta do mundo. Através deles, cheguei a livros, a cinema, a nomes e mais nomes e a outros discos, outros livros, outros filmes. Foi pela música que cheguei ao jornalismo. Primeiro no Blitz, onde entrei estagiário no final do curso de Ciências da Comunicação e que seria, posteriormente, a casa do meu primeiro emprego. Depois no Diário de Notícias, onde a música começou a significar mais jornalismo, aberto a mais que bandas e discos. Ao PÚBLICO cheguei em 2005. Para escrever maioritariamente sobre música. Para, através da música, chegar a outros universos da cultura. E para, através da cultura, tentar compreender melhor o mundo e, escrevendo sobre ela, tentar mostrá-lo o mais claramente possível. A adolescência já lá vai há muito. Discos, livros, filmes, continuam a ser guias de descoberta. Assim sendo, continuarei.","email":"mario.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"mario-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Mario_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/860961?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#111;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"<em>A Alma Só Está Bem Onde Não Cabe</em> é voz fadista, voz magrebina, voz alentejana, voz andaluza, a dar-se às palavras com sabedoria e uma consciência aguda, inata, das emoções que carregam.","url":"/2026/03/17/culturaipsilon/critica/ricardo-ribeiro-voz-janela-aberta-vastidao-mundo-2168112","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Crítica","url":"/musica"},"id":2168112,"type":"NOTICIA","isMultipleRubric":true,"tag":{"id":708,"nome":"Música","slug":"musica","tagEn":"","isPrincipal":false,"isVisible":true,"urlRoute":"/tmusica","isPrincipalParaArtigo":true,"isTimeLine":false,"forcaConteudoAberto":false,"follow_type":null,"descricao":null,"imagem":null,"html":null,"isForForuns":true,"isUsedInForuns":false},"size":30},{"pos":18,"title":"John Galliano vai revisitar os arquivos para desenhar colecções para a Zara","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2074975?tp=UH&db=IMAGENS&type=JPG","author":[{"id":12425,"nome":"Inês Duarte de Freitas","descricao":"","email":"ines.freitas@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"ines-duarte-freitas","imagem":{"w":null,"h":null,"largura":344,"altura":320,"nome":"WhatsApp_Image_2023-02-01_at_13.49.04-removebg-preview.png","legenda":null,"autor":null,"tipo":"PNG","url":"https://imagens.publico.pt/imagens.aspx/1775300?tp=UH&db=IMAGENS&type=PNG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#97;&#116;&#105;&#101;&#114;&#102;&#46;&#115;&#101;&#110;&#105;","contribuicao":"","tipo":"INTERNO"}],"s