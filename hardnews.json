[{"pos":0,"title":"Violência sexual: 70% das vítimas conhecem o agressor, mas apenas um terço denuncia","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2076607?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19963,"nome":"Catarina Pinho","descricao":"","email":"","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"jornalista estagiária","profissaoNaAltura":"jornalista estagiária","slug":"catarina-pinho","imagem":null,"hasImage":false,"isExternal":true,"encodedEmail":"","contribuicao":"","tipo":"EXTERNO"}],"shares":0,"description":"Mais de metade das testemunhas que assistiram a casos de violência sexual não tentaram ajudar a vítima e mais de 50% dos casos são repetidos pelo mesmo agressor. Vítima mais jovem tinha três anos.","url":"/2026/03/25/sociedade/noticia/violencia-sexual-70-vitimas-conhecem-agressor-apenas-terco-consegue-denunciar-2168884","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Violência","url":"https://www.publico.pt/2026/03/25/sociedade/noticia/violencia-sexual-70-vitimas-conhecem-agressor-apenas-terco-consegue-denunciar-2168884"},"id":2168884,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":1,"title":"Prémio de 1,4 milhões apoia projectos que combatem a pobreza infantil em Portugal","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2065971?tp=UH&db=IMAGENS&type=JPG","author":[],"shares":0,"description":"Estão abertas as candidaturas ao Prémio BPI Fundação ”la Caixa” Infância, cujo objectivo é auxiliar quem luta para quebrar o círculo vicioso de crianças e adolescentes em situação de vulnerabilidade.","url":"/2026/02/23/estudiop/noticia/premio-14-milhoes-apoia-projectos-combatem-pobreza-infantil-portugal-2164226","comments":0,"spoonsored":true,"isOpinion":false,"homeBrand":null,"brand":{"id":0,"name":"BPI La Caixa","ImageUrl":"https://imagens.publico.pt/imagens.aspx/1779903?tp=UH&db=IMAGENS","slug":null,"url":null},"rubric":{"name":"Conteúdo comercial","url":"https://www.publico.pt/2026/02/23/estudiop/noticia/premio-14-milhoes-apoia-projectos-combatem-pobreza-infantil-portugal-2164226"},"id":2164226,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":2,"title":"Banco de Portugal prevê menos crescimento e inflação nos 2,8% este ano","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2076702?tp=UH&db=IMAGENS&type=JPG","author":[{"id":1053,"nome":"Sérgio Aníbal","descricao":"Sou jornalista desde 1998, tendo começado pouco tempo depois de ter concluído a minha licenciatura em economia no ISEG. Nesse ano, fiz um estágio não-remunerado de três meses no Semanário Económico, jornal onde acabei por ficar durante seis anos, como redactor, primeiro, e como editor da secção de Economia, no final. Passei depois pelo Jornal de Negócios e pelo Diário de Notícias, chegando finalmente ao PÚBLICO em 2006. Sempre a cobrir temas económicos. Nos últimos anos, a crise financeira internacional e a crise da dívida soberana europeia têm ocupado grande parte do meu tempo e atenção.","email":"sergio.anibal@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"sergio-anibal","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Sergio_Anibal.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737905?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#108;&#97;&#98;&#105;&#110;&#97;&#46;&#111;&#105;&#103;&#114;&#101;&#115;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Entidade liderada por Álvaro Santos Pereira prevê inflação a subir até aos 2,8% este ano e voltou a colocar o crescimento da economia abaixo dos 2%.","url":"/2026/03/25/economia/noticia/menos-crescimento-inflacao-guerra-irao-faz-banco-portugal-ficar-pessimista-2169041","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"PIB","url":"https://www.publico.pt/2026/03/25/economia/noticia/menos-crescimento-inflacao-guerra-irao-faz-banco-portugal-ficar-pessimista-2169041"},"id":2169041,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":3,"title":"Irão rejeita proposta americana e apresenta condições para um cessar-fogo","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2076805?tp=UH&db=IMAGENS&type=JPG","author":[{"id":4038,"nome":"João Pedro Pincha","descricao":"Se não tivesse passado seis meses em Barcelona, provavelmente nunca me teria interessado por escrever sobre Lisboa. Foi na Catalunha que descobri, enquanto estagiava na televisão local, que a esquina mais próxima pode ser tão interessante como o outro lado do mundo. Meses depois, quando entrei no PÚBLICO pela primeira vez, já só queria estagiar na secção Local. E assim me iniciei a acompanhar tudo o que se passava na capital. Ainda passei brevemente pelo <i>O Corvo</i> antes de ajudar a fundar o <i>Observador</i>, onde estive quase três anos. Depois de cinco anos a acompanhar para o PÙBLICO a actualidade lisboeta e arredores, escrevo agora para a secção Mundo.","email":"joao.pincha@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"","profissaoNaAltura":"","slug":"joao-pedro-pincha","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Joao P Pincha.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/1332529?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#104;&#99;&#110;&#105;&#112;&#46;&#111;&#97;&#111;&#106;","contribu