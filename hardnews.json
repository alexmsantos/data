o":"","email":"filipe.santabarbara@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"Jornalista","slug":"filipe-santabarbara","imagem":null,"hasImage":false,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#97;&#114;&#97;&#98;&#114;&#97;&#98;&#97;&#116;&#110;&#97;&#115;&#46;&#101;&#112;&#105;&#108;&#105;&#102;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Primeiro-ministro desvalorizou adesão à greve e apelou à reflexão dos sindicatos sobre “consequências” destas jornadas de luta. Sobre lei laboral, admite aproximações “num ou outro ponto”.","url":"/2026/06/03/politica/noticia/montenegro-consequencia-greve-final-dia-pareceme-passou-apenas-prejudicar-vida-gente-2177060","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Greve geral","url":"https://www.publico.pt/2026/06/03/politica/noticia/montenegro-consequencia-greve-final-dia-pareceme-passou-apenas-prejudicar-vida-gente-2177060"},"id":2177060,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":6,"title":"Ciente de poder levar leis ao TC, candidata a provedora de Justiça diz-se “comedida”","isPremium":true,"image":"https://imagens.publico.pt/imagens.aspx/2093145?tp=UH&db=IMAGENS&type=JPG","author":[{"id":157,"nome":"Maria Lopes","descricao":"Entrei para o PÚBLICO, vinda da universidade, quando se vivia a excitação das vésperas da primeira Exposição Mundial em Portugal. Calcorreei a Expo-98 de fio a pavio, de caderno, caneta e, por vezes, de Polaroid na mão. Esses poucos meses ensinaram-me a conjugar o verbo tão português “desenrascar-se”.\r\nNestes mais de 20 anos, passei depois pelas secções Local, Media (por duas vezes) e Economia. Estive no lançamento do suplemento Digital – que apesar do nome existiu apenas em papel – e pertenci à equipa do irreverente projecto Sexta, o jornal gratuito que o PÚBLICO partilhou com A Bola, em 2007 e 2008. Em simultâneo, durante dez anos, escrevi também para o Motores (da Fugas), vivendo os automóveis sob uma perspectiva menos técnica e mais prazenteira. Desde 2009 que integro a secção de Política e tento manter debaixo de olho o panorama dos media. \r\n\r\n","email":"maria.lopes@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null,"url":null,"localizacao":"","profissaoActual":"Jornalista","profissaoNaAltura":"","slug":"maria-lopes","imagem":{"w":null,"h":null,"largura":null,"altura":null,"nome":"Maria_C_Lopes.jpg","legenda":null,"autor":null,"tipo":"JPG","url":"https://imagens.publico.pt/imagens.aspx/737865?tp=UH&db=IMAGENS&type=JPG","is_vertical":false,"tags":null,"translations":null},"hasImage":true,"isExternal":false,"encodedEmail":"&#116;&#112;&#46;&#111;&#99;&#105;&#108;&#98;&#117;&#112;&#64;&#115;&#101;&#112;&#111;&#108;&#46;&#97;&#105;&#114;&#97;&#109;","contribuicao":"","tipo":"INTERNO"}],"shares":0,"description":"Luísa Neto, indicada pelo PS, foi largamente elogiada por todos os partidos por comparação com Tiago Antunes. Candidata levou aos deputados uma lista de desafios a que a Provedoria deve responder.","url":"/2026/06/03/politica/noticia/ciente-levar-leis-tc-candidata-provedora-justica-dizse-comedida-2177045","comments":0,"spoonsored":false,"isOpinion":false,"homeBrand":null,"brand":null,"rubric":{"name":"Provedoria de Justiça","url":"https://www.publico.pt/2026/06/03/politica/noticia/ciente-levar-leis-tc-candidata-provedora-justica-dizse-comedida-2177045"},"id":2177045,"type":"NOTICIA","isMultipleRubric":false,"tag":null,"size":30},{"pos":7,"title":"Portugal eleito como membro não permanente do Conselho de Segurança da ONU","isPremium":false,"image":"https://imagens.publico.pt/imagens.aspx/2093189?tp=UH&db=IMAGENS&type=JPG","author":[{"id":19373,"nome":"Pedro Candeias","descricao":"","email":"pmcandeias@publico.pt","facebook":null,"googlePlus":null,"twitter":null,"site":null